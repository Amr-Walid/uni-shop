+        public bool IsMain { get; set; } = false;
+        public int SortOrder { get; set; } = 0;
+
+        public Product Product { get; set; } = null!;
+    }
+
+    // ── ATTRIBUTE ─────────────────────────────────────────────────────────────
+    public class ProductAttribute
+    {
