+@model FTD.Web.ViewModels.ProductDetailViewModel
+@{
+    var p = Model.Product;
+    ViewData["Title"] = p.NameAr;
+    var badgeClass = p.Badge switch
+    {
+        "NEW" => "badge-blue",
+        "HOT" => "badge-green",
+        "4K" => "badge-orange",
+        _ => "badge-dark"
+    };
+}
+<div class="product-detail-page">
+    <!-- BREADCRUMB -->
+    <div class="breadcrumb">
+        <a href="/"><span data-ar>الرئيسية</span><span data-en>Home</span></a>
+        <span class="breadcrumb-sep">/</span>
+        <a href="/Products?category=@p.Category?.Slug">
+            <span data-ar>@p.Category?.NameAr</span><span data-en>@p.Category?.NameEn</span>
+        </a>
+        <span class="breadcrumb-sep">/</span>
+        <span><span data-ar>@p.NameAr</span><span data-en>@p.NameEn</span></span>
+    </div>
+    <div class="detail-grid">
+        <!-- IMAGE COLUMN -->
+        @{
+            var allImages = new List<string>();
+            if (!string.IsNullOrEmpty(p.ImagePath)) allImages.Add(p.ImagePath);
+            foreach (var img in p.Images.OrderBy(i => i.SortOrder))
+                if (!allImages.Contains(img.ImagePath)) allImages.Add(img.ImagePath);
+        }
+        <div>
+            <!-- MAIN IMAGE / SLIDER -->
+            <div class="detail-img-wrap" style="position:relative;border-radius:20px;overflow:hidden">
+                @if (!string.IsNullOrEmpty(p.Badge))
+                {
+                    <span class="detail-badge @badgeClass" style="z-index:5">@p.Badge</span>
+                }
+                @if (allImages.Count > 1)
+                {
+                    <div class="pslider" id="pslider_@p.Id">
+                        @for (int si = 0; si < allImages.Count; si++)
+                        {
+                            <div class="pslide @(si == 0 ? "active" : "")" data-idx="@si">
+                                <img src="@allImages[si]" alt="@p.NameEn @(si + 1)"
+                                     style="width:100%;max-height:340px;object-fit:contain;padding:2rem;background:var(--bg)">
+                            </div>
+                        }
+                        <button class="pslider-arrow pslider-prev" onclick="pslide(@p.Id,-1)">&#8249;</button>
+                        <button class="pslider-arrow pslider-next" onclick="pslide(@p.Id, 1)">&#8250;</button>
+                    </div>
+                }
+                else if (allImages.Count == 1)
+                {
+                    <img src="@allImages[0]" alt="@p.NameEn"
+                         style="width:100%;max-height:340px;object-fit:contain;padding:2rem;background:var(--bg)">
+                }
+                else
+                {
+                    <span style="font-size:8rem;padding:2rem;display:flex;align-items:center;justify-content:center;min-height:280px">@(p.Emoji ?? "📦")</span>
+                }
+            </div>
+
+            <!-- THUMBNAILS — تحت الصورة مباشرة -->
+            @if (allImages.Count > 1)
+            {
+                <div class="pslider-thumbs" id="pthumbs_@p.Id" style="margin-top:10px">
