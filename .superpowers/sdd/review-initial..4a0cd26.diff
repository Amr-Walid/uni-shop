+@model FTD.Web.Models.ContentPage
+@{
+    Layout = "_AdminLayout";
+    var isEdit = Model.Id > 0;
+    ViewData["Title"] = isEdit ? "تعديل صفحة" : "صفحة جديدة";
+}
+
+<form action="@(isEdit ? "/Admin/AdminContent/EditPage/" + Model.Id : "/Admin/AdminContent/CreatePage")" method="post">
+  @Html.AntiForgeryToken()
+
+  <div style="display:grid;grid-template-columns:1fr 300px;gap:1.5rem;align-items:start">
+    <div>
+      <div class="a-card" style="margin-bottom:1.5rem">
+        <h3 class="a-card-title">محتوى الصفحة</h3>
+        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem">
+          <div class="a-form-group">
+            <label>العنوان بالعربي *</label>
+            <input asp-for="TitleAr" placeholder="عنوان الصفحة بالعربي">
+          </div>
+          <div class="a-form-group">
+            <label>العنوان بالإنجليزي *</label>
+            <input asp-for="TitleEn" placeholder="Page title in English" dir="ltr">
+          </div>
+        </div>
+        <div class="a-form-group" style="margin-top:1rem">
+          <label>المحتوى بالعربي (HTML)</label>
+          <textarea asp-for="BodyAr" rows="10" placeholder="محتوى الصفحة بالعربي — HTML مسموح به..." style="font-family:monospace;font-size:13px"></textarea>
+        </div>
+        <div class="a-form-group">
+          <label>المحتوى بالإنجليزي (HTML)</label>
+          <textarea asp-for="BodyEn" rows="10" placeholder="Page content in English — HTML allowed..." dir="ltr" style="font-family:monospace;font-size:13px"></textarea>
+        </div>
+      </div>
+    </div>
+
+    <div>
+      <div class="a-card" style="margin-bottom:1rem">
+        <h3 class="a-card-title">إعدادات الصفحة</h3>
+        <div class="a-form-group">
+          <label>الـ Slug (URL)</label>
+          <input asp-for="Slug" placeholder="privacy-policy" dir="ltr">
+          <small style="font-size:11px;color:var(--a-text2)">/page/<strong>@(Model.Slug ?? "slug")</strong></small>
+        </div>
+        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px;margin-top:.8rem">
+          <input asp-for="IsPublished" type="checkbox" style="width:16px;height:16px">
+          منشور (مرئي للزوار)
+        </label>
+      </div>
+
+      <div class="a-card" style="margin-bottom:1rem">
+        <h3 class="a-card-title">SEO</h3>
+        <div class="a-form-group">
+          <label>Meta Title</label>
+          <input asp-for="MetaTitle" placeholder="عنوان لمحركات البحث">
+        </div>
+        <div class="a-form-group">
+          <label>Meta Description</label>
+          <textarea asp-for="MetaDesc" rows="2" placeholder="وصف لمحركات البحث..."></textarea>
+        </div>
+      </div>
+
+      <div style="display:flex;gap:.8rem">
+        <button type="submit" class="a-btn" style="flex:1">
+          @(isEdit ? "💾 حفظ التعديلات" : "✚ إنشاء الصفحة")
+        </button>
+        <a href="/Admin/AdminContent/Pages" class="a-btn-outline">إلغاء</a>
+      </div>
+    </div>
+  </div>
+</form>
diff --git a/FTD.Web/Views/Admin/Content/PageSections.cshtml b/FTD.Web/Views/Admin/Content/PageSections.cshtml
new file mode 100644
index 0000000..4f33d48
--- /dev/null
+++ b/FTD.Web/Views/Admin/Content/PageSections.cshtml
@@ -0,0 +1,143 @@
+@model FTD.Web.Models.ContentPage
+@{
+    Layout = "_AdminLayout";
+    ViewData["Title"] = "Sections — " + Model.TitleAr;
+}
+
+<div style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem">
+    <a href="/Admin/AdminContent/Pages" style="color:var(--a-text2);font-size:13px">← الصفحات</a>
+    <span style="color:var(--a-text3)">/</span>
+    <span style="font-size:13px;font-weight:700">@Model.TitleAr</span>
+</div>
+
+<!-- ADD NEW SECTION -->
+<div class="a-card" style="margin-bottom:1.5rem">
+    <h3 class="a-card-title" style="margin-bottom:1rem">إضافة Section جديد</h3>
+    <form action="/Admin/AdminPageSections/AddSection" method="post">
+        @Html.AntiForgeryToken()
+        <input type="hidden" name="id" value="@Model.Id">
+        <div style="display:flex;gap:1rem;align-items:flex-end;flex-wrap:wrap">
+            <div class="a-form-group" style="flex:1;min-width:200px">
+                <label>نوع الـ Section</label>
+                <select name="type" class="a-select" id="sectionTypeSelect" onchange="showTypeHelp(this.value)">
+                    <option value="RichText">📝 RichText — نص حر (HTML)</option>
+                    <option value="FAQ">❓ FAQ — أسئلة وأجوبة (أكورديون)</option>
+                    <option value="Cards">🃏 Cards — بطاقات (مميزات / خدمات)</option>
+                    <option value="Hero">🖼️ Hero — بانر علوي</option>
+                </select>
+            </div>
+            <button type="submit" class="a-btn">+ إضافة</button>
+        </div>
+        <div id="typeHelp" style="margin-top:.8rem;padding:.8rem 1rem;background:var(--a-bg);border-radius:8px;font-size:12px;color:var(--a-text2);display:none"></div>
+    </form>
+</div>
+
+<!-- EXISTING SECTIONS -->
+@if (Model.Sections != null && Model.Sections.Any())
+{
+    <div style="display:flex;flex-direction:column;gap:1rem">
+        @foreach (var sec in Model.Sections.OrderBy(s => s.SortOrder))
+        {
+            <div class="a-card">
+                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
+                    <div style="display:flex;align-items:center;gap:10px">
+                        <span style="font-size:18px">
+                            @(sec.Type switch {
+                                "FAQ"      => "❓",
+                                "Cards"    => "🃏",
+                                "Hero"     => "🖼️",
+                                _          => "📝"
+                            })
+                        </span>
+                        <div>
+                            <span style="font-weight:700;font-size:14px">@sec.Type</span>
+                            <span style="font-size:11px;color:var(--a-text2);margin-right:8px">Section #@sec.Id</span>
+                        </div>
+                    </div>
+                    <div style="display:flex;gap:6px;align-items:center">
+                        <!-- Move up/down -->
+                        <form action="/Admin/AdminPageSections/MoveSectionUp" method="post" style="display:inline">
+                            @Html.AntiForgeryToken()
+                            <input type="hidden" name="id" value="@sec.Id">
+                            <button type="submit" class="a-btn-sm" title="تحريك لأعلى">↑</button>
+                        </form>
+                        <form action="/Admin/AdminPageSections/MoveSectionDown" method="post" style="display:inline">
+                            @Html.AntiForgeryToken()
+                            <input type="hidden" name="id" value="@sec.Id">
+                            <button type="submit" class="a-btn-sm" title="تحريك لأسفل">↓</button>
+                        </form>
+                        <!-- Toggle visible -->
+                        <form action="/Admin/AdminPageSections/ToggleSectionVisible" method="post" style="display:inline">
+                            @Html.AntiForgeryToken()
+                            <input type="hidden" name="id" value="@sec.Id">
+                            <button type="submit" class="a-btn-sm" style="background:@(sec.IsVisible ? "rgba(0,196,140,.12)" : "rgba(255,59,48,.12)");color:@(sec.IsVisible ? "#00C48C" : "#FF3B30")">
+                                @(sec.IsVisible ? "👁 ظاهر" : "🚫 مخفي")
+                            </button>
+                        </form>
+                        <!-- Delete -->
+                        <form action="/Admin/AdminPageSections/DeleteSection" method="post" style="display:inline">
+                            @Html.AntiForgeryToken()
+                            <input type="hidden" name="id" value="@sec.Id">
+                            <button type="submit" class="a-btn-sm a-btn-danger" onclick="return confirm('حذف هذا الـ section؟')">حذف</button>
+                        </form>
+                    </div>
+                </div>
+
+                <!-- SECTION EDITOR based on Type -->
+                <form action="/Admin/AdminPageSections/SaveSection" method="post">
+                    @Html.AntiForgeryToken()
+                    <input type="hidden" name="id" value="@sec.Id">
+
+                    @if (sec.Type == "RichText")
+                    {
+                        @await Html.PartialAsync("~/Views/Admin/Content/_SectionEditor_RichText.cshtml", sec)
+                    }
+                    else if (sec.Type == "FAQ")
+                    {
+                        @await Html.PartialAsync("~/Views/Admin/Content/_SectionEditor_FAQ.cshtml", sec)
+                    }
+                    else if (sec.Type == "Cards")
+                    {
+                        @await Html.PartialAsync("~/Views/Admin/Content/_SectionEditor_Cards.cshtml", sec)
+                    }
+                    else if (sec.Type == "Hero")
+                    {
+                        @await Html.PartialAsync("~/Views/Admin/Content/_SectionEditor_Hero.cshtml", sec)
+                    }
+
+                    <button type="submit" class="a-btn-sm" style="margin-top:1rem">💾 حفظ هذا الـ Section</button>
+                </form>
+            </div>
+        }
+    </div>
+}
+else
+{
+    <div style="text-align:center;padding:3rem;color:var(--a-text2);background:var(--a-card);border-radius:14px;border:1px dashed var(--a-border)">
+        <div style="font-size:2rem;margin-bottom:.5rem">📄</div>
+        <p>الصفحة دي مفيهاش sections بعد — ضيف section من فوق</p>
+    </div>
+}
+
+@section Scripts {
+<script>
+var typeHelp = {
+    RichText: 'نص HTML حر — بتكتب فيه محتوى عادي أو HTML بالعربي والإنجليزي',
+    FAQ: 'أسئلة وأجوبة — بتضيف أسئلة وإجاباتها وبتظهر كـ accordion في الموقع',
+    Cards: 'بطاقات — عرض مميزات أو خدمات في شكل grid من الكروت',
+    Hero: 'بانر علوي — عنوان كبير مع وصف وزرار'
+};
+function showTypeHelp(type) {
+    var el = document.getElementById('typeHelp');
+    if (typeHelp[type]) {
+        el.textContent = '💡 ' + typeHelp[type];
+        el.style.display = 'block';
+    } else {
+        el.style.display = 'none';
+    }
+}
+document.addEventListener('DOMContentLoaded', function() {
+    showTypeHelp(document.getElementById('sectionTypeSelect').value);
+});
+</script>
+}
diff --git a/FTD.Web/Views/Admin/Content/Pages.cshtml b/FTD.Web/Views/Admin/Content/Pages.cshtml
new file mode 100644
index 0000000..2e139a8
--- /dev/null
+++ b/FTD.Web/Views/Admin/Content/Pages.cshtml
@@ -0,0 +1,42 @@
+@model List<FTD.Web.Models.ContentPage>
+@{
+    Layout = "_AdminLayout";
+    ViewData["Title"] = "الصفحات الحرة";
+}
+
+<div style="display:flex;justify-content:flex-end;margin-bottom:1.5rem">
+  <a href="/Admin/AdminContent/CreatePage" class="a-btn">+ صفحة جديدة</a>
+</div>
+
+<div class="a-card">
+  <div class="a-table-wrap">
+    <table class="a-table">
+      <thead>
+        <tr><th>العنوان</th><th>الـ Slug</th><th>الحالة</th><th>آخر تحديث</th><th></th></tr>
+      </thead>
+      <tbody>
+        @foreach (var pg in Model)
+        {
+            <tr>
+              <td><strong>@pg.TitleAr</strong><br><small style="color:var(--a-text2)">@pg.TitleEn</small></td>
+              <td><a href="/page/@pg.Slug" target="_blank" style="font-family:monospace;font-size:12px;color:var(--a-blue)">/page/@pg.Slug</a></td>
+              <td>
+                <span class="status-badge" style="background:@(pg.IsPublished ? "rgba(0,196,140,.1)" : "rgba(255,59,48,.1)");color:@(pg.IsPublished ? "#00C48C" : "#FF3B30")">
+                  @(pg.IsPublished ? "منشور" : "مسودة")
+                </span>
+              </td>
+              <td style="font-size:12px;color:var(--a-text2)">@pg.UpdatedAt.ToString("dd/MM/yyyy")</td>
+              <td style="display:flex;gap:6px">
+                <a href="/Admin/AdminContent/EditPage/@pg.Id" class="a-btn-sm">تعديل</a>
+                <a href="/Admin/AdminPageSections/Manage/@pg.Id" class="a-btn-sm" style="background:rgba(0,196,140,.12);color:#00C48C;border-color:rgba(0,196,140,.2)">Sections</a>
+              </td>
+            </tr>
+        }
+      </tbody>
+    </table>
+    @if (!Model.Any())
+    {
+        <div style="text-align:center;padding:3rem;color:var(--a-text2)">لا توجد صفحات بعد — أضف صفحة جديدة</div>
+    }
+  </div>
+</div>
diff --git a/FTD.Web/Views/Admin/Content/_SectionEditor_Cards.cshtml b/FTD.Web/Views/Admin/Content/_SectionEditor_Cards.cshtml
new file mode 100644
index 0000000..c082a8d
--- /dev/null
+++ b/FTD.Web/Views/Admin/Content/_SectionEditor_Cards.cshtml
@@ -0,0 +1,78 @@
+@* _SectionEditor_Cards.cshtml *@
+@model FTD.Web.Models.PageSection
+@{
+    var cards = new List<(string titleAr, string titleEn, string bodyAr, string bodyEn, string icon)>();
+    if (!string.IsNullOrEmpty(Model.ContentJson))
+    {
+        try {
+            var arr = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(Model.ContentJson);
+            if (arr != null)
+                foreach (var el in arr)
+                {
+                    el.TryGetProperty("title_ar", out var tAr); el.TryGetProperty("title_en", out var tEn);
+                    el.TryGetProperty("body_ar",  out var bAr); el.TryGetProperty("body_en",  out var bEn);
+                    el.TryGetProperty("icon",     out var ic);
+                    cards.Add((tAr.GetString() ?? "", tEn.GetString() ?? "", bAr.GetString() ?? "", bEn.GetString() ?? "", ic.GetString() ?? ""));
+                }
+        } catch { }
+    }
+    while (cards.Count < 3) cards.Add(("", "", "", "", ""));
+}
+
+<div id="cardRows-@Model.Id">
+    @for (int i = 0; i < cards.Count; i++)
+    {
+        var c = cards[i];
+        <div class="card-row" style="background:var(--a-bg);border-radius:10px;padding:1rem;margin-bottom:.8rem;border:1px solid var(--a-border)">
+            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem">
+                <span style="font-size:11px;font-weight:700;color:var(--a-text3)">كارد @(i+1)</span>
+                <button type="button" onclick="this.closest('.card-row').remove()" style="background:none;border:none;color:var(--a-text3);cursor:pointer">✕</button>
+            </div>
+            <div style="display:grid;grid-template-columns:80px 1fr 1fr;gap:.8rem;margin-bottom:.8rem">
+                <div class="a-form-group">
+                    <label>Emoji/Icon</label>
+                    <input type="text" name="card_icon_@Model.Id" value="@c.icon" placeholder="✓">
+                </div>
+                <div class="a-form-group">
+                    <label>العنوان بالعربي</label>
+                    <input type="text" name="card_title_ar_@Model.Id" value="@c.titleAr" placeholder="مميزة">
+                </div>
+                <div class="a-form-group">
+                    <label>Title in English</label>
+                    <input type="text" name="card_title_en_@Model.Id" value="@c.titleEn" placeholder="Feature" dir="ltr">
+                </div>
+            </div>
+            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem">
+                <div class="a-form-group">
+                    <label>الوصف بالعربي</label>
+                    <textarea name="card_body_ar_@Model.Id" rows="2" placeholder="وصف المميزة...">@c.bodyAr</textarea>
+                </div>
+                <div class="a-form-group">
+                    <label>Description in English</label>
+                    <textarea name="card_body_en_@Model.Id" rows="2" placeholder="Feature description..." dir="ltr">@c.bodyEn</textarea>
+                </div>
+            </div>
+        </div>
+    }
+</div>
+<button type="button" onclick="addCardRow('@Model.Id')" class="a-btn-sm">+ كارد جديد</button>
+<script>
+function addCardRow(sid) {
+    var c = document.getElementById('cardRows-'+sid);
+    var n = c.querySelectorAll('.card-row').length + 1;
+    var d = document.createElement('div');
+    d.className='card-row';
+    d.style.cssText='background:var(--a-bg);border-radius:10px;padding:1rem;margin-bottom:.8rem;border:1px solid var(--a-border)';
+    d.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem"><span style="font-size:11px;font-weight:700;color:var(--a-text3)">كارد ${n}</span><button type="button" onclick="this.closest('.card-row').remove()" style="background:none;border:none;color:var(--a-text3);cursor:pointer">✕</button></div>
+    <div style="display:grid;grid-template-columns:80px 1fr 1fr;gap:.8rem;margin-bottom:.8rem">
+      <div class="a-form-group"><label>Icon</label><input type="text" name="card_icon_${sid}" placeholder="✓"></div>
+      <div class="a-form-group"><label>العنوان AR</label><input type="text" name="card_title_ar_${sid}" placeholder="مميزة"></div>
+      <div class="a-form-group"><label>Title EN</label><input type="text" name="card_title_en_${sid}" placeholder="Feature" dir="ltr"></div>
+    </div>
+    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem">
+      <div class="a-form-group"><label>الوصف AR</label><textarea name="card_body_ar_${sid}" rows="2"></textarea></div>
+      <div class="a-form-group"><label>Desc EN</label><textarea name="card_body_en_${sid}" rows="2" dir="ltr"></textarea></div>
+    </div>`;
+    c.appendChild(d);
+}
+</script>
diff --git a/FTD.Web/Views/Admin/Content/_SectionEditor_FAQ.cshtml b/FTD.Web/Views/Admin/Content/_SectionEditor_FAQ.cshtml
new file mode 100644
index 0000000..20815e4
--- /dev/null
+++ b/FTD.Web/Views/Admin/Content/_SectionEditor_FAQ.cshtml
@@ -0,0 +1,97 @@
+@* _SectionEditor_FAQ.cshtml *@
+@model FTD.Web.Models.PageSection
+@{
+    var items = new List<(string qAr, string qEn, string aAr, string aEn)>();
+    if (!string.IsNullOrEmpty(Model.ContentJson))
+    {
+        try {
+            var arr = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(Model.ContentJson);
+            if (arr != null)
+                foreach (var el in arr)
+                {
+                    el.TryGetProperty("q_ar", out var qAr); el.TryGetProperty("q_en", out var qEn);
+                    el.TryGetProperty("a_ar", out var aAr); el.TryGetProperty("a_en", out var aEn);
+                    items.Add((qAr.GetString() ?? "", qEn.GetString() ?? "", aAr.GetString() ?? "", aEn.GetString() ?? ""));
+                }
+        } catch { }
+    }
+    // always show at least 3 rows
+    while (items.Count < 3) items.Add(("", "", "", ""));
+}
+
+<p style="font-size:12px;color:var(--a-text2);margin-bottom:1rem">
+    كل سطر = سؤال وإجابة. السطور الفارغة بيتم تجاهلها تلقائياً.
+</p>
+
+<div id="faqRows-@Model.Id">
+    @for (int i = 0; i < items.Count; i++)
+    {
+        var item = items[i];
+        <div class="faq-row" style="background:var(--a-bg);border-radius:10px;padding:1rem;margin-bottom:.8rem;border:1px solid var(--a-border)">
+            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem">
+                <span style="font-size:11px;font-weight:700;color:var(--a-text3)">سؤال @(i+1)</span>
+                <button type="button" onclick="this.closest('.faq-row').remove()" style="background:none;border:none;color:var(--a-text3);cursor:pointer;font-size:14px">✕</button>
+            </div>
+            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-bottom:.8rem">
+                <div class="a-form-group">
+                    <label>السؤال بالعربي</label>
+                    <input type="text" name="faq_q_ar_@Model.Id" value="@item.qAr" placeholder="ما هي سياسة الإرجاع؟">
+                </div>
+                <div class="a-form-group">
+                    <label>Question in English</label>
+                    <input type="text" name="faq_q_en_@Model.Id" value="@item.qEn" placeholder="What is the return policy?" dir="ltr">
+                </div>
+            </div>
+            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem">
+                <div class="a-form-group">
+                    <label>الإجابة بالعربي</label>
+                    <textarea name="faq_a_ar_@Model.Id" rows="2" placeholder="يمكنك الإرجاع خلال 14 يوم...">@item.aAr</textarea>
+                </div>
+                <div class="a-form-group">
+                    <label>Answer in English</label>
+                    <textarea name="faq_a_en_@Model.Id" rows="2" placeholder="You can return within 14 days..." dir="ltr">@item.aEn</textarea>
+                </div>
+            </div>
+        </div>
+    }
+</div>
+
+<button type="button" onclick="addFaqRow('@Model.Id')" class="a-btn-sm" style="margin-top:.5rem">
+    + سؤال جديد
+</button>
+
+<script>
+function addFaqRow(sectionId) {
+    var container = document.getElementById('faqRows-' + sectionId);
+    var count = container.querySelectorAll('.faq-row').length + 1;
+    var div = document.createElement('div');
+    div.className = 'faq-row';
+    div.style.cssText = 'background:var(--a-bg);border-radius:10px;padding:1rem;margin-bottom:.8rem;border:1px solid var(--a-border)';
+    div.innerHTML = `
+        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem">
+            <span style="font-size:11px;font-weight:700;color:var(--a-text3)">سؤال ${count}</span>
+            <button type="button" onclick="this.closest('.faq-row').remove()" style="background:none;border:none;color:var(--a-text3);cursor:pointer;font-size:14px">✕</button>
+        </div>
+        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-bottom:.8rem">
+            <div class="a-form-group">
+                <label>السؤال بالعربي</label>
+                <input type="text" name="faq_q_ar_${sectionId}" placeholder="السؤال بالعربي">
+            </div>
+            <div class="a-form-group">
+                <label>Question in English</label>
+                <input type="text" name="faq_q_en_${sectionId}" placeholder="Question in English" dir="ltr">
+            </div>
+        </div>
+        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem">
+            <div class="a-form-group">
+                <label>الإجابة بالعربي</label>
+                <textarea name="faq_a_ar_${sectionId}" rows="2" placeholder="الإجابة..."></textarea>
+            </div>
+            <div class="a-form-group">
+                <label>Answer in English</label>
+                <textarea name="faq_a_en_${sectionId}" rows="2" placeholder="Answer..." dir="ltr"></textarea>
+            </div>
+        </div>`;
+    container.appendChild(div);
+}
+</script>
diff --git a/FTD.Web/Views/Admin/Content/_SectionEditor_Hero.cshtml b/FTD.Web/Views/Admin/Content/_SectionEditor_Hero.cshtml
new file mode 100644
index 0000000..c837284
