+@model List<FTD.Web.Models.SalesOrder>
+@{
+    Layout = "_AdminLayout";
+    ViewData["Title"] = "الطلبات";
+    var statuses = ViewBag.Statuses as List<FTD.Web.Models.OrderStatus>;
+}
+
+<!-- STATUS FILTER TABS -->
+<div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1.5rem">
