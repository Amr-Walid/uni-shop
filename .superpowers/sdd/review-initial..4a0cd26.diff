diff --git a/FTD.Web/Views/Admin/Account/Login.cshtml b/FTD.Web/Views/Admin/Account/Login.cshtml
new file mode 100644
index 0000000..3b5b918
--- /dev/null
+++ b/FTD.Web/Views/Admin/Account/Login.cshtml
@@ -0,0 +1,59 @@
+@{
+    Layout = null;
+    ViewData["Title"] = "تسجيل الدخول";
+}
+<!DOCTYPE html>
+<html lang="ar" dir="rtl">
+<head>
+<meta charset="UTF-8">
+<meta name="viewport" content="width=device-width, initial-scale=1.0">
+<title>FTD Admin — Login</title>
+<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
+<link rel="stylesheet" href="~/css/admin.css">
+<style>
+.login-page{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--a-bg);padding:2rem}
+.login-card{background:var(--a-card);border:1px solid var(--a-border);border-radius:20px;padding:2.5rem;width:100%;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,.15)}
+.login-logo{display:flex;align-items:center;gap:10px;margin-bottom:2rem;justify-content:center}
+.login-icon{width:48px;height:48px;background:var(--a-blue);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:900;color:white}
+.login-title{font-size:1.6rem;font-weight:900;margin-bottom:.3rem;text-align:center;color:var(--a-text)}
+.login-sub{font-size:13px;color:var(--a-text2);text-align:center;margin-bottom:2rem}
+.login-group{margin-bottom:1.2rem}
+.login-group label{display:block;font-size:12px;font-weight:700;color:var(--a-text2);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
+.login-group input{width:100%;padding:12px 16px;border:1.5px solid var(--a-border);border-radius:10px;font-size:14px;font-family:'Tajawal',sans-serif;color:var(--a-text);background:var(--a-bg);outline:none;transition:border-color .2s;direction:ltr}
+.login-group input:focus{border-color:var(--a-blue);background:var(--a-card)}
+.login-btn{width:100%;padding:13px;background:var(--a-blue);color:white;border:none;border-radius:10px;font-size:15px;font-weight:700;font-family:'Tajawal',sans-serif;cursor:pointer;margin-top:.5rem;transition:all .2s}
+.login-btn:hover{background:#0E4FCC;transform:translateY(-1px)}
+.error-msg{background:#FEE;border:1px solid #FCC;border-radius:8px;padding:10px 14px;font-size:13px;color:#C33;margin-bottom:1rem}
+</style>
+</head>
+<body>
+<div class="login-page">
+  <div class="login-card">
+    <div class="login-logo">
+      <div class="login-icon">FTD</div>
+    </div>
+    <div class="login-title">لوحة التحكم</div>
+    <div class="login-sub">FTD TechZone — Admin Panel</div>
+
+    @if (!ViewData.ModelState.IsValid)
+    {
+        <div class="error-msg">بيانات الدخول غير صحيحة</div>
+    }
+
+    <form method="post" action="/Admin/AdminAccount/Login">
+      @Html.AntiForgeryToken()
+      <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl">
+      <div class="login-group">
+        <label>البريد الإلكتروني</label>
+        <input type="email" name="email" placeholder="admin@ftdtechzone.com" required>
+      </div>
+      <div class="login-group">
+        <label>كلمة المرور</label>
+        <input type="password" name="password" placeholder="••••••••" required>
+      </div>
+      <button type="submit" class="login-btn">دخول ←</button>
+    </form>
+  </div>
+</div>
+</body>
+</html>
diff --git a/FTD.Web/Views/Admin/Attributes/Form.cshtml b/FTD.Web/Views/Admin/Attributes/Form.cshtml
new file mode 100644
index 0000000..c64334c
--- /dev/null
+++ b/FTD.Web/Views/Admin/Attributes/Form.cshtml
@@ -0,0 +1,54 @@
+@model FTD.Web.Models.ProductAttribute
+@{
+    Layout = "_AdminLayout";
+    var isEdit = Model.Id > 0;
+    ViewData["Title"] = isEdit ? "تعديل Attribute" : "Attribute جديد";
+    var categories = ViewBag.Categories as List<FTD.Web.Models.Category>;
+}
+
+<form action="@(isEdit ? "/Admin/AdminAttributes/Edit/" + Model.Id : "/Admin/AdminAttributes/Create")" method="post">
+    @Html.AntiForgeryToken()
+    <div style="max-width:580px">
+        <div class="a-card">
+            <h3 class="a-card-title">بيانات الـ Attribute</h3>
+            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem">
+                <div class="a-form-group">
+                    <label>الاسم بالعربي *</label>
+                    <input type="text" name="NameAr" value="@Model.NameAr" placeholder="مثال: الذاكرة العشوائية" required>
+                </div>
+                <div class="a-form-group">
+                    <label>الاسم بالإنجليزي *</label>
+                    <input type="text" name="NameEn" value="@Model.NameEn" placeholder="e.g. RAM" dir="ltr" required>
+                </div>
+                <div class="a-form-group">
+                    <label>الكاتيجوري *</label>
+                    <select name="CategoryId" class="a-select" required>
+                        <option value="">اختر الكاتيجوري...</option>
+                        @if (categories != null)
+                        {
+                            foreach (var cat in categories)
+                            {
+                                if (Model.CategoryId == cat.Id)
+                                {
+                                    <option value="@cat.Id" selected>@(cat.Emoji ?? "") @cat.NameAr</option>
+                                }
+                                else
+                                {
+                                    <option value="@cat.Id">@(cat.Emoji ?? "") @cat.NameAr</option>
+                                }
+                            }
+                        }
+                    </select>
+                </div>
+                <div class="a-form-group">
+                    <label>الترتيب</label>
+                    <input type="number" name="SortOrder" value="@Model.SortOrder" placeholder="0">
+                </div>
+            </div>
+            <div style="display:flex;gap:.8rem;margin-top:1.5rem">
+                <button type="submit" class="a-btn">@(isEdit ? "💾 حفظ" : "✚ إضافة")</button>
+                <a href="/Admin/AdminAttributes" class="a-btn-outline">إلغاء</a>
+            </div>
+        </div>
+    </div>
+</form>
diff --git a/FTD.Web/Views/Admin/Attributes/Index.cshtml b/FTD.Web/Views/Admin/Attributes/Index.cshtml
new file mode 100644
index 0000000..e763ed8
--- /dev/null
+++ b/FTD.Web/Views/Admin/Attributes/Index.cshtml
@@ -0,0 +1,91 @@
+@model List<FTD.Web.Models.ProductAttribute>
+@{
+    Layout = "_AdminLayout";
+    ViewData["Title"] = "الـ Attributes";
+    var categories = ViewBag.Categories as List<FTD.Web.Models.Category>;
+    var currentCatId = ViewBag.CurrentCategoryId as int?;
+}
+
+<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem">
+    <!-- Category filter -->
+    <div style="display:flex;gap:.5rem;flex-wrap:wrap">
+        <a href="/Admin/AdminAttributes" class="a-btn-sm @(currentCatId == null ? "a-btn" : "a-btn-outline")">الكل</a>
+        @if (categories != null)
+        {
+            @foreach (var cat in categories)
+            {
+                <a href="/Admin/AdminAttributes?categoryId=@cat.Id"
+                   class="a-btn-sm @(currentCatId == cat.Id ? "a-btn" : "a-btn-outline")">
+                    @(cat.Emoji ?? "") @cat.NameAr
+                </a>
+            }
+        }
+    </div>
+    <a href="/Admin/AdminAttributes/Create" class="a-btn">+ Attribute جديد</a>
+</div>
+
+@if (!Model.Any())
+{
+    <div style="text-align:center;padding:3rem;color:var(--a-text2);background:var(--a-card);border-radius:14px;border:1px dashed var(--a-border)">
+        <div style="font-size:2rem;margin-bottom:.5rem">🏷️</div>
+        <p>مفيش attributes بعد — أضف attribute جديد</p>
+    </div>
+}
+else
+{
+    @foreach (var attr in Model)
+    {
+        <div class="a-card" style="margin-bottom:1rem">
+            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
+                <div>
+                    <span style="font-weight:700;font-size:15px">@attr.NameAr</span>
+                    <span style="color:var(--a-text2);font-size:13px;margin-right:8px">/ @attr.NameEn</span>
+                    <span style="font-size:11px;background:rgba(26,107,255,.1);color:#1A6BFF;padding:2px 8px;border-radius:100px;margin-right:6px">
+                        @attr.Category?.NameAr
+                    </span>
+                </div>
+                <div style="display:flex;gap:6px">
+                    <a href="/Admin/AdminAttributes/Edit/@attr.Id" class="a-btn-sm">تعديل</a>
+                    <form action="/Admin/AdminAttributes/Delete/@attr.Id" method="post" style="display:inline">
+                        @Html.AntiForgeryToken()
+                        <button type="submit" class="a-btn-sm a-btn-danger" onclick="return confirm('حذف هذا الـ Attribute؟')">حذف</button>
+                    </form>
+                </div>
+            </div>
+
+            <!-- Attribute Values -->
+            <div>
+                <div style="font-size:11px;font-weight:700;color:var(--a-text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:.8rem">
+                    القيم (@attr.Values.Count)
+                </div>
+                <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:.8rem">
+                    @foreach (var val in attr.Values)
+                    {
+                        <div style="display:flex;align-items:center;gap:6px;background:var(--a-bg);border:1px solid var(--a-border);border-radius:8px;padding:5px 10px">
+                            <span style="font-size:13px">@val.ValueAr / @val.ValueEn</span>
+                            <form action="/Admin/AdminAttributes/DeleteValue/@val.Id" method="post" style="display:inline">
+                                @Html.AntiForgeryToken()
+                                <button type="submit" style="background:none;border:none;color:var(--a-text3);cursor:pointer;font-size:12px;padding:0" onclick="return confirm('حذف؟')">✕</button>
+                            </form>
+                        </div>
+                    }
+                </div>
+
+                <!-- Add new value -->
+                <form action="/Admin/AdminAttributes/AddValue" method="post" style="display:flex;gap:.5rem;flex-wrap:wrap;align-items:flex-end">
+                    @Html.AntiForgeryToken()
+                    <input type="hidden" name="attributeId" value="@attr.Id">
+                    <div class="a-form-group" style="flex:1;min-width:140px">
+                        <label>قيمة جديدة AR</label>
+                        <input type="text" name="valueAr" placeholder="مثال: 12GB">
+                    </div>
+                    <div class="a-form-group" style="flex:1;min-width:140px">
+                        <label>New Value EN</label>
+                        <input type="text" name="valueEn" placeholder="e.g. 12GB" dir="ltr">
+                    </div>
+                    <button type="submit" class="a-btn-sm" style="margin-bottom:1px">+ إضافة</button>
+                </form>
+            </div>
+        </div>
+    }
+}
diff --git a/FTD.Web/Views/Admin/Brands/Form.cshtml b/FTD.Web/Views/Admin/Brands/Form.cshtml
