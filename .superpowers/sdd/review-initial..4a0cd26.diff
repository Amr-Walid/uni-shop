+        color: var(--text3);
+        cursor: pointer;
+        transition: color .2s
+    }
+
+        .breadcrumb a:hover {
+            color: var(--blue)
+        }
+
+.breadcrumb-sep {
+    color: var(--border)
+}
+
+/* ── BRAND HERO ── */
+.brand-hero {
+    background: var(--dark);
+    padding: 4rem 5%;
+    color: white;
+    text-align: center;
+    position: relative;
+    overflow: hidden
+}
+
+    .brand-hero::before {
+        content: '';
+        position: absolute;
+        top: -30%;
+        left: 50%;
+        transform: translateX(-50%);
+        width: 500px;
+        height: 300px;
+        background: var(--blue);
+        border-radius: 50%;
+        opacity: .08;
+        filter: blur(60px)
+    }
+
+.brand-hero-icon {
+    font-size: 3.5rem;
+    margin-bottom: 1rem;
+    position: relative
+}
+
+.brand-hero-title {
+    font-size: clamp(2rem,4vw,3.2rem);
+    font-weight: 900;
+    letter-spacing: -1px;
+    margin-bottom: .8rem;
+    position: relative
+}
+
+.brand-hero-desc {
+    font-size: 15px;
+    color: rgba(255,255,255,.6);
+    max-width: 480px;
+    margin: 0 auto;
+    position: relative
+}
+
+/* ── FILTER BAR (products page) ── */
+.brands-filter {
+    display: flex;
+    gap: .6rem;
+    flex-wrap: wrap;
+    margin-bottom: 2rem
+}
+
+.filter-btn {
+    padding: 9px 22px;
+    border-radius: 100px;
+    border: 1.5px solid var(--border);
+    background: transparent;
+    cursor: pointer;
+    font-size: 13px;
+    font-weight: 600;
+    font-family: var(--font);
+    transition: all .2s;
+    text-decoration: none;
+    color: var(--text);
+    display: inline-flex;
+    align-items: center
+}
+
+    .filter-btn.active, .filter-btn:hover {
+        background: var(--blue);
+        color: white;
+        border-color: var(--blue)
+    }
+
+/* ── PRODUCT DETAIL ── */
+.product-detail-page {
+    padding-top: var(--nav-h)
+}
+
+.detail-grid {
+    display: grid;
+    grid-template-columns: 1fr 1fr;
+    gap: 4rem;
+    padding: 3rem 5%
+}
+
+.detail-img-wrap {
+    background: var(--bg);
+    border-radius: 24px;
+    padding: 3rem;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    min-height: 360px;
+    position: relative;
+    font-size: 8rem
+}
+
+.detail-badge {
+    position: absolute;
+    top: 1.5rem;
+    right: 1.5rem;
+    font-size: 11px;
+    font-weight: 700;
+    padding: 6px 14px;
+    border-radius: 100px
+}
+
+body.en .detail-badge {
+    right: auto;
+    left: 1.5rem
+}
+
+.detail-brand {
+    font-size: 11px;
+    font-weight: 700;
+    color: var(--blue);
+    letter-spacing: 2px;
+    text-transform: uppercase;
+    margin-bottom: .5rem
+}
+
+.detail-title {
+    font-size: clamp(1.5rem,3vw,2.2rem);
+    font-weight: 900;
+    margin-bottom: 1rem;
+    line-height: 1.2
+}
+
+.detail-price {
+    font-size: 2rem;
+    font-weight: 900;
+    margin-bottom: 1.5rem;
+    color: var(--blue)
+}
+
+.detail-desc {
+    font-size: 15px;
+    color: var(--text2);
+    line-height: 1.9;
+    margin-bottom: 2rem
+}
+
+.detail-specs {
+    margin-bottom: 2rem;
+    background: var(--bg);
+    border-radius: var(--r);
+    padding: 1.2rem
+}
+
+    .detail-specs h4 {
+        font-size: 13px;
+        font-weight: 700;
+        margin-bottom: 1rem;
+        color: var(--text2)
+    }
+
+.spec-row {
+    display: flex;
+    justify-content: space-between;
+    padding: .65rem 0;
+    border-bottom: 1px solid var(--border);
+    font-size: 13px
+}
+
+    .spec-row:last-child {
+        border-bottom: none
+    }
+
+.spec-label {
+    color: var(--text3)
+}
+
+.spec-val {
+    font-weight: 700
+}
+
+.detail-actions {
+    display: flex;
+    gap: 1rem;
+    flex-wrap: wrap
+}
+
+.related-section {
+    background: var(--bg)
+}
+
+.add-cart-btn {
+    display: inline-flex;
+    align-items: center;
+    gap: 8px;
+    background: var(--blue);
+    color: white;
+    padding: 13px 28px;
+    border-radius: 100px;
+    font-weight: 700;
+    font-size: 15px;
+    font-family: var(--font);
+    border: none;
+    cursor: pointer;
+    transition: all .3s
+}
+
+    .add-cart-btn:hover {
+        background: var(--blue-dark);
+        transform: translateY(-2px);
+        box-shadow: var(--shadow-blue)
+    }
+
+/* ── CART PAGE ── */
+.cart-page {
+    padding: var(--nav-h) 5% 4rem;
+    min-height: 100vh
+}
+
+.cart-grid {
+    display: grid;
+    grid-template-columns: 1fr 360px;
+    gap: 2rem;
+    margin-top: 2rem;
+    align-items: start
+}
+
+.cart-items {
+    background: white;
+    border-radius: var(--rl);
+    border: 1px solid var(--border);
+    overflow: hidden
+}
+
+.cart-item {
+    display: flex;
+    align-items: center;
+    gap: 1.2rem;
+    padding: 1.2rem 1.5rem;
+    border-bottom: 1px solid var(--border)
+}
+
+    .cart-item:last-child {
+        border-bottom: none
+    }
+
+.cart-item-img {
+    width: 72px;
+    height: 72px;
+    background: var(--bg);
+    border-radius: 12px;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    font-size: 32px;
+    flex-shrink: 0
+}
+
+.cart-item-name {
+    font-size: 14px;
+    font-weight: 700;
+    margin-bottom: 3px
+}
+
+.cart-item-brand {
+    font-size: 10px;
+    font-weight: 700;
+    color: var(--blue);
+    letter-spacing: 1px;
+    text-transform: uppercase;
+    margin-bottom: 6px
+}
+
+.cart-item-price {
+    font-size: 15px;
+    font-weight: 800
+}
+
+.qty-wrap {
+    display: flex;
+    align-items: center;
+    gap: 8px;
+    margin-top: 8px
+}
+
+.qty-btn {
+    width: 28px;
+    height: 28px;
+    background: var(--bg);
+    border: 1px solid var(--border);
+    border-radius: 8px;
+    font-size: 14px;
+    cursor: pointer;
+    transition: all .2s;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    font-family: var(--font)
+}
+
+    .qty-btn:hover {
+        background: var(--blue);
+        color: white;
+        border-color: var(--blue)
+    }
+
+.qty-num {
+    font-size: 14px;
+    font-weight: 700;
+    min-width: 24px;
+    text-align: center
+}
+
+.cart-item-remove {
+    margin-right: auto;
+    background: none;
+    border: none;
+    color: var(--text3);
+    cursor: pointer;
+    font-size: 18px;
+    transition: color .2s;
+    margin-inline-start: auto
+}
+
+body.en .cart-item-remove {
+    margin-right: 0;
+    margin-left: auto
+}
+
+.cart-item-remove:hover {
+    color: #e74c3c
+}
+
+.cart-summary {
+    background: white;
+    border-radius: var(--rl);
+    border: 1px solid var(--border);
+    padding: 1.5rem;
+    position: sticky;
+    top: calc(var(--nav-h) + 1rem)
+}
+
+    .cart-summary h3 {
+        font-size: 1.1rem;
+        font-weight: 800;
+        margin-bottom: 1.5rem
+    }
+
+.summary-row {
+    display: flex;
+    justify-content: space-between;
+    font-size: 14px;
+    margin-bottom: .8rem;
+    color: var(--text2)
+}
+
+    .summary-row.total {
+        font-size: 17px;
+        font-weight: 800;
+        color: var(--text);
+        padding-top: .8rem;
+        border-top: 1px solid var(--border);
+        margin-top: .8rem
+    }
+
+.checkout-btn {
+    width: 100%;
+    padding: 14px;
+    background: var(--blue);
+    color: white;
+    border: none;
+    border-radius: 10px;
+    font-size: 15px;
+    font-weight: 700;
+    font-family: var(--font);
+    cursor: pointer;
+    transition: all .2s;
+    margin-top: 1rem
+}
+
+    .checkout-btn:hover {
+        background: var(--blue-dark);
+        box-shadow: var(--shadow-blue)
+    }
+
+.empty-cart {
+    text-align: center;
+    padding: 5rem 2rem;
+    color: var(--text3)
+}
+
+.empty-cart-icon {
+    font-size: 4rem;
+    margin-bottom: 1rem
+}
+
+/* ── FOOTER ── */
+footer {
+    background: var(--dark);
+    color: white;
+    padding: 4rem 5% 2rem
+}
+
+.footer-grid {
+    display: grid;
+    grid-template-columns: 2fr 1fr 1fr 1fr;
+    gap: 3rem;
+    margin-bottom: 3rem
+}
+
+.footer-brand-logo {
+    display: flex;
+    align-items: center;
+    gap: 10px;
+    margin-bottom: 1rem
+}
+
+.footer-logo-icon {
+    background: rgba(26,107,255,.2);
+    border: 1px solid rgba(26,107,255,.3)
+}
+
+.footer-brand-desc {
+    color: rgba(255,255,255,.45);
+    font-size: 13px;
+    line-height: 1.8;
+    max-width: 240px
+}
+
+.footer-col h4 {
+    font-size: 11px;
+    font-weight: 700;
+    color: rgba(255,255,255,.35);
+    letter-spacing: 2px;
+    text-transform: uppercase;
+    margin-bottom: 1.2rem
+}
+
+.footer-col ul li {
+    margin-bottom: .7rem
+}
+
+    .footer-col ul li a {
+        color: rgba(255,255,255,.55);
+        font-size: 13px;
+        transition: color .2s;
+        cursor: pointer
+    }
+
+        .footer-col ul li a:hover {
+            color: white
+        }
+
+.footer-social {
+    display: flex;
+    gap: 8px;
+    margin-top: 1.2rem
+}
+
+.social-btn {
+    width: 36px;
+    height: 36px;
+    background: rgba(255,255,255,.07);
+    border-radius: 9px;
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    font-size: 12px;
+    font-weight: 700;
+    transition: all .2s;
+    cursor: pointer;
+    border: 1px solid rgba(255,255,255,.1);
+    color: rgba(255,255,255,.6)
+}
+
+    .social-btn:hover {
+        background: var(--blue);
+        border-color: var(--blue);
+        color: white
+    }
+
+.footer-bottom {
+    border-top: 1px solid rgba(255,255,255,.08);
+    padding-top: 1.5rem;
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    flex-wrap: wrap;
+    gap: .5rem
+}
+
+    .footer-bottom p {
+        font-size: 12px;
+        color: rgba(255,255,255,.3)
+    }
+
+/* ── LANG ── */
+[data-ar] {
+    display: block
+}
+
+[data-en] {
+    display: none
+}
+
+span[data-ar] {
+    display: inline
+}
+
+span[data-en] {
+    display: none
+}
+
+body.en [data-ar] {
+    display: none !important
+}
+
+body.en [data-en] {
+    display: block
+}
+
+body.en span[data-ar] {
+    display: none !important
+}
+
+body.en span[data-en] {
+    display: inline
+}
+
+/* ── ANIMATIONS ── */
+@keyframes fadeInUp {
+    from {
+        opacity: 0;
+        transform: translateY(20px)
+    }
+
+    to {
+        opacity: 1;
+        transform: translateY(0)
+    }
+}
+
+.slide.active .slide-content {
+    animation: fadeInUp .6s ease forwards
+}
+
+.slide.active .slide-visual {
+    animation: fadeInUp .6s .15s ease both
+}
+
+/* ── RESPONSIVE ── */
+/* ── HAMBURGER MENU ── */
+.hamburger {
+    display: none;
+    flex-direction: column;
+    justify-content: center;
+    gap: 5px;
+    background: none;
+    border: none;
+    cursor: pointer;
+    padding: 8px;
+    border-radius: 8px;
+    flex-shrink: 0
+}
+
+body.en .hamburger {
+    order: -1
+}
+
+.hamburger span {
+    display: block;
+    width: 22px;
+    height: 2px;
+    background: var(--text);
+    border-radius: 2px;
+    transition: all .3s
+}
+
+.hamburger.open span:nth-child(1) {
+    transform: translateY(7px) rotate(45deg)
+}
+
+.hamburger.open span:nth-child(2) {
+    opacity: 0
+}
+
+.hamburger.open span:nth-child(3) {
+    transform: translateY(-7px) rotate(-45deg)
+}
+
+/* ── TABLET ── */
+@media(max-width:960px) {
+    .about-grid, .mv-grid, .contact-grid, .footer-grid, .detail-grid, .cart-grid {
+        grid-template-columns: 1fr;
+        gap: 2rem
+    }
+
+    .nav-center {
+        display: none
+    }
+
+    .hamburger {
+        display: flex
+    }
+
+    nav {
+        justify-content: space-between
+    }
+
+    .nav-logo {
+        flex: 1;
+        justify-content: center
+    }
+
+    .nav-right {
+        gap: 8px
+    }
+
+    .search-trigger {
+        display: none
+    }
+
+    .stats-row {
+        grid-template-columns: repeat(2,1fr)
+    }
+
+    .footer-grid {
+        grid-template-columns: 1fr 1fr
+    }
+    /* Slider: hide visual, center content */
+    .slide-visual {
+        display: none
+    }
+
+    .slide-content {
+        max-width: 100%;
+        text-align: center
+    }
+
+    .slide-actions {
+        justify-content: center
+    }
+
+    .slide {
+        justify-content: center;
+        padding: 0 6%
+    }
+}
+
+/* ── MOBILE ── */
+@media(max-width:600px) {
+    .section {
+        padding: 4rem 4%
+    }
+
+    .slide-title {
+        font-size: 2rem;
+        letter-spacing: -1px
+    }
+
+    .slide-desc {
+        font-size: 14px
+    }
+
+    .products-grid {
+        grid-template-columns: 1fr 1fr
+    }
+
+    .footer-grid {
+        grid-template-columns: 1fr
+    }
+
+    .search-trigger span {
+        display: none
+    }
+
+    .brands-strip {
+        gap: 1rem;
+        padding: .8rem 4%
+    }
+
+    .brands-strip-items {
+        gap: 1.5rem
+    }
+
+    .card-footer {
+        flex-wrap: wrap;
+        gap: .5rem
+    }
+
+        .card-footer > div {
+            width: 100%
+        }
+
+            .card-footer > div:last-child {
+                width: 100%;
+                display: flex;
+                gap: 6px
+            }
+
+        .card-footer .card-btn {
+            flex: 1;
+            text-align: center;
+            justify-content: center
+        }
+}
+
+/* Mobile Nav Drawer */
+.mobile-nav {
+    display: none;
+    position: fixed;
+    top: var(--nav-h);
+    right: 0;
+    left: 0;
+    background: white;
+    border-bottom: 1px solid var(--border);
+    padding: 1rem 5% 1.5rem;
+    z-index: 999;
+    box-shadow: 0 8px 32px rgba(0,0,0,.1);
+}
+
+    .mobile-nav.open {
+        display: block
+    }
+
+    .mobile-nav a {
+        display: block;
+        padding: .75rem 0;
+        font-size: 15px;
+        font-weight: 600;
+        color: var(--text);
+        border-bottom: 1px solid var(--border);
+        text-decoration: none;
+    }
+
+        .mobile-nav a:last-child {
+            border-bottom: none
+        }
+
+        .mobile-nav a:hover {
+            color: var(--blue)
+        }
+
+/* ── SOCIAL CONTACT BUTTONS ── */
+.social-contact-btn {
+    display: inline-flex;
+    align-items: center;
+    padding: 7px 16px;
+    border-radius: 100px;
+    font-size: 12px;
+    font-weight: 700;
+    background: var(--blue-light);
+    color: var(--blue);
+    border: 1px solid rgba(26,107,255,.2);
+    text-decoration: none;
+    transition: all .2s;
+    font-family: var(--font)
+}
+
+    .social-contact-btn:hover {
+        background: var(--blue);
+        color: white
+    }
+
+/* ── BRAND LOGOS ── */
+.brand-logo-strip {
+    height: 28px;
+    object-fit: contain;
+    max-width: 100px;
+    transition: opacity .2s;
+    filter: none;
+}
+
+.brand-strip-item:hover .brand-logo-strip {
+    opacity: .7
+}
+
+.brand-logo-card {
+    height: 18px;
+    object-fit: contain;
+    max-width: 80px;
+    display: block;
+}
