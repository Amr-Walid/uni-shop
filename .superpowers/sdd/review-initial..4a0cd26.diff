+
+        // Re-render products
+        if (data.count === 0) {
+            grid.innerHTML = '<div style="text-align:center;padding:4rem 2rem;color:var(--text3);grid-column:1/-1"><div style="font-size:3rem;margin-bottom:1rem">🔍</div><p style="font-size:15px;font-weight:600">لا توجد منتجات</p></div>';
+        } else {
+            grid.innerHTML = data.products.map(function(p) {
+                var disc = p.oldPrice && p.oldPrice > p.price
+                    ? Math.round((1 - p.price / p.oldPrice) * 100) : 0;
+                var img = p.imagePath
+                    ? '<img src="' + p.imagePath + '" alt="' + p.nameEn + '" style="max-height:120px;object-fit:contain">'
+                    : '<span style="font-size:52px">' + (p.emoji || '📦') + '</span>';
+                return '<div class="product-card" onclick="location.href=\'' + p.url + '\'">'
+                    + '<div class="card-img">'
+                    + (p.badge ? '<span class="card-badge badge-blue">' + p.badge + '</span>' : '')
+                    + img + '</div>'
+                    + '<div class="card-body">'
+                    + '<div class="card-brand">' + (p.brandName || '') + '</div>'
+                    + '<div class="card-name">' + p.nameAr + '</div>'
+                    + '</div>'
+                    + '<div class="card-footer">'
+                    + '<div><div class="card-price">EGP ' + Number(p.price).toLocaleString() + '</div>'
+                    + (disc > 0 ? '<div style="display:flex;align-items:center;gap:4px"><span style="font-size:11px;color:var(--text3);text-decoration:line-through">EGP ' + Number(p.oldPrice).toLocaleString() + '</span><span style="background:#FF3B30;color:white;font-size:9px;font-weight:800;padding:2px 6px;border-radius:100px">-' + disc + '%</span></div>' : '')
+                    + '</div>'
+                    + '<div style="display:flex;gap:6px">'
+                    + '<button class="card-btn" onclick="event.stopPropagation();location.href=\'' + p.url + '\'">التفاصيل</button>'
+                    + '<button class="card-btn" style="padding:7px 10px;background:#F4F6FA;color:#0A0D14;border:1.5px solid #E4E8F0" onclick="event.stopPropagation();addToCartQuick(' + p.id + ',this)" title="أضف للسلة">🛒</button>'
+                    + '</div>'
+                    + '</div></div>';
+            }).join('');
+        }
+
+        // Update attribute filters
+        updateAttrFilters(data.attrGroups);
+
+        // Update URL without reload
+        var url = new URL(window.location);
+        _brand    ? url.searchParams.set('brand',    _brand)    : url.searchParams.delete('brand');
+        _category ? url.searchParams.set('category', _category) : url.searchParams.delete('category');
+        _sort !== 'featured' ? url.searchParams.set('sort', _sort) : url.searchParams.delete('sort');
+        url.searchParams.delete('av');
+        _attrVals.forEach(function(v) { url.searchParams.append('av', v); });
+        history.replaceState({}, '', url);
+
+        // Update clear button and tags
+        updateActiveTags();
+
+    } catch(e) {
+        console.error('Filter error:', e);
+    }
+    grid.classList.remove('loading');
+}
+
+function updateAttrFilters(groups) {
+    var container = document.getElementById('attrFilters');
+    if (!groups || !groups.length) { container.innerHTML = ''; return; }
+
+    container.innerHTML = groups.map(function(g) {
+        return '<div class="flt-group" id="flt-attr-' + g.attributeId + '">'
+            + '<div class="flt-group-hdr" onclick="toggleFltGroup(\'flt-attr-' + g.attributeId + '\')">'
+            + '<span>' + g.nameAr + '</span><span class="flt-arrow">▾</span></div>'
+            + '<div class="flt-opts">'
+            + g.options.map(function(o) {
+                var checked = _attrVals.indexOf(o.valueId) !== -1;
+                return '<label class="flt-opt ' + (checked ? 'checked' : '') + '" onclick="toggleAttrFilter(' + o.valueId + ', this)">'
+                    + '<span class="flt-chk"></span>'
+                    + '<span class="flt-lbl">' + o.valueAr + '</span>'
+                    + '<span class="flt-count">' + o.count + '</span>'
+                    + '</label>';
+            }).join('')
+            + '</div></div>';
+    }).join('');
+}
+
+function updateActiveTags() {
+    var container = document.getElementById('activeTags');
+    var clearBtn  = document.getElementById('clearBtn');
+    var tags = [];
+
+    if (_brand)    tags.push({ label: _brand,    fn: 'clearAllFilters()' });
+    if (_category) tags.push({ label: _category, fn: 'clearAllFilters()' });
+    _attrVals.forEach(function(v) {
+        var el = document.querySelector('.flt-opt.checked [data-value="' + v + '"]');
+        tags.push({ label: 'فلتر #' + v, fn: 'toggleAttrFilter(' + v + ', null)' });
+    });
+
+    var hasFilters = _brand || _category || _attrVals.length;
+    container.style.display = hasFilters ? 'flex' : 'none';
+    clearBtn.style.display  = hasFilters ? 'block' : 'none';
+}
+
+// Init
+updateActiveTags();
+</script>
+}
