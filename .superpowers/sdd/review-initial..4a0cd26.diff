+@inject FTD.Web.Data.AppDbContext _layoutDb
+@{
+    var en = Context.Request.Cookies["ftd_lang"] == "en";
+    var navItems = _layoutDb.NavigationItems.Where(n => n.IsActive && (n.Location == "Navbar" || n.Location == "Both")).OrderBy(n => n.SortOrder).ToList();
+    var footItems = _layoutDb.NavigationItems.Where(n => n.IsActive && (n.Location == "Footer" || n.Location == "Both")).OrderBy(n => n.SortOrder).ToList();
+    var navBrands = _layoutDb.Brands.Where(b => b.IsActive).OrderBy(b => b.SortOrder).ToList();
+    var contactInfo = _layoutDb.ContactInfos.FirstOrDefault();
+}
+<!DOCTYPE html>
+<html lang="ar" dir="rtl" id="htmlRoot">
+<head>
+    <meta charset="UTF-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1.0">
+    <title>@ViewData["Title"] — FTD TechZone</title>
+    <meta name="description" content="@(ViewData["MetaDesc"] ?? "وجهتك الأولى لأحدث التكنولوجيا في مصر — الفجر للتجارة")">
+    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
+    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
+    @await RenderSectionAsync("Styles", required: false)
+</head>
+<body>
+    <!-- SEARCH OVERLAY -->
+    <div class="search-overlay" id="searchOverlay">
+        <div class="search-box">
+            <div class="search-input-wrap">
+                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
+                <input type="text" id="searchInput" placeholder="ابحث عن منتج، براند، أو كاتيجوري...">
+                <button class="search-close" onclick="closeSearch()">✕</button>
+            </div>
+            <div id="searchResults" class="search-results" style="display:none"></div>
+            <div class="search-tags" id="searchTags">
+                <a href="/brand/doogee" class="search-tag">Doogee Tablets</a>
+                <a href="/brand/jisulife" class="search-tag">Jisulife Fans</a>
+                <a href="/brand/dreame" class="search-tag">Dreame Webcams</a>
+                <span class="search-tag" onclick="doSearch('تابلت متين')">تابلت متين</span>
+                <span class="search-tag" onclick="doSearch('مروحة محمولة')">مروحة محمولة</span>
+                <span class="search-tag" onclick="doSearch('كاميرا 4K')">كاميرا 4K</span>
+            </div>
+        </div>
+    </div>
+    <!-- NAV -->
+    <nav id="mainNav">
+        <button class="hamburger" id="hamburger" aria-label="Menu">
+            <span></span><span></span><span></span>
+        </button>
+        <div class="nav-logo">
+            <a href="/" style="display:flex;align-items:center;text-decoration:none">
+                <img src="/images/ftd-logo.png" alt="FTD TechZone" style="height:38px;object-fit:contain">
+            </a>
+        </div>
+        <ul class="nav-center">
+            <li>
+                <a href="/" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
+                    <span data-ar>الرئيسية</span><span data-en>Home</span>
+                </a>
+            </li>
+            <li><a href="/#about"><span data-ar>عننا</span><span data-en>About</span></a></li>
+            <li class="nav-megabtn" id="productsMegaBtn">
+                <a href="/Products" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")" id="productsMegaTrigger">
+                    <span data-ar>المنتجات</span><span data-en>Products</span>
+                    <span class="mega-arrow">▾</span>
+                </a>
+                <div class="mega-panel" id="productsMegaPanel">
+                    <a href="/Products" class="mega-all">
+                        <span class="d-icon">🛍️</span>
+                        <span data-ar>كل المنتجات</span><span data-en>All Products</span>
+                    </a>
+                    <div class="mega-divider"></div>
+                    @foreach (var nb in navBrands)
+                    {
+                        <a href="/brand/@nb.Slug" class="mega-brand-link">
+                            @if (!string.IsNullOrEmpty(nb.LogoPath))
+                            {
+                                <img src="@nb.LogoPath" alt="@nb.NameEn" style="height:18px;object-fit:contain;max-width:70px">
+                            }
+                            else
+                            {
+                                <span>@nb.NameEn</span>
+                            }
+                        </a>
+                    }
+                </div>
+            </li>
+            <li><a href="/#contact"><span data-ar>تواصل معنا</span><span data-en>Contact</span></a></li>
+            @foreach (var ni in navItems)
+            {
+                var niUrl = ni.LinkType == "ContentPage" ? "/page/" + ni.PageSlug
+                : ni.LinkType == "External" ? ni.ExternalUrl
+                : ni.StaticRoute;
+                <li>
+                    <a href="@niUrl" @(ni.OpenInNewTab ? "target=_blank" : "")>
+                        <span data-ar>@ni.LabelAr</span><span data-en>@ni.LabelEn</span>
+                    </a>
+                </li>
+            }
+        </ul>
+        <div class="nav-right">
+            <div class="search-trigger" onclick="openSearch()">
+                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
+                <span><span data-ar>بحث...</span><span data-en>Search...</span></span>
+            </div>
+            <a href="/Cart" class="cart-btn">
+                <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 01-8 0" /></svg>
+                <div class="cart-count" id="cartCount">0</div>
+            </a>
+            <button class="lang-btn" onclick="toggleLang()">
+                <span data-ar>EN</span><span data-en>AR</span>
+            </button>
+        </div>
+    </nav>
+    <!-- MOBILE NAV DRAWER -->
+    <div class="mobile-nav" id="mobileNav">
+        <a href="/">
+            <span data-ar>الرئيسية</span><span data-en>Home</span>
+        </a>
+        <a href="/#about">
+            <span data-ar>عننا</span><span data-en>About</span>
+        </a>
+        <a href="/Products">
+            <span data-ar>كل المنتجات</span><span data-en>All Products</span>
+        </a>
+        @foreach (var nb in navBrands)
+        {
+            <a href="/brand/@nb.Slug">@nb.NameEn</a>
+        }
+        @foreach (var ni in navItems.Where(n => n.Location == "Navbar" || n.Location == "Both"))
+        {
+            var niUrl = ni.LinkType == "ContentPage" ? "/page/" + ni.PageSlug
+            : ni.LinkType == "External" ? ni.ExternalUrl
+            : ni.StaticRoute;
+            <a href="@niUrl">
+                <span data-ar>@ni.LabelAr</span><span data-en>@ni.LabelEn</span>
+            </a>
+        }
+        <a href="/#contact">
+            <span data-ar>تواصل معنا</span><span data-en>Contact</span>
+        </a>
+    </div>
+    <!-- MAIN CONTENT -->
+    <main>
+        @RenderBody()
+    </main>
+    <!-- FOOTER -->
+    <footer>
+        <div class="footer-grid">
+            <div>
+                <div class="footer-brand-logo">
+                    <img src="/images/ftd-logo.png" alt="FTD TechZone" style="height:36px;object-fit:contain">
+                </div>
+                <p class="footer-brand-desc">
+                    <span data-ar>وجهتك الأولى لأحدث التكنولوجيا في مصر — الفجر للتجارة</span>
+                    <span data-en>Your first destination for the latest technology in Egypt — Alfajr For Trade</span>
+                </p>
+                <div class="footer-social">
+                    @if (contactInfo?.ShowFacebook == true && !string.IsNullOrEmpty(contactInfo.Facebook))
+                    {
+                        <a href="@contactInfo.Facebook" target="_blank" class="social-btn">f</a>
+                    }
+                    @if (contactInfo?.ShowInstagram == true && !string.IsNullOrEmpty(contactInfo.Instagram))
+                    {
+                        <a href="@contactInfo.Instagram" target="_blank" class="social-btn">ig</a>
+                    }
+                    @if (contactInfo?.ShowWhatsApp == true && !string.IsNullOrEmpty(contactInfo.WhatsApp))
+                    {
+                        <a href="https://wa.me/@(contactInfo.WhatsApp?.Replace("+", "").Replace(" ", ""))" target="_blank" class="social-btn">wa</a>
+                    }
+                    @if (contactInfo?.ShowTikTok == true && !string.IsNullOrEmpty(contactInfo.TikTok))
+                    {
+                        <a href="@contactInfo.TikTok" target="_blank" class="social-btn">tt</a>
+                    }
+                </div>
+            </div>
+            <div class="footer-col">
+                <h4><span data-ar>روابط سريعة</span><span data-en>Quick Links</span></h4>
+                <ul>
+                    <li><a href="/"><span data-ar>الرئيسية</span><span data-en>Home</span></a></li>
+                    <li><a href="/#about"><span data-ar>عننا</span><span data-en>About</span></a></li>
+                    <li><a href="/Products"><span data-ar>المنتجات</span><span data-en>Products</span></a></li>
+                    <li><a href="/#contact"><span data-ar>تواصل معنا</span><span data-en>Contact</span></a></li>
+                    @foreach (var fi in footItems)
+                    {
+                        var fiUrl = fi.LinkType == "ContentPage" ? "/page/" + fi.PageSlug
+                        : fi.LinkType == "External" ? fi.ExternalUrl
+                        : fi.StaticRoute;
+                        <li>
+                            <a href="@fiUrl" @(fi.OpenInNewTab ? "target=_blank" : "")>
+                                <span data-ar>@fi.LabelAr</span><span data-en>@fi.LabelEn</span>
+                            </a>
+                        </li>
+                    }
+                </ul>
+            </div>
+            <div class="footer-col">
+                <h4><span data-ar>الماركات</span><span data-en>Brands</span></h4>
+                <ul>
+                    @foreach (var nb in navBrands)
+                    {
+                        <li><a href="/brand/@nb.Slug">@nb.NameEn</a></li>
+                    }
+                </ul>
+            </div>
+            <div class="footer-col">
+                <h4><span data-ar>تابعنا</span><span data-en>Follow Us</span></h4>
+                <ul>
+                    @if (contactInfo?.ShowFacebook == true && !string.IsNullOrEmpty(contactInfo.Facebook))
+                    {
+                        <li><a href="@contactInfo.Facebook" target="_blank">Facebook</a></li>
+                    }
+                    @if (contactInfo?.ShowInstagram == true && !string.IsNullOrEmpty(contactInfo.Instagram))
+                    {
+                        <li><a href="@contactInfo.Instagram" target="_blank">Instagram</a></li>
+                    }
+                    @if (contactInfo?.ShowWhatsApp == true && !string.IsNullOrEmpty(contactInfo.WhatsApp))
+                    {
+                        <li><a href="https://wa.me/@(contactInfo.WhatsApp?.Replace("+", "").Replace(" ", ""))" target="_blank">WhatsApp</a></li>
+                    }
+                    @if (contactInfo?.ShowTikTok == true && !string.IsNullOrEmpty(contactInfo.TikTok))
+                    {
+                        <li><a href="@contactInfo.TikTok" target="_blank">TikTok</a></li>
+                    }
+                </ul>
+            </div>
+        </div>
+        <div class="footer-bottom">
+            <p>
+                © @DateTime.Now.Year FTD TechZone —
+                <span data-ar>الفجر للتجارة. جميع الحقوق محفوظة.</span>
+                <span data-en>Alfajr For Trade. All Rights Reserved.</span>
+            </p>
+        </div>
+    </footer>
+    <script src="~/js/site.js" asp-append-version="true"></script>
+    @await RenderSectionAsync("Scripts", required: false)
+</body>
+</html>
diff --git a/FTD.Web/Views/Shared/_ProductCard.cshtml b/FTD.Web/Views/Shared/_ProductCard.cshtml
new file mode 100644
index 0000000..c9cf14e
--- /dev/null
+++ b/FTD.Web/Views/Shared/_ProductCard.cshtml
@@ -0,0 +1,79 @@
+@model FTD.Web.Models.Product
+@{
+    var badgeClass = Model.Badge switch
+    {
+        "NEW" => "badge-blue",
+        "HOT" => "badge-green",
+        "4K" => "badge-orange",
+        "RUGGED" => "badge-dark",
+        _ => "badge-blue"
+    };
+    var logoPath = Model.BrandName?.ToLower() switch
+    {
+        "doogee" => "/images/brands/doogee.png",
+        "jisulife" => "/images/brands/jisulife.png",
+        "dreame" => "/images/brands/dreame.png",
+        _ => null
+    };
+}
+<div class="product-card" onclick="location.href='/products/@Model.Slug'">
+    <div class="card-img">
+        @if (!string.IsNullOrEmpty(Model.Badge))
+        {
+            <span class="card-badge @badgeClass">@Model.Badge</span>
+        }
+        @if (!string.IsNullOrEmpty(Model.ImagePath))
+        {
+            <img src="@Model.ImagePath" alt="@Model.NameEn" style="max-height:120px;object-fit:contain">
+        }
+        else
+        {
+            <span style="font-size:52px">@(Model.Emoji ?? "📦")</span>
+        }
+    </div>
+    <div class="card-body">
+        <div class="card-brand">
+            @if (!string.IsNullOrEmpty(logoPath))
+            {
+                <img src="@logoPath" alt="@Model.BrandName"
+                     style="height:18px;object-fit:contain;max-width:80px;filter:brightness(0) saturate(100%) invert(35%) sepia(80%) saturate(500%) hue-rotate(195deg) brightness(95%)">
+            }
+            else
+            {
+
+                @Model.BrandName
+            }
+        </div>
+        <div class="card-name">
+            <span data-ar>@Model.NameAr</span>
+            <span data-en>@Model.NameEn</span>
+        </div>
+        <div class="card-desc">
+            <span data-ar>@Model.ShortDescAr</span>
+            <span data-en>@Model.ShortDescEn</span>
+        </div>
+    </div>
+    <div class="card-footer">
+        <div>
+            <div class="card-price">EGP @Model.Price.ToString("N0")</div>
+            @if (Model.OldPrice.HasValue && Model.OldPrice.Value > Model.Price)
+            {
+                var disc = (int)Math.Round((1 - Model.Price / Model.OldPrice.Value) * 100);
+                <div style="display:flex;align-items:center;gap:5px;margin-top:2px">
+                    <span style="font-size:11px;color:var(--text3);text-decoration:line-through">EGP @Model.OldPrice.Value.ToString("N0")</span>
+                    <span style="background:#FF3B30;color:white;font-size:9px;font-weight:800;padding:2px 6px;border-radius:100px">-@disc%</span>
+                </div>
+            }
+        </div>
+        <div style="display:flex;gap:6px">
+            <a href="/products/@Model.Slug" class="card-btn" onclick="event.stopPropagation()">
+                <span data-ar>التفاصيل</span><span data-en>Details</span>
+            </a>
+            <button class="card-btn" style="padding:7px 10px;background:var(--bg);color:var(--text);border:1.5px solid var(--border)"
+                    onclick="event.stopPropagation();addToCartQuick(@Model.Id, this)"
+                    title="أضف للسلة">
+                🛒
+            </button>
+        </div>
+    </div>
+</div>
diff --git a/FTD.Web/Views/Shared/_Section_Cards.cshtml b/FTD.Web/Views/Shared/_Section_Cards.cshtml
new file mode 100644
index 0000000..150d940
--- /dev/null
+++ b/FTD.Web/Views/Shared/_Section_Cards.cshtml
@@ -0,0 +1,51 @@
+@model FTD.Web.Models.PageSection
+@{
+    var cards = new List<(string titleAr, string titleEn, string bodyAr, string bodyEn, string icon)>();
+    if (!string.IsNullOrEmpty(Model.ContentJson))
+    {
+        try {
+            var arr = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(Model.ContentJson);
+            if (arr != null)
+                foreach (var el in arr)
+                {
+                    el.TryGetProperty("title_ar", out var tAr); el.TryGetProperty("title_en", out var tEn);
+                    el.TryGetProperty("body_ar",  out var bAr); el.TryGetProperty("body_en",  out var bEn);
+                    el.TryGetProperty("icon",     out var ic);
+                    cards.Add((tAr.GetString() ?? "", tEn.GetString() ?? "",
+                               bAr.GetString() ?? "", bEn.GetString() ?? "",
+                               ic.GetString()  ?? "✓"));
+                }
+        } catch { }
+    }
+}
+
+@if (cards.Any())
+{
+    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.2rem;margin-bottom:2rem">
+        @foreach (var card in cards)
+        {
+            <div style="background:white;border:1px solid var(--border);border-radius:var(--rl);padding:1.5rem;transition:all .3s" onmouseover="this.style.boxShadow='0 8px 32px rgba(26,107,255,.12)';this.style.borderColor='rgba(26,107,255,.3)'" onmouseout="this.style.boxShadow='';this.style.borderColor='var(--border)'">
+                @if (!string.IsNullOrEmpty(card.icon))
+                {
+                    <div style="width:44px;height:44px;background:var(--blue-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:1rem;border:1px solid rgba(26,107,255,.15)">
+                        @card.icon
+                    </div>
+                }
+                @if (!string.IsNullOrEmpty(card.titleAr) || !string.IsNullOrEmpty(card.titleEn))
+                {
+                    <h3 style="font-size:15px;font-weight:700;margin-bottom:.5rem">
+                        <span data-ar>@card.titleAr</span>
+                        <span data-en>@card.titleEn</span>
+                    </h3>
+                }
+                @if (!string.IsNullOrEmpty(card.bodyAr) || !string.IsNullOrEmpty(card.bodyEn))
+                {
+                    <p style="font-size:13px;color:var(--text2);line-height:1.7">
+                        <span data-ar>@card.bodyAr</span>
+                        <span data-en>@card.bodyEn</span>
+                    </p>
+                }
+            </div>
+        }
+    </div>
+}
diff --git a/FTD.Web/Views/Shared/_Section_FAQ.cshtml b/FTD.Web/Views/Shared/_Section_FAQ.cshtml
new file mode 100644
index 0000000..a752e0a
--- /dev/null
+++ b/FTD.Web/Views/Shared/_Section_FAQ.cshtml
@@ -0,0 +1,108 @@
+@model FTD.Web.Models.PageSection
+@{
+    var items = new List<(string qAr, string qEn, string aAr, string aEn)>();
+    if (!string.IsNullOrEmpty(Model.ContentJson))
+    {
+        try {
+            var arr = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(Model.ContentJson);
+            if (arr != null)
+                foreach (var el in arr)
+                {
+                    el.TryGetProperty("q_ar", out var qAr); el.TryGetProperty("q_en", out var qEn);
+                    el.TryGetProperty("a_ar", out var aAr); el.TryGetProperty("a_en", out var aEn);
+                    var q = qAr.GetString() ?? ""; var qe = qEn.GetString() ?? "";
+                    var a = aAr.GetString() ?? ""; var ae = aEn.GetString() ?? "";
+                    if (!string.IsNullOrWhiteSpace(q) || !string.IsNullOrWhiteSpace(qe))
+                        items.Add((q, qe, a, ae));
+                }
+        } catch { }
+    }
+    var uid = "faq_" + Model.Id;
+}
+
+@if (items.Any())
+{
+    <div class="ftd-accordion" id="@uid" style="margin-bottom:2rem">
+        @for (int i = 0; i < items.Count; i++)
+        {
+            var item   = items[i];
+            var itemId = uid + "_" + i;
+            <div class="ftd-acc-item">
+                <button class="ftd-acc-btn" type="button"
+                        onclick="ftdToggle('@itemId')"
+                        aria-expanded="false"
+                        id="btn_@itemId">
+                    <span class="ftd-acc-q">
+                        <span data-ar>@item.qAr</span>
+                        <span data-en>@item.qEn</span>
+                    </span>
+                    <span class="ftd-acc-icon" id="icon_@itemId">+</span>
+                </button>
+                <div class="ftd-acc-body" id="body_@itemId" style="display:none">
+                    <div class="ftd-acc-answer">
+                        <span data-ar>@item.aAr</span>
+                        <span data-en>@item.aEn</span>
+                    </div>
+                </div>
+            </div>
+        }
+    </div>
+
+    <style>
+    .ftd-accordion { border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
+    .ftd-acc-item  { border-bottom: 1px solid var(--border); background: white; }
+    .ftd-acc-item:last-child { border-bottom: none; }
+    .ftd-acc-btn   {
+        width: 100%; display: flex; align-items: center;
+        justify-content: space-between; gap: 1rem;
+        padding: 1.1rem 1.4rem;
+        background: none; border: none; cursor: pointer;
+        text-align: right; font-family: var(--font);
+        font-size: 15px; font-weight: 600; color: var(--text);
+        transition: background .15s;
+    }
+    .ftd-acc-btn:hover { background: var(--bg); }
+    .ftd-acc-btn.open  { background: var(--blue-light); color: var(--blue); }
+    .ftd-acc-q   { flex: 1; text-align: right; line-height: 1.5; }
+    .ftd-acc-icon {
+        width: 28px; height: 28px; border-radius: 50%;
+        background: var(--bg); border: 1.5px solid var(--border);
+        display: flex; align-items: center; justify-content: center;
+        font-size: 18px; font-weight: 400; color: var(--text2);
+        flex-shrink: 0; transition: all .25s; line-height: 1;
+    }
+    .ftd-acc-btn.open .ftd-acc-icon {
+        background: var(--blue); color: white;
+        border-color: var(--blue); transform: rotate(45deg);
+    }
+    .ftd-acc-body  { overflow: hidden; }
+    .ftd-acc-answer {
+        padding: .8rem 1.4rem 1.2rem;
+        font-size: 14px; color: var(--text2);
+        line-height: 1.9; border-top: 1px solid var(--border);
+        background: white;
+    }
+    </style>
+
+    <script>
+    function ftdToggle(id) {
+        var body = document.getElementById('body_' + id);
+        var btn  = document.getElementById('btn_'  + id);
+        var icon = document.getElementById('icon_' + id);
+        var isOpen = body.style.display !== 'none';
+
+        // Close all in same accordion
+        var acc = btn.closest('.ftd-accordion');
+        acc.querySelectorAll('.ftd-acc-body').forEach(function(b)  { b.style.display = 'none'; });
+        acc.querySelectorAll('.ftd-acc-btn').forEach(function(b)   { b.classList.remove('open'); b.setAttribute('aria-expanded','false'); });
+        acc.querySelectorAll('.ftd-acc-icon').forEach(function(ic) { ic.textContent = '+'; });
+
+        // Open clicked if it was closed
+        if (!isOpen) {
+            body.style.display = 'block';
+            btn.classList.add('open');
+            btn.setAttribute('aria-expanded', 'true');
+        }
+    }
+    </script>
+}
diff --git a/FTD.Web/Views/Shared/_Section_Hero.cshtml b/FTD.Web/Views/Shared/_Section_Hero.cshtml
