+        @foreach (var order in Model)
+        {
+            <tr>
+              <td><strong style="color:var(--a-blue)">@order.OrderNumber</strong></td>
+              <td>@order.CustomerName</td>
+              <td style="direction:ltr;font-size:13px">@order.CustomerPhone</td>
+              <td style="font-size:13px">@order.Governorate</td>
+              <td><strong>EGP @order.TotalAmount.ToString("N0")</strong></td>
+              <td>
+                <span class="status-badge" style="background:@(order.Status.ColorHex)20;color:@order.Status.ColorHex;border:1px solid @(order.Status.ColorHex)40">
+                  @order.Status.Icon @order.Status.NameAr
+                </span>
+              </td>
+              <td style="font-size:12px;color:var(--a-text2)">@order.CreatedAt.ToString("dd/MM HH:mm")</td>
+              <td><a href="/Admin/AdminOrders/Detail/@order.Id" class="a-btn-sm">تفاصيل</a></td>
+            </tr>
+        }
+      </tbody>
+    </table>
+    @if (!Model.Any())
+    {
+        <div style="text-align:center;padding:3rem;color:var(--a-text2)">لا توجد طلبات</div>
+    }
+  </div>
+</div>
