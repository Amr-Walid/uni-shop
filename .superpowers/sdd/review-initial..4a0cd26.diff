@@ -0,0 +1,58 @@
+@model List<FTD.Web.Models.Brand>
+@{
+    Layout = "_AdminLayout";
+    ViewData["Title"] = "البراندات";
+}
+<div style="display:flex;justify-content:flex-end;margin-bottom:1.5rem">
+    <a href="/Admin/AdminBrands/Create" class="a-btn">+ براند جديد</a>
+</div>
+<div class="a-card">
+    <div class="a-table-wrap">
+        <table class="a-table">
+            <thead>
+                <tr><th>البراند</th><th>اللوجو</th><th>البانر</th><th>المنتجات</th><th>الترتيب</th><th>الحالة</th><th></th></tr>
+            </thead>
+            <tbody>
+                @foreach (var b in Model)
+                {
+                    <tr>
+                        <td>
+                            <div style="font-weight:700">@b.NameAr</div>
+                            <div style="font-size:11px;color:var(--a-text3);font-family:monospace">@b.Slug</div>
+                        </td>
+                        <td>
+                            @if (!string.IsNullOrEmpty(b.LogoPath))
+                            {
+                                <img src="@b.LogoPath" style="height:20px;object-fit:contain;max-width:80px">
+                            }
+                            else
+                            {
+
+                                <span style="color:var(--a-text3);font-size:12px">—</span>
+                            }
+                        </td>
+                        <td>
+                            @if (!string.IsNullOrEmpty(b.BannerPath))
+                            {
+                                <img src="@b.BannerPath" style="height:32px;width:80px;object-fit:cover;border-radius:5px">
+                            }
+                            else
+                            {
+
+                                <span style="color:var(--a-text3);font-size:12px">—</span>
+                            }
+                        </td>
+                        <td>@b.Products.Count منتج</td>
+                        <td>@b.SortOrder</td>
+                        <td>
+                            <span class="status-badge" style="background:@(b.IsActive ? "rgba(0,196,140,.1)" : "rgba(255,59,48,.1)");color:@(b.IsActive ? "#00C48C" : "#FF3B30")">
+                                @(b.IsActive ? "نشط" : "مخفي")
+                            </span>
+                        </td>
+                        <td><a href="/Admin/AdminBrands/Edit/@b.Id" class="a-btn-sm">تعديل</a></td>
+                    </tr>
+                }
+            </tbody>
+        </table>
+    </div>
+</div>
diff --git a/FTD.Web/Views/Admin/Categories/Form.cshtml b/FTD.Web/Views/Admin/Categories/Form.cshtml
