+@model List<FTD.Web.Models.Product>
+@{
+    Layout = "_AdminLayout";
+    ViewData["Title"] = "المنتجات";
+}
+
+<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
+  <div></div>
+  <a href="/Admin/AdminProducts/Create" class="a-btn">+ إضافة منتج</a>
+</div>
+
+<div class="a-card">
+  <div class="a-table-wrap">
+    <table class="a-table">
+      <thead>
+        <tr>
+          <th>المنتج</th>
+          <th>الكاتيجوري</th>
+          <th>البراند</th>
+          <th>السعر</th>
+          <th>المخزون</th>
+          <th>الحالة</th>
+          <th>الإجراءات</th>
+        </tr>
+      </thead>
+      <tbody>
+        @foreach (var p in Model)
+        {
+            <tr>
+              <td>
+                <div style="display:flex;align-items:center;gap:10px">
+                  <div style="width:40px;height:40px;background:var(--a-bg);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:20px">
+                    @(p.Emoji ?? "📦")
+                  </div>
+                  <div>
+                    <div style="font-weight:700;font-size:13px">@p.NameAr</div>
+                    <div style="font-size:11px;color:var(--a-text2)">@p.Slug</div>
+                  </div>
+                </div>
+              </td>
+              <td style="font-size:13px">@p.Category?.NameAr</td>
+              <td><span class="status-badge" style="background:rgba(26,107,255,.1);color:#1A6BFF">@p.BrandName</span></td>
+              <td style="font-weight:700">EGP @p.Price.ToString("N0")</td>
+              <td>@p.Stock</td>
+              <td>
+                <span class="status-badge" style="background:@(p.IsActive ? "rgba(0,196,140,.1)" : "rgba(255,59,48,.1)");color:@(p.IsActive ? "#00C48C" : "#FF3B30")">
+                  @(p.IsActive ? "نشط" : "مخفي")
+                </span>
+              </td>
+              <td>
+                <div style="display:flex;gap:6px">
+                  <a href="/Admin/AdminProducts/Edit/@p.Id" class="a-btn-sm">تعديل</a>
+                  <form action="/Admin/AdminProducts/Delete" method="post" style="display:inline" onsubmit="return confirm('هل أنت متأكد من حذف هذا المنتج؟')">
+                    @Html.AntiForgeryToken()
+                    <input type="hidden" name="id" value="@p.Id">
+                    <button type="submit" class="a-btn-sm a-btn-danger">حذف</button>
+                  </form>
+                </div>
+              </td>
+            </tr>
+        }
+      </tbody>
+    </table>
+  </div>
+</div>
diff --git a/FTD.Web/Views/Admin/Settings/Index.cshtml b/FTD.Web/Views/Admin/Settings/Index.cshtml
new file mode 100644
index 0000000..30c6c21
--- /dev/null
+++ b/FTD.Web/Views/Admin/Settings/Index.cshtml
@@ -0,0 +1,320 @@
+@model List<FTD.Web.Models.SiteSetting>
+@{
+    Layout = "_AdminLayout";
+    ViewData["Title"] = "إعدادات الموقع";
+    var contact = ViewBag.ContactInfo as FTD.Web.Models.ContactInfo;
+}
+<!-- SITE SETTINGS -->
+<div class="a-card" style="margin-bottom:1.5rem">
+    <h3 class="a-card-title">إعدادات عامة</h3>
+    <form action="/Admin/AdminSettings/SaveSettings" method="post">
+        @Html.AntiForgeryToken()
+        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem">
+            @foreach (var s in Model)
+            {
+                <div class="a-form-group">
+                    <label>
+                        @s.Description
+                        <span style="font-family:monospace;font-size:10px;color:var(--a-text3);margin-right:6px">@s.Key</span>
+                    </label>
+                    @if (s.Type == "color")
+                    {
+                        <div style="display:flex;align-items:center;gap:8px">
+                            <input type="color" name="values[@s.Id]" value="@s.Value"
+                                   style="width:44px;height:36px;border:1px solid var(--a-border);border-radius:8px;cursor:pointer">
+                            <input type="text" value="@s.Value" dir="ltr"
+                                   style="flex:1;padding:8px 12px;border:1.5px solid var(--a-border);border-radius:8px;font-size:13px;font-family:monospace;background:var(--a-bg);color:var(--a-text)">
+                        </div>
+                    }
+                    else
+                    {
+                        <input type="text" name="values[@s.Id]" value="@s.Value"
+                               dir="@(s.Key.EndsWith(".ar") ? "rtl" : "ltr")">
+                    }
+                </div>
+            }
+        </div>
+        <button type="submit" class="a-btn" style="margin-top:1.5rem">💾 حفظ الإعدادات</button>
+    </form>
+</div>
+<!-- CONTACT INFO -->
+<div class="a-card">
+    <h3 class="a-card-title">بيانات التواصل</h3>
+    <form action="/Admin/AdminSettings/SaveContact" method="post">
+        @Html.AntiForgeryToken()
+        <input type="hidden" name="Id" value="@(contact?.Id ?? 1)">
+
+        @* PHONE *@
+        <div class="csb">
+            <div class="csb-hdr">
+                <span>📞 الهاتف</span>
+                <button type="button" class="sw-btn @(contact?.ShowPhone == true ? "sw-on" : "")"
+                        onclick="toggleSw(this,'ShowPhone')">
+                    <span class="sw-knob"></span>
+                </button>
+                <input type="hidden" name="ShowPhone" value="@(contact?.ShowPhone == true ? "true" : "false")" id="hShowPhone">
+                <span class="sw-lbl">عرض في الموقع</span>
+            </div>
+            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
+                <div class="a-form-group">
+                    <label>رقم الهاتف الأول</label>
+                    <input name="Phone" value="@contact?.Phone" placeholder="+20 100 000 0000" dir="ltr">
+                </div>
+                <div class="a-form-group">
+                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:5px">
+                        <label style="margin:0;font-size:11px;font-weight:700;color:var(--a-text2);text-transform:uppercase">رقم الهاتف الثاني</label>
+                        <div style="display:flex;align-items:center;gap:6px">
+                            <button type="button" class="sw-btn sw-sm @(contact?.ShowPhone2 == true ? "sw-on" : "")"
+                                    onclick="toggleSw(this,'ShowPhone2')">
+                                <span class="sw-knob"></span>
+                            </button>
+                            <input type="hidden" name="ShowPhone2" value="@(contact?.ShowPhone2 == true ? "true" : "false")" id="hShowPhone2">
+                            <span class="sw-lbl">عرض</span>
+                        </div>
+                    </div>
+                    <input name="Phone2" value="@contact?.Phone2" placeholder="+20 100 000 0001" dir="ltr">
+                </div>
+            </div>
+        </div>
+
+        @* EMAIL *@
+        <div class="csb">
+            <div class="csb-hdr">
+                <span>✉️ البريد الإلكتروني</span>
+                <div style="display:flex;align-items:center;gap:6px">
+                    <button type="button" class="sw-btn @(contact?.ShowEmail == true ? "sw-on" : "")"
+                            onclick="toggleSw(this,'ShowEmail')">
+                        <span class="sw-knob"></span>
+                    </button>
+                    <input type="hidden" name="ShowEmail" value="@(contact?.ShowEmail == true ? "true" : "false")" id="hShowEmail">
+                    <span class="sw-lbl">عرض في الموقع</span>
+                </div>
+            </div>
+            <div class="a-form-group">
+                <input name="Email" value="@contact?.Email" placeholder="info@ftdtechzone.com" dir="ltr">
+            </div>
+        </div>
+
+        @* ADDRESS *@
+        <div class="csb">
+            <div class="csb-hdr">
+                <span>📍 العنوان</span>
+                <div style="display:flex;align-items:center;gap:6px">
+                    <button type="button" class="sw-btn @(contact?.ShowAddress == true ? "sw-on" : "")"
+                            onclick="toggleSw(this,'ShowAddress')">
+                        <span class="sw-knob"></span>
+                    </button>
+                    <input type="hidden" name="ShowAddress" value="@(contact?.ShowAddress == true ? "true" : "false")" id="hShowAddress">
+                    <span class="sw-lbl">عرض في الموقع</span>
+                </div>
+            </div>
+            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
+                <div class="a-form-group">
+                    <label>العنوان بالعربي</label>
+                    <input name="AddressAr" value="@contact?.AddressAr" placeholder="القاهرة، مصر الجديدة">
+                </div>
+                <div class="a-form-group">
+                    <label>Address in English</label>
+                    <input name="AddressEn" value="@contact?.AddressEn" placeholder="Cairo, Heliopolis" dir="ltr">
+                </div>
+                <div class="a-form-group">
+                    <label>المدينة</label>
+                    <input name="City" value="@contact?.City" placeholder="Cairo">
+                </div>
+            </div>
+        </div>
+
+        @* MAP *@
+        <div class="csb">
+            <div class="csb-hdr">
+                <span>🗺️ خريطة Google Maps</span>
+                <div style="display:flex;align-items:center;gap:6px">
+                    <button type="button" class="sw-btn @(contact?.ShowMap == true ? "sw-on" : "")"
+                            onclick="toggleSw(this,'ShowMap')">
+                        <span class="sw-knob"></span>
+                    </button>
+                    <input type="hidden" name="ShowMap" value="@(contact?.ShowMap == true ? "true" : "false")" id="hShowMap">
+                    <span class="sw-lbl">عرض في الموقع</span>
+                </div>
+            </div>
+            <div class="a-form-group">
+                <label>رابط Embed الخريطة</label>
+                <input name="MapEmbedUrl" value="@contact?.MapEmbedUrl"
+                       placeholder="https://www.google.com/maps/embed?pb=..." dir="ltr">
+                <small style="font-size:11px;color:var(--a-text3);margin-top:4px;display:block">
+                    افتح Google Maps ← ابحث عن موقعك ← اضغط Share ← Embed a map ← انسخ الـ src
+                </small>
+            </div>
+            @if (!string.IsNullOrEmpty(contact?.MapEmbedUrl))
+            {
+                <div style="margin-top:1rem;border-radius:12px;overflow:hidden;border:1px solid var(--a-border)">
+                    <iframe src="@contact.MapEmbedUrl" width="100%" height="220"
+                            style="border:0;display:block" allowfullscreen="" loading="lazy"
+                            referrerpolicy="no-referrer-when-downgrade"></iframe>
+                </div>
+            }
+        </div>
+
+        @* WORKING HOURS *@
+        <div class="csb">
+            <div class="csb-hdr">
+                <span>🕐 ساعات العمل</span>
+                <div style="display:flex;align-items:center;gap:6px">
+                    <button type="button" class="sw-btn @(contact?.ShowWorkingHours == true ? "sw-on" : "")"
+                            onclick="toggleSw(this,'ShowWorkingHours')">
+                        <span class="sw-knob"></span>
+                    </button>
+                    <input type="hidden" name="ShowWorkingHours" value="@(contact?.ShowWorkingHours == true ? "true" : "false")" id="hShowWorkingHours">
+                    <span class="sw-lbl">عرض في الموقع</span>
+                </div>
+            </div>
+            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
+                <div class="a-form-group">
+                    <label>بالعربي</label>
+                    <input name="WorkingHoursAr" value="@contact?.WorkingHoursAr" placeholder="السبت – الخميس: 10ص – 10م">
+                </div>
+                <div class="a-form-group">
+                    <label>In English</label>
+                    <input name="WorkingHoursEn" value="@contact?.WorkingHoursEn" placeholder="Sat – Thu: 10AM – 10PM" dir="ltr">
+                </div>
+            </div>
+        </div>
+
+        @* SOCIAL MEDIA *@
+        <div class="csb">
+            <div class="csb-hdr"><span>🔗 السوشيال ميديا</span></div>
+            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
+                @{
+                    var socials = new (string Name, string Field, string? Value, bool Show, string ShowField, string Placeholder)[]
+                    {
+                                ("Facebook",  "Facebook",  contact?.Facebook,  contact?.ShowFacebook==true,  "ShowFacebook",  "https://facebook.com/..."),
+                                ("Instagram", "Instagram", contact?.Instagram, contact?.ShowInstagram==true, "ShowInstagram", "https://instagram.com/..."),
+                                ("WhatsApp",  "WhatsApp",  contact?.WhatsApp,  contact?.ShowWhatsApp==true,  "ShowWhatsApp",  "+201000000000"),
+                                ("TikTok",    "TikTok",    contact?.TikTok,    contact?.ShowTikTok==true,    "ShowTikTok",    "https://tiktok.com/@..."),
+                    };
+                }
+                @foreach (var s in socials)
+                {
+                    <div style="background:var(--a-bg);border-radius:10px;padding:1rem;border:1px solid var(--a-border)">
+                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.7rem">
+                            <span style="font-size:13px;font-weight:700">@s.Name</span>
+                            <div style="display:flex;align-items:center;gap:6px">
+                                <button type="button" class="sw-btn sw-sm @(s.Show ? "sw-on" : "")"
+                                        onclick="toggleSw(this,'@s.ShowField')">
+                                    <span class="sw-knob"></span>
+                                </button>
+                                <input type="hidden" name="@s.ShowField" value="@(s.Show ? "true" : "false")" id="h@(s.ShowField)">
+                                <span class="sw-lbl">عرض</span>
+                            </div>
+                        </div>
+                        <input name="@s.Field" value="@s.Value" placeholder="@s.Placeholder" dir="ltr"
+                               style="width:100%;padding:9px 12px;background:var(--a-card);border:1.5px solid var(--a-border);border-radius:8px;font-size:13px;color:var(--a-text);font-family:'Tajawal',sans-serif;outline:none">
+                    </div>
+                }
+            </div>
+        </div>
+
+        <button type="submit" class="a-btn" style="margin-top:1.5rem">💾 حفظ بيانات التواصل</button>
+    </form>
+</div>
+
+@section Styles {
+    <style>
+        .csb {
+            padding: 1.2rem 0;
+            border-bottom: 1px solid var(--a-border);
+        }
+
+            .csb:last-of-type {
+                border-bottom: none;
+            }
+
+        .csb-hdr {
+            display: flex;
+            align-items: center;
+            justify-content: space-between;
+            margin-bottom: 1rem;
+            font-size: 12px;
+            font-weight: 700;
+            color: var(--a-text2);
+            text-transform: uppercase;
+            letter-spacing: .5px;
+        }
+        /* Switch button */
+        .sw-btn {
+            width: 38px;
+            height: 22px;
+            border-radius: 100px;
+            background: var(--a-border);
+            border: none;
+            cursor: pointer;
+            position: relative;
+            transition: background .2s;
+            flex-shrink: 0;
+            padding: 0;
+        }
+
+            .sw-btn.sw-on {
+                background: var(--a-blue);
+            }
+
+        .sw-knob {
+            position: absolute;
+            top: 3px;
+            left: 3px;
+            width: 16px;
+            height: 16px;
+            border-radius: 50%;
+            background: white;
+            transition: transform .2s;
+            display: block;
+            box-shadow: 0 1px 3px rgba(0,0,0,.2);
+        }
+
+        .sw-btn.sw-on .sw-knob {
+            transform: translateX(16px);
+        }
+
+        .sw-btn.sw-sm {
+            width: 28px;
+            height: 16px;
+        }
+
+            .sw-btn.sw-sm .sw-knob {
+                width: 10px;
+                height: 10px;
+                top: 3px;
+                left: 3px;
+            }
+
+            .sw-btn.sw-sm.sw-on .sw-knob {
+                transform: translateX(12px);
+            }
+
+        .sw-lbl {
+            font-size: 12px;
+            color: var(--a-text2);
+        }
+    </style>
+}
+
+@section Scripts {
+    <script>
+        function toggleSw(btn, field) {
+            btn.classList.toggle('sw-on');
+            var isOn = btn.classList.contains('sw-on');
+            document.getElementById('h' + field).value = isOn ? 'true' : 'false';
+        }
+
+        // Before submit: copy hidden values into named inputs for the server
+        document.querySelector('form[action*="SaveContact"]').addEventListener('submit', function() {
+            document.querySelectorAll('input[data-fname]').forEach(function(el) {
+                var named = document.createElement('input');
+                named.type = 'hidden';
+                named.name = el.getAttribute('data-fname');
+                named.value = el.value;
+                el.parentNode.appendChild(named);
+            });
+        });
+    </script>
+}
diff --git a/FTD.Web/Views/Cart/Index.cshtml b/FTD.Web/Views/Cart/Index.cshtml
new file mode 100644
index 0000000..eeea6d1
--- /dev/null
+++ b/FTD.Web/Views/Cart/Index.cshtml
@@ -0,0 +1,125 @@
+@model FTD.Web.ViewModels.CartViewModel
+@{
+    ViewData["Title"] = "سلة التسوق";
+}
+
+<div class="cart-page">
+    <div class="breadcrumb" style="padding-right:0;padding-left:0">
+        <a href="/"><span data-ar>الرئيسية</span><span data-en>Home</span></a>
+        <span class="breadcrumb-sep">/</span>
+        <span><span data-ar>سلة التسوق</span><span data-en>Shopping Cart</span></span>
+    </div>
+
+    <div style="margin-top:2rem;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
+        <h1 style="font-size:1.8rem;font-weight:900;letter-spacing:-.5px">
+            <span data-ar>سلة التسوق</span><span data-en>Shopping Cart</span>
+        </h1>
+        <a href="/Products" style="font-size:13px;color:var(--blue);font-weight:600">
+            ← <span data-ar>متابعة التسوق</span><span data-en>Continue Shopping</span>
+        </a>
+    </div>
+
+    @if (!Model.Items.Any())
+    {
+        <div class="empty-cart">
+            <div class="empty-cart-icon">🛒</div>
+            <p style="font-size:1.1rem;font-weight:700;margin-bottom:.5rem">
+                <span data-ar>السلة فارغة</span><span data-en>Your cart is empty</span>
+            </p>
+            <p style="color:var(--text3);margin-bottom:1.5rem">
+                <span data-ar>أضف منتجات من متجرنا</span><span data-en>Add products from our store</span>
+            </p>
+            <a href="/Products" class="btn-primary" style="display:inline-flex;margin:auto">
+                <span data-ar>تصفح المنتجات</span><span data-en>Browse Products</span>
+            </a>
+        </div>
+    }
+    else
+    {
+        <div class="cart-grid">
+            <div>
+                <div class="cart-items">
+                    @foreach (var item in Model.Items)
+                    {
+                        <div class="cart-item">
+                            <div class="cart-item-img">
+                                @if (!string.IsNullOrEmpty(item.ImagePath))
+                                {
+                                    <img src="@item.ImagePath" alt="@item.ProductName" style="max-height:52px;object-fit:contain">
+                                }
+                                else
+                                {
+                                    @(item.Emoji ?? "📦")
+                                }
+                            </div>
+                            <div style="flex:1">
+                                <div class="cart-item-brand">@item.BrandName</div>
+                                <div class="cart-item-name">@item.ProductName</div>
+                                <div class="qty-wrap">
+                                    <form action="/Cart/Update" method="post" style="display:contents">
+                                        @Html.AntiForgeryToken()
+                                        <input type="hidden" name="productId" value="@item.ProductId">
+                                        <button type="submit" name="qty" value="@(item.Quantity - 1)" class="qty-btn">−</button>
+                                        <span class="qty-num">@item.Quantity</span>
+                                        <button type="submit" name="qty" value="@(item.Quantity + 1)" class="qty-btn">+</button>
+                                    </form>
+                                    <span class="cart-item-price">EGP @item.SubTotal.ToString("N0")</span>
+                                </div>
+                            </div>
+                            <form action="/Cart/Remove" method="post">
+                                @Html.AntiForgeryToken()
+                                <input type="hidden" name="productId" value="@item.ProductId">
+                                <button type="submit" class="cart-item-remove">🗑</button>
+                            </form>
+                        </div>
+                    }
+                </div>
+
+                <form action="/Cart/Clear" method="post" style="margin-top:1rem">
+                    @Html.AntiForgeryToken()
+                    <button type="submit" style="background:none;border:none;color:var(--text3);font-size:12px;cursor:pointer;font-family:var(--font);padding:.5rem 0">
+                        <span data-ar>إفراغ السلة</span><span data-en>Clear Cart</span>
+                    </button>
+                </form>
+            </div>
+
+            <!-- SUMMARY -->
+            <div class="cart-summary">
+                <h3><span data-ar>ملخص الطلب</span><span data-en>Order Summary</span></h3>
+                <div class="summary-row">
+                    <span><span data-ar>المجموع الفرعي</span><span data-en>Subtotal</span></span>
+                    <span>EGP @Model.SubTotal.ToString("N0")</span>
+                </div>
+                <div class="summary-row">
+                    <span><span data-ar>الشحن</span><span data-en>Shipping</span></span>
+                    <span>
+                        @if (Model.FreeShipping)
+                        {
+                            <span style="color:var(--green);font-weight:700">
+                                <span data-ar>مجاني</span><span data-en>Free</span>
+                            </span>
+                        }
+                        else
+                        {
+                            <span>EGP @Model.ShippingFee.ToString("N0")</span>
+                        }
+                    </span>
+                </div>
+                <div class="summary-row total">
+                    <span><span data-ar>الإجمالي</span><span data-en>Total</span></span>
+                    <span style="color:var(--blue)">EGP @Model.Total.ToString("N0")</span>
+                </div>
+                @if (!Model.FreeShipping)
+                {
+                    <p style="font-size:11px;color:var(--text3);text-align:center;margin-top:.5rem">
+                        <span data-ar>شحن مجاني للطلبات فوق 5000 جنيه</span>
+                        <span data-en>Free shipping on orders above EGP 5,000</span>
+                    </p>
+                }
+                <a href="/Order/Checkout" class="checkout-btn" style="display:block;text-align:center;margin-top:1rem">
+                    <span data-ar>إتمام الطلب ←</span><span data-en>Checkout →</span>
+                </a>
+            </div>
+        </div>
+    }
+</div>
diff --git a/FTD.Web/Views/Home/Index.cshtml b/FTD.Web/Views/Home/Index.cshtml
new file mode 100644
index 0000000..c81df41
--- /dev/null
+++ b/FTD.Web/Views/Home/Index.cshtml
@@ -0,0 +1,412 @@
+@model FTD.Web.ViewModels.HomeViewModel
+@{
+    ViewData["Title"] = "الرئيسية";
+    string Get(string key) => Model.ContentBlocks.TryGetValue(key, out var v) ? v : "";
+}
+
+<!-- HERO SLIDER -->
+<section class="hero">
+    <div class="hero-bg"></div>
+    <div class="hero-grid-lines"></div>
+    <div class="slider-wrap">
+
+        @for (int i = 0; i < Model.Categories.Count && i < 3; i++)
+        {
+            var cat = Model.Categories[i];
+            var catProduct = Model.FeaturedProducts.FirstOrDefault(p => p.CategoryId == cat.Id);
+            <div class="slide @(i == 0 ? "active" : "")">
+                <div class="slide-content">
+                    <div class="slide-tag">✦ <span data-ar>@(i == 0 ? "وصل حديثاً" : i == 1 ? "الأكثر مبيعاً" : "عرض خاص")</span><span data-en>@(i == 0 ? "New Arrival" : i == 1 ? "Best Seller" : "Hot Deal")</span></div>
+                    <h1 class="slide-title">
+                        <span data-ar>@cat.NameAr<br><span class="hl">@(catProduct?.BrandName ?? "")</span></span>
+                        <span data-en>@cat.NameEn<br><span class="hl">@(catProduct?.BrandName ?? "")</span></span>
+                    </h1>
+                    <p class="slide-desc">
+                        <span data-ar>@(catProduct?.ShortDescAr ?? cat.NameAr)</span>
+                        <span data-en>@(catProduct?.ShortDescEn ?? cat.NameEn)</span>
+                    </p>
+                    <div class="slide-actions">
+                        <a href="/Products?category=@cat.Slug" class="btn-primary">
+                            <span data-ar>اكتشف المنتجات</span><span data-en>Explore Products</span> →
+                        </a>
+                        @if (catProduct != null)
+                        {
+                            <a href="/Products/@catProduct.Slug" class="btn-ghost">
+                                @catProduct.BrandName @catProduct.NameEn
+                            </a>
+                        }
+                    </div>
+                </div>
+                <div class="slide-visual">
+                    @if (catProduct != null)
+                    {
+                        <div class="product-showcase">
+                            @if (!string.IsNullOrEmpty(catProduct.Badge))
+                            {
+                                <span class="showcase-badge">@catProduct.Badge</span>
+                            }
+                            @if (!string.IsNullOrEmpty(catProduct.ImagePath))
+                            {
+                                <img src="@catProduct.ImagePath" alt="@catProduct.NameEn" style="max-height:180px;object-fit:contain;margin-bottom:1rem">
+                            }
+                            else
+                            {
+                                <span class="showcase-emoji">@(catProduct.Emoji ?? "📱")</span>
+                            }
+                            <div class="showcase-brand">@catProduct.BrandName</div>
+                            <div class="showcase-name">
+                                <span data-ar>@catProduct.NameAr</span>
+                                <span data-en>@catProduct.NameEn</span>
+                            </div>
+                            <span class="showcase-price">EGP @catProduct.Price.ToString("N0")</span>
+                        </div>
+                    }
+                </div>
+            </div>
+        }
+
+        <button class="slider-arrow arrow-prev" id="btnPrev">&#8250;</button>
+        <button class="slider-arrow arrow-next" id="btnNext">&#8249;</button>
+        <div class="slider-dots">
+            @for (int i = 0; i < Math.Min(Model.Categories.Count, 3); i++)
+            {
+                <button class="dot @(i == 0 ? "active" : "")" data-idx="@i"></button>
+            }
+        </div>
+    </div>
+</section>
+
+<!-- BRANDS STRIP -->
+<div class="brands-strip">
+    <span class="brands-strip-label">
+        <span data-ar>براندات موثوقة</span><span data-en>Trusted Brands</span>
+    </span>
+    <div class="brands-strip-divider"></div>
+    <div class="brands-strip-items">
+        <a href="/Products?brand=doogee" class="brand-strip-item">
+            <img src="/images/brands/doogee.png" alt="DOOGEE" class="brand-logo-strip">
+        </a>
+        <a href="/Products?brand=jisulife" class="brand-strip-item">
+            <img src="/images/brands/jisulife.png" alt="JisuLife" class="brand-logo-strip">
+        </a>
+        <a href="/Products?brand=dreame" class="brand-strip-item">
+            <img src="/images/brands/dreame.png" alt="Dreame" class="brand-logo-strip" >
+        </a>
+    </div>
+</div>
+
+<!-- PRODUCTS -->
+<section class="section products-section" id="products">
+    <div class="products-header">
+        <div>
+            <p class="section-tag"><span data-ar>منتجاتنا</span><span data-en>Our Products</span></p>
+            <div class="section-divider"></div>
+            <h2 class="section-title">
+                <span data-ar>اختر من أفضل التكنولوجيا</span>
+                <span data-en>Choose From The Best Tech</span>
+            </h2>
+        </div>
+        <a href="/Products" class="btn-outline">
+            <span data-ar>عرض الكل</span><span data-en>View All</span>
+        </a>
+    </div>
+
+    <div class="filter-tabs">
+        <button class="filter-tab active" data-filter="all">
+            <span data-ar>الكل</span><span data-en>All</span>
+        </button>
+        @foreach (var cat in Model.Categories)
+        {
+            <button class="filter-tab" data-filter="@cat.Slug">
+                @(cat.Emoji ?? "") <span data-ar>@cat.NameAr</span><span data-en>@cat.NameEn</span>
+            </button>
+        }
+    </div>
+
+    <div class="products-grid" id="productsGrid">
+        @foreach (var product in Model.FeaturedProducts)
+        {
+            <div data-category="@product.Category?.Slug">
+                <partial name="_ProductCard" model="product" />
+            </div>
+        }
+    </div>
+
+</section>
+
+<!-- ABOUT -->
+<section class="section about-section" id="about">
+    <div class="about-grid">
+        <div>
+            <p class="section-tag"><span data-ar>من نحن</span><span data-en>About Us</span></p>
+            <div class="section-divider"></div>
+            <h2 class="section-title">
+                <span data-ar>@Get("about.title.ar.ar")</span>
+                <span data-en>@Get("about.title.en.en")</span>
+            </h2>
+            <p class="section-desc">
+                <span data-ar>@Get("about.body.ar.ar")</span>
+                <span data-en>@Get("about.body.en.en")</span>
+            </p>
+            <div class="stats-row">
+                <div class="stat-card">
+                    <div class="stat-num">@Get("about.stat.years.ar")</div>
+                    <div class="stat-label"><span data-ar>سنوات خبرة</span><span data-en>Years Exp.</span></div>
+                </div>
+                <div class="stat-card">
+                    <div class="stat-num">@Get("about.stat.clients.ar")</div>
+                    <div class="stat-label"><span data-ar>عميل سعيد</span><span data-en>Happy Clients</span></div>
+                </div>
+                <div class="stat-card">
+                    <div class="stat-num">@Get("about.stat.products.ar")</div>
+                    <div class="stat-label"><span data-ar>منتج</span><span data-en>Products</span></div>
+                </div>
+            </div>
+        </div>
+        @{
+            var featTitle = Model.ContentBlocks.GetValueOrDefault("features.title.ar.ar", "لماذا نحن؟");
+            var featTitleEn = Model.ContentBlocks.GetValueOrDefault("features.title.en.en", "Why Us?");
+            var features = Enumerable.Range(1, 6)
+            .Select(i => new
+            {
+                icon = Model.ContentBlocks.GetValueOrDefault($"features.{i}.icon", "⭐"),
+                ar = Model.ContentBlocks.GetValueOrDefault($"features.{i}.ar", ""),
+                en = Model.ContentBlocks.GetValueOrDefault($"features.{i}.en", "")
+            })
+            .Where(f => !string.IsNullOrEmpty(f.ar))
+            .ToList();
+        }
+        <div class="about-visual">
+            <h3><span data-ar>@featTitle</span><span data-en>@featTitleEn</span></h3>
+            <ul class="feature-list">
+                @foreach (var feat in features)
+                {
+                    <li><div class="feat-icon">@feat.icon</div><span data-ar>@feat.ar</span><span data-en>@feat.en</span></li>
+                }
+            </ul>
+        </div>
+    </div>
+</section>
+
+<!-- MISSION VISION -->
+<section class="mv-section">
+    <div style="text-align:center;position:relative;z-index:1">
+        <p class="section-tag"><span data-ar>رؤيتنا ورسالتنا</span><span data-en>Mission & Vision</span></p>
+        <h2 class="section-title" style="color:white">
+            <span data-ar>نبني مستقبل التكنولوجيا في مصر</span>
+            <span data-en>Building The Tech Future In Egypt</span>
+        </h2>
+    </div>
+    <div class="mv-grid" style="position:relative;z-index:1">
+        <div class="mv-card">
+            <div class="mv-icon">🎯</div>
+            <h3><span data-ar>رسالتنا</span><span data-en>Our Mission</span></h3>
+            <p>
+                <span data-ar>@Get("mission.text.ar.ar")</span>
+                <span data-en>@Get("mission.text.en.en")</span>
+            </p>
+        </div>
+        <div class="mv-card">
+            <div class="mv-icon">🔭</div>
+            <h3><span data-ar>رؤيتنا</span><span data-en>Our Vision</span></h3>
+            <p>
+                <span data-ar>@Get("vision.text.ar.ar")</span>
+                <span data-en>@Get("vision.text.en.en")</span>
+            </p>
+        </div>
+    </div>
+</section>
+
+<!-- CONTACT -->
+<section class="contact-section" id="contact">
+    <p class="section-tag"><span data-ar>تواصل معنا</span><span data-en>Contact Us</span></p>
+    <div class="section-divider"></div>
+    <h2 class="section-title">
+        <span data-ar>نحن هنا لمساعدتك دائماً</span>
+        <span data-en>We're Always Here To Help</span>
+    </h2>
+    <div class="contact-grid">
+        <div>
+            <div class="contact-info-card">
+                @* Contact Info *@
+                @if (Model.ContactInfo?.ShowAddress == true && (!string.IsNullOrEmpty(Model.ContactInfo.AddressAr) || !string.IsNullOrEmpty(Model.ContactInfo.AddressEn)))
+                {
+                    <div class="contact-item">
+                        <div class="contact-icon-wrap">📍</div>
+                        <div>
+                            <strong><span data-ar>العنوان</span><span data-en>Address</span></strong>
+                            <span>
+                                <span data-ar>@Model.ContactInfo!.AddressAr</span>
+                                <span data-en>@Model.ContactInfo!.AddressEn</span>
+                            </span>
+                        </div>
+                    </div>
+                }
+                @if (Model.ContactInfo?.ShowPhone == true && !string.IsNullOrEmpty(Model.ContactInfo.Phone))
+                {
+                    <div class="contact-item">
+                        <div class="contact-icon-wrap">📞</div>
+                        <div>
+                            <strong><span data-ar>الهاتف</span><span data-en>Phone</span></strong>
+                            <span>@Model.ContactInfo!.Phone</span>
+                            @if (Model.ContactInfo.ShowPhone2 && !string.IsNullOrEmpty(Model.ContactInfo.Phone2))
+                            {
+                                <span style="display:block;font-size:12px;color:var(--text3)">@Model.ContactInfo.Phone2</span>
+                            }
+                        </div>
+                    </div>
+                }
+                @if (Model.ContactInfo?.ShowEmail == true && !string.IsNullOrEmpty(Model.ContactInfo.Email))
+                {
+                    <div class="contact-item">
+                        <div class="contact-icon-wrap">✉️</div>
+                        <div>
+                            <strong><span data-ar>البريد</span><span data-en>Email</span></strong>
+                            <span>@Model.ContactInfo!.Email</span>
+                        </div>
+                    </div>
+                }
+                @if (Model.ContactInfo?.ShowWorkingHours == true && (!string.IsNullOrEmpty(Model.ContactInfo.WorkingHoursAr) || !string.IsNullOrEmpty(Model.ContactInfo.WorkingHoursEn)))
+                {
+                    <div class="contact-item">
+                        <div class="contact-icon-wrap">🕐</div>
+                        <div>
+                            <strong><span data-ar>ساعات العمل</span><span data-en>Working Hours</span></strong>
+                            <span>
+                                <span data-ar>@Model.ContactInfo!.WorkingHoursAr</span>
+                                <span data-en>@Model.ContactInfo!.WorkingHoursEn</span>
+                            </span>
+                        </div>
+                    </div>
+                }
+                @if (Model.ContactInfo?.ShowMap == true && !string.IsNullOrEmpty(Model.ContactInfo.MapEmbedUrl))
+                {
+                    <div style="margin-top:1.2rem;border-radius:14px;overflow:hidden;border:1px solid var(--border)">
+                        <iframe src="@Model.ContactInfo!.MapEmbedUrl" width="100%" height="200"
+                                style="border:0;display:block" allowfullscreen="" loading="lazy"
+                                referrerpolicy="no-referrer-when-downgrade"></iframe>
+                    </div>
+                }
+                else if (Model.ContactInfo != null && (Model.ContactInfo.ShowMap == false || string.IsNullOrEmpty(Model.ContactInfo.MapEmbedUrl)))
+                {
+                    <div class="map-placeholder">
+                        📍 <span>
+                            <span data-ar>@(Model.ContactInfo.AddressAr ?? "القاهرة")</span>
+                            <span data-en>@(Model.ContactInfo.AddressEn ?? "Cairo")</span>
+                        </span>
+                    </div>
+                }
+                @if (Model.ContactInfo != null)
+                {
+                    var _ci = Model.ContactInfo;
+                    bool _fb = _ci.ShowFacebook && !string.IsNullOrEmpty(_ci.Facebook);
+                    bool _ig = _ci.ShowInstagram && !string.IsNullOrEmpty(_ci.Instagram);
+                    bool _wa = _ci.ShowWhatsApp && !string.IsNullOrEmpty(_ci.WhatsApp);
+                    bool _tk = _ci.ShowTikTok && !string.IsNullOrEmpty(_ci.TikTok);
+                    if (_fb || _ig || _wa || _tk)
+                    {
+                        <div style="display:flex;gap:8px;margin-top:1.2rem;flex-wrap:wrap">
+                            @if (_fb)
+                            {
+                                <a href="@_ci.Facebook" target="_blank" class="social-contact-btn">Facebook</a>
+                            }
+                            @if (_ig)
+                            {
+                                <a href="@_ci.Instagram" target="_blank" class="social-contact-btn">Instagram</a>
+                            }
+                            @if (_wa)
+                            {
+                                <a href="@("https://wa.me/" + _ci.WhatsApp!.Replace("+", "").Replace(" ", ""))" target="_blank" class="social-contact-btn" style="background:rgba(0,196,140,.1);color:#00C48C;border-color:rgba(0,196,140,.2)">WhatsApp</a>
+                            }
+                            @if (_tk)
+                            {
+                                <a href="@_ci.TikTok" target="_blank" class="social-contact-btn">TikTok</a>
+                            }
+                        </div>
+                    }
+                }
+            </div>
+        </div>
+        <div class="contact-form-card">
+            <h3 style="font-size:1.2rem;font-weight:800;margin-bottom:1.5rem">
+                <span data-ar>أرسل رسالتك</span><span data-en>Send Your Message</span>
+            </h3>
+            @if (TempData["ContactSuccess"] != null)
+            {
+                <div style="background:rgba(0,196,140,.1);border:1px solid rgba(0,196,140,.2);border-radius:10px;padding:1rem;margin-bottom:1rem;color:#00A374;font-size:14px;font-weight:600">
+                    ✓ <span data-ar>تم إرسال رسالتك بنجاح، سنتواصل معك قريباً</span>
+                    <span data-en>Your message was sent successfully, we'll contact you soon</span>
+                </div>
+            }
+            <form action="/Home/Contact" method="post">
+                @Html.AntiForgeryToken()
+                <div class="form-group">
+                    <label><span data-ar>الاسم الكامل</span><span data-en>Full Name</span></label>
+                    <input type="text" name="name" placeholder="اسمك هنا...">
+                </div>
+                <div class="form-group">
+                    <label><span data-ar>البريد الإلكتروني</span><span data-en>Email</span></label>
+                    <input type="email" name="email" placeholder="example@email.com">
+                </div>
+                <div class="form-group">
+                    <label><span data-ar>رقم الهاتف</span><span data-en>Phone</span></label>
+                    <input type="tel" name="phone" placeholder="+20 1XX XXX XXXX">
+                </div>
+                <div class="form-group">
+                    <label><span data-ar>الرسالة</span><span data-en>Message</span></label>
+                    <textarea name="message" placeholder="اكتب رسالتك هنا..."></textarea>
+                </div>
+                <button type="submit" class="submit-btn">
+                    <span data-ar>إرسال الرسالة ←</span>
+                    <span data-en>Send Message →</span>
+                </button>
+            </form>
+        </div>
+    </div>
+</section>
+
+@section Scripts {
+    <script>
+        // Slider
+        var cur=0, slides, dots, timer;
+        function initSlider(){
+          slides=document.querySelectorAll('.slide');
+          dots=document.querySelectorAll('.dot');
+          document.getElementById('btnPrev').onclick=function(){goTo(cur+1);resetTimer()};
+          document.getElementById('btnNext').onclick=function(){goTo(cur-1);resetTimer()};
+          document.querySelector('.slider-dots').onclick=function(e){
+            var b=e.target.closest('.dot');
+            if(b){goTo(parseInt(b.dataset.idx));resetTimer();}
+          };
+          resetTimer();
+        }
+        function goTo(n){
+          slides[cur].classList.remove('active');dots[cur].classList.remove('active');
+          cur=(n+slides.length)%slides.length;
+          slides[cur].classList.add('active');dots[cur].classList.add('active');
+        }
+        function resetTimer(){if(timer)clearInterval(timer);timer=setInterval(()=>goTo(cur+1),5500);}
+
+        // Category filter — filters featured products in-place
+        document.querySelectorAll('.filter-tab').forEach(function(btn) {
+          btn.addEventListener('click', function() {
+            var filter = this.dataset.filter;
+
+            // Mark active tab
+            document.querySelectorAll('.filter-tab').forEach(function(b) { b.classList.remove('active'); });
+            this.classList.add('active');
+
+            // Show/hide cards in-place
+            var wrappers = document.querySelectorAll('#productsGrid [data-category]');
+            wrappers.forEach(function(w) {
+              w.style.display = (filter === 'all' || w.dataset.category === filter) ? '' : 'none';
+            });
+          });
+        });
+
+        document.addEventListener('DOMContentLoaded', function(){
+          initSlider();
+          updateCartCount();
+        });
+    </script>
+}
