@model FTD.Web.ViewModels.ProductDetailViewModel
@{
    var p = Model.Product;
    ViewData["Title"] = p.NameAr;
    var badgeClass = p.Badge switch
    {
        "NEW" => "badge-blue",
        "HOT" => "badge-green",
        "4K" => "badge-orange",
        _ => "badge-dark"
    };
}
<div class="product-detail-page">
    <!-- BREADCRUMB -->
    <div class="breadcrumb">
        <a href="/"><span data-ar>الرئيسية</span><span data-en>Home</span></a>
        <span class="breadcrumb-sep">/</span>
        <a href="/Products?category=@p.Category?.Slug">
            <span data-ar>@p.Category?.NameAr</span><span data-en>@p.Category?.NameEn</span>
        </a>
        <span class="breadcrumb-sep">/</span>
        <span><span data-ar>@p.NameAr</span><span data-en>@p.NameEn</span></span>
    </div>
    <div class="detail-grid">
        <!-- IMAGE COLUMN -->
        @{
            var allImages = new List<string>();
            if (!string.IsNullOrEmpty(p.ImagePath)) allImages.Add(p.ImagePath);
            foreach (var img in p.Images.OrderBy(i => i.SortOrder))
                if (!allImages.Contains(img.ImagePath)) allImages.Add(img.ImagePath);
        }
        <div>
            <!-- MAIN IMAGE / SLIDER -->
            <div class="detail-img-wrap" style="position:relative;border-radius:20px;overflow:hidden">
                @if (!string.IsNullOrEmpty(p.Badge))
                {
                    <span class="detail-badge @badgeClass" style="z-index:5">@p.Badge</span>
                }
                @if (allImages.Count > 1)
                {
                    <div class="pslider" id="pslider_@p.Id">
                        @for (int si = 0; si < allImages.Count; si++)
                        {
                            <div class="pslide @(si == 0 ? "active" : "")" data-idx="@si">
                                <img src="@allImages[si]" alt="@p.NameEn @(si + 1)"
                                     style="width:100%;max-height:340px;object-fit:contain;padding:2rem;background:var(--bg)">
                            </div>
                        }
                        <button class="pslider-arrow pslider-prev" onclick="pslide(@p.Id,-1)">&#8249;</button>
                        <button class="pslider-arrow pslider-next" onclick="pslide(@p.Id, 1)">&#8250;</button>
                    </div>
                }
                else if (allImages.Count == 1)
                {
                    <img src="@allImages[0]" alt="@p.NameEn"
                         style="width:100%;max-height:340px;object-fit:contain;padding:2rem;background:var(--bg)">
                }
                else
                {
                    <span style="font-size:8rem;padding:2rem;display:flex;align-items:center;justify-content:center;min-height:280px">@(p.Emoji ?? "📦")</span>
                }
            </div>

            <!-- THUMBNAILS — تحت الصورة مباشرة -->
            @if (allImages.Count > 1)
            {
                <div class="pslider-thumbs" id="pthumbs_@p.Id" style="margin-top:10px">
                    @for (int si = 0; si < allImages.Count; si++)
                    {
                        <div class="pthumb @(si == 0 ? "active" : "")" data-idx="@si"
                             onclick="pslideGo(@p.Id, @si)">
                            <img src="@allImages[si]" alt="thumb @(si + 1)">
                        </div>
                    }
                </div>
            }
        </div>

        <!-- INFO -->
        <div>
            <div class="detail-brand">@p.BrandName</div>
            <h1 class="detail-title">
                <span data-ar>@p.NameAr</span>
                <span data-en>@p.NameEn</span>
            </h1>
            <div class="detail-price-wrap">
                @if (p.OldPrice.HasValue && p.OldPrice.Value > p.Price)
                {
                    var discount = (int)Math.Round((1 - p.Price / p.OldPrice.Value) * 100);
                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:.3rem">
                        <span class="detail-price">EGP @p.Price.ToString("N0")</span>
                        <span style="font-size:1rem;color:var(--text3);text-decoration:line-through;font-weight:500">EGP @p.OldPrice.Value.ToString("N0")</span>
                        <span style="background:#FF3B30;color:white;font-size:11px;font-weight:800;padding:3px 9px;border-radius:100px">-@discount%</span>
                    </div>
                }
                else
                {
                    <div class="detail-price">EGP @p.Price.ToString("N0")</div>
                }
            </div>
            <p class="detail-desc">
                <span data-ar>@p.DescAr</span>
                <span data-en>@p.DescEn</span>
            </p>
            <!-- SPECS -->
            @{
                var specs = Model.Attributes
                .Where(av => av.Attribute != null && av.AttributeValue != null)
                .ToList();
            }
            @if (specs.Any())
            {
                <div class="detail-specs">
                    <h4 style="font-size:14px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.8rem">
                        <span data-ar>المواصفات التقنية</span>
                        <span data-en>Specifications</span>
                    </h4>
                    @foreach (var av in specs)
                    {
                        <div class="spec-row">
                            <span class="spec-label">
                                <span data-ar>@av.Attribute!.NameAr</span>
                                <span data-en>@av.Attribute!.NameEn</span>
                            </span>
                            <span class="spec-val">
                                <span data-ar>@av.AttributeValue!.ValueAr</span>
                                <span data-en>@av.AttributeValue!.ValueEn</span>
                            </span>
                        </div>
                    }
                </div>
            }
            <!-- ACTIONS -->
            <div class="detail-actions">
                <form action="/Cart/Add" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@p.Id">
                    <input type="hidden" name="qty" value="1">
                    <button type="submit" class="add-cart-btn">
                        🛒 <span data-ar>أضف للسلة</span><span data-en>Add to Cart</span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- RELATED -->
    @if (Model.RelatedProducts.Any())
    {
        <div class="related-section section" style="padding-top:3rem">
            <h3 style="font-size:1.4rem;font-weight:800;margin-bottom:1.5rem">
                <span data-ar>منتجات مشابهة</span><span data-en>Related Products</span>
            </h3>
            <div class="products-grid">
                @foreach (var rel in Model.RelatedProducts)
                {
                    <partial name="_ProductCard" model="rel" />
                }
            </div>
        </div>
    }
</div>

@if (TempData["CartAdded"] != null)
{
    <div id="cartToast" class="cart-toast show">
        ✓ <span data-ar>تم إضافة المنتج للسلة</span><span data-en>Added to cart</span>
    </div>
}

@section Styles {
    <style>
        .pslider {
            position: relative;
            background: var(--bg);
            overflow: hidden;
        }

        .pslide {
            display: none;
        }

            .pslide.active {
                display: block;
            }

            .pslide img {
                display: block;
                transition: opacity .3s ease;
            }

        .pslider-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: white;
            border: 1px solid var(--border);
            border-radius: 50%;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 20px;
            color: var(--text);
            transition: all .2s;
            z-index: 4;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
        }

            .pslider-arrow:hover {
                background: var(--blue);
                color: white;
                border-color: var(--blue);
            }

        .pslider-prev {
            right: 12px;
        }

        .pslider-next {
            left: 12px;
        }

        .pslider-thumbs {
            display: flex;
            gap: 8px;
            padding: 8px 4px;
            overflow-x: auto;
            border-radius: 12px;
        }

        .pthumb {
            width: 64px;
            height: 64px;
            flex-shrink: 0;
            border-radius: 10px;
            overflow: hidden;
            border: 2px solid var(--border);
            cursor: pointer;
            transition: border-color .2s;
            background: var(--bg);
        }

            .pthumb img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

            .pthumb.active, .pthumb:hover {
                border-color: var(--blue);
            }

            .pthumb.active {
                box-shadow: 0 0 0 2px rgba(26,107,255,.2);
            }
    </style>
}

@section Scripts {
    <script>
        var psliders = {};
        function pslideGo(productId, idx) {
            var slider = document.getElementById('pslider_' + productId);
            var thumbs = document.getElementById('pthumbs_' + productId);
            if (!slider) return;
            slider.querySelectorAll('.pslide').forEach(function(s) { s.classList.remove('active'); });
            if (thumbs) thumbs.querySelectorAll('.pthumb').forEach(function(t) { t.classList.remove('active'); });
            var slides = slider.querySelectorAll('.pslide');
            var total  = slides.length;
            idx = ((idx % total) + total) % total;
            slides[idx].classList.add('active');
            if (thumbs) {
                var th = thumbs.querySelectorAll('.pthumb')[idx];
                if (th) { th.classList.add('active'); th.scrollIntoView({block:'nearest',inline:'center'}); }
            }
            psliders[productId] = idx;
        }
        function pslide(productId, dir) {
            var current = psliders[productId] || 0;
            pslideGo(productId, current + dir);
        }
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.pslider').forEach(function(el) {
                var startX = 0;
                var pid = el.id.replace('pslider_', '');
                el.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; }, {passive:true});
                el.addEventListener('touchend',   function(e) {
                    var diff = startX - e.changedTouches[0].clientX;
                    if (Math.abs(diff) > 40) pslide(pid, diff > 0 ? 1 : -1);
                }, {passive:true});
            });
        });
    </script>
}
