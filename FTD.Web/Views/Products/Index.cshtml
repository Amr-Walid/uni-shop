@model FTD.Web.ViewModels.ProductsViewModel
@{
    Layout = "_Layout";
    var brand = Model.CurrentBrand;
    var cat   = Model.CurrentCategory;
    var title = brand != null ? brand.NameAr
              : cat   != null ? cat.NameAr
              : "كل المنتجات";
    ViewData["Title"] = title;
}

@Html.AntiForgeryToken()

<main>
    <div class="container">
        <div class="breadcrumb">
            <a href="/"><span data-ar>الرئيسية</span><span data-en>Home</span></a>
            <span class="sep">/</span>
            <span class="current"><span data-ar>المنتجات</span><span data-en>Products</span></span>
        </div>
    </div>

    <!-- HERO -->
    <section class="products-hero">
        <div class="container">
            <div class="products-hero-inner">
                <div class="products-hero-top">
                    <div>
                        <span class="eyebrow"><span data-ar>كل المنتجات</span><span data-en>All Products</span></span>
                        <h1>
                            @if (brand != null)
                            {
                                <span>@brand.NameEn</span>
                            }
                            else if (cat != null)
                            {
                                <span>@cat.NameEn</span>
                            }
                            else
                            {
                                <span data-ar>الكتالوج الكامل<br>في نظرة واحدة.</span>
                                <span data-en>The complete catalog<br>at a glance.</span>
                            }
                        </h1>
                        <p class="sub">
                            @if (brand != null)
                            {
                                <span data-ar>@brand.DescAr</span>
                                <span data-en>@brand.DescEn</span>
                            }
                            else if (cat != null)
                            {
                                <span>@cat.Description</span>
                            }
                            else
                            {
                                <span data-ar>تصفح كل الأجهزة المتوفرة في المخزون — قم بالتصفية حسب الماركة أو الفئة للعثور على ما تحتاجه تماماً.</span>
                                <span data-en>Browse every hardware unit in stock — filter by brand, category, or price to find exactly what you need.</span>
                            }
                        </p>
                    </div>
                    @if (brand == null)
                    {
                        <div class="brand-pills" id="brand-pills">
                            <button class="brand-pill @(string.IsNullOrEmpty(Model.BrandFilter) ? "active" : "")" onclick="toggleBrandFilter('', this)">
                                <span data-ar>الكل</span><span data-en>All</span> <span class="count">@Model.TotalCount</span>
                            </button>
                            @foreach (var b in Model.Brands)
                            {
                                <button class="brand-pill @(Model.BrandFilter == b.Slug ? "active" : "")" onclick="toggleBrandFilter('@b.Slug', this)">
                                    @b.NameEn
                                </button>
                            }
                        </div>
                    }
                </div>
                <div class="products-hero-stats">
                    <div class="stat-tile">
                        <div class="l"><span data-ar>المتوفر</span><span data-en>In Stock</span></div>
                        <div class="v"><span id="statsCount">@Model.TotalCount</span> <span class="accent">SKUs</span></div>
                    </div>
                    <div class="stat-tile">
                        <div class="l"><span data-ar>الماركات</span><span data-en>Brands</span></div>
                        <div class="v">@Model.Brands.Count</div>
                    </div>
                    <div class="stat-tile">
                        <div class="l"><span data-ar>نطاق السعر</span><span data-en>Price Range</span></div>
                        <div class="v">EGP 899 – 12,500</div>
                    </div>
                    <div class="stat-tile">
                        <div class="l"><span data-ar>الضمان</span><span data-en>Warranty</span></div>
                        <div class="v"><span data-ar>معتمد</span><span data-en>Certified</span> <span class="accent">✓</span></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CATALOG -->
    <section style="padding: 40px 0 100px;">
        <div class="container">
            <div class="catalog">
                <!-- Sidebar -->
                <aside class="catalog-sidebar" id="filtersSidebar">
                    <div class="sidebar-card">
                        <h4>
                            <span data-ar>تصفية النتائج</span><span data-en>Filter Results</span>
                            <span class="clear" onclick="clearAllFilters()"><span data-ar>مسح الكل</span><span data-en>Clear all</span></span>
                        </h4>

                        @if (cat == null)
                        {
                            <div class="filter-group" id="flt-cat">
                                <div class="filter-group-title" onclick="this.parentElement.classList.toggle('collapsed')">
                                    <span data-ar>الفئة</span><span data-en>Category</span>
                                    <svg class="arrow" width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </div>
                                <div class="filter-options">
                                    @foreach (var c in Model.Categories)
                                    {
                                        var isChecked = Model.CategoryFilter == c.Slug;
                                        <label class="filter-opt @(isChecked ? "checked" : "")" onclick="toggleCatFilter('@c.Slug', this)">
                                            <span class="check"></span>
                                            <span><span data-ar>@c.NameAr</span><span data-en>@c.NameEn</span></span>
                                        </label>
                                    }
                                </div>
                            </div>
                        }

                        @if (brand == null)
                        {
                            <div class="filter-group" id="flt-brand">
                                <div class="filter-group-title" onclick="this.parentElement.classList.toggle('collapsed')">
                                    <span data-ar>الماركة</span><span data-en>Brand</span>
                                    <svg class="arrow" width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </div>
                                <div class="filter-options">
                                    @foreach (var b in Model.Brands)
                                    {
                                        var isChecked = Model.BrandFilter == b.Slug;
                                        <label class="filter-opt @(isChecked ? "checked" : "")" onclick="toggleBrandFilter('@b.Slug', this)">
                                            <span class="check"></span>
                                            <span>@b.NameEn</span>
                                        </label>
                                    }
                                </div>
                            </div>
                        }

                        <div id="attrFilters">
                            @foreach (var grp in Model.AttributeGroups)
                            {
                                <div class="filter-group" id="flt-attr-@grp.AttributeId">
                                    <div class="filter-group-title" onclick="this.parentElement.classList.toggle('collapsed')">
                                        <span><span data-ar>@grp.NameAr</span><span data-en>@grp.NameEn</span></span>
                                        <svg class="arrow" width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    </div>
                                    <div class="filter-options">
                                        @foreach (var opt in grp.Options)
                                        {
                                            var isActive = Model.SelectedAttrValues.Contains(opt.ValueId);
                                            <label class="filter-opt @(isActive ? "checked" : "")" onclick="toggleAttrFilter(@opt.ValueId, this)">
                                                <span class="check"></span>
                                                <span><span data-ar>@opt.ValueAr</span><span data-en>@opt.ValueEn</span></span>
                                                <span class="n">@opt.Count</span>
                                            </label>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="sidebar-card" style="background: var(--navy); color: white; border: none;">
                        <h4 style="color: var(--accent);"><span data-ar>تحتاج مساعدة؟</span><span data-en>Need Help?</span></h4>
                        <p style="font-size: 13px; line-height: 20px; color: rgba(255,255,255,0.7); margin-bottom: 16px;">
                            <span data-ar>يمكن لخبرائنا مساعدتك في اختيار الجهاز المناسب لاحتياجاتك.</span>
                            <span data-en>Our specialists can help you choose the right device for your needs.</span>
                        </p>
                        <a href="/#contact" class="btn btn-sm" style="background: var(--accent); color: var(--navy); width: 100%; justify-content: center;">
                            <span data-ar>تحدث معنا ←</span><span data-en>Talk to us →</span>
                        </a>
                    </div>
                </aside>

                <!-- Main Grid area -->
                <div style="flex: 1; min-width: 0;">
                    <div class="catalog-toolbar">
                        <div class="catalog-count">
                            <span class="live"></span>
                            <span data-ar>عرض </span><span data-en>Showing </span>
                            <strong id="resultCount">@Model.TotalCount</strong>
                            <span data-ar> من أصل </span><span data-en> of </span>
                            <strong id="statsTotal">@Model.TotalCount</strong>
                            <span data-ar> منتجات</span><span data-en> products</span>
                        </div>
                        @{
                            var sortVal = Model.SortBy ?? "featured";
                        }
                        <select id="sortSelect" onchange="applySort(this.value)" class="sort-select">
                            <option value="featured" selected="@(sortVal == "featured" ? "selected" : null)">★ الأبرز / Featured</option>
                            <option value="newest"     selected="@(sortVal == "newest"     ? "selected" : null)">الأحدث أولاً / Newest</option>
                            <option value="price_asc"  selected="@(sortVal == "price_asc"  ? "selected" : null)">السعر: الأقل أولاً / Price: Low to High</option>
                            <option value="price_desc" selected="@(sortVal == "price_desc" ? "selected" : null)">السعر: الأعلى أولاً / Price: High to Low</option>
                        </select>
                    </div>

                    <div class="products-grid" id="productsGrid">
                        @if (!Model.Products.Any())
                        {
                            <div style="text-align:center;padding:4rem 2rem;color:var(--on-surface-muted);grid-column:1/-1">
                                <div style="font-size:3rem;margin-bottom:1rem">🔍</div>
                                <p style="font-size:15px;font-weight:600"><span data-ar>لا توجد منتجات</span><span data-en>No products found</span></p>
                            </div>
                        }
                        @foreach (var p in Model.Products)
                        {
                            <partial name="_ProductCard" model="p" />
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
<script>
    var _brand    = '@(Model.BrandFilter ?? "")';
    var _category = '@(Model.CategoryFilter ?? "")';
    var _sort     = '@(Model.SortBy ?? "featured")';
    var _attrVals = [@string.Join(",", Model.SelectedAttrValues)];

    function toggleFltGroup(id) {
        var el = document.getElementById(id);
        if (el) el.classList.toggle('collapsed');
    }

    function toggleBrandFilter(slug, el) {
        // Toggle active design for brand pills if clicked, or sidebar filters
        _brand = (_brand === slug && slug !== '') ? '' : slug;
        
        // Remove active class from other elements
        if (el && el.classList.contains('brand-pill')) {
            document.querySelectorAll('.brand-pill').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
        }
        
        _doFetch();
    }

    function toggleCatFilter(slug, el) {
        _category = (_category === slug) ? '' : slug;
        if (el) {
            el.classList.toggle('checked');
        }
        _doFetch();
    }

    function toggleAttrFilter(valId, el) {
        var idx = _attrVals.indexOf(valId);
        if (idx === -1) {
            _attrVals.push(valId);
            if (el) el.classList.add('checked');
        } else {
            _attrVals.splice(idx, 1);
            if (el) el.classList.remove('checked');
        }
        _doFetch();
    }

    function applySort(val) {
        _sort = val;
        _doFetch();
    }

    function clearAllFilters() {
        _brand = '';
        _category = '';
        _attrVals = [];
        
        document.querySelectorAll('.filter-opt').forEach(el => el.classList.remove('checked'));
        document.querySelectorAll('.brand-pill').forEach(b => b.classList.remove('active'));
        var firstPill = document.querySelector('.brand-pill');
        if (firstPill) firstPill.classList.add('active');
        
        _doFetch();
    }

    async function _doFetch() {
        var grid = document.getElementById('productsGrid');
        grid.style.opacity = '0.5';
        grid.style.pointerEvents = 'none';

        var params = new URLSearchParams();
        if (_brand)    params.append('brand',    _brand);
        if (_category) params.append('category', _category);
        if (_sort)     params.append('sort',     _sort);
        _attrVals.forEach(function(v) { params.append('av', v); });

        try {
            var res  = await fetch('/Products/Filter?' + params.toString());
            var data = await res.json();

            // Update stats & count
            document.getElementById('resultCount').textContent = data.count;
            document.getElementById('statsCount').textContent = data.count;

            // Re-render products
            if (data.count === 0) {
                grid.innerHTML = '<div style="text-align:center;padding:4rem 2rem;color:var(--on-surface-muted);grid-column:1/-1"><div style="font-size:3rem;margin-bottom:1rem">🔍</div><p style="font-size:15px;font-weight:600"><span data-ar>لا توجد منتجات مطابقة</span><span data-en>No products match your filters</span></p></div>';
                if (typeof applyLangVisibility === 'function') applyLangVisibility();
            } else {
                grid.innerHTML = data.products.map(function(p) {
                    var disc = p.oldPrice && p.oldPrice > p.price
                        ? Math.round((1 - p.price / p.oldPrice) * 100) : 0;
                    
                    var badgeKind = (p.badge || '').toLowerCase();
                    if (['new', 'hot', '4k', 'rugged'].indexOf(badgeKind) === -1) badgeKind = 'new';
                    var badgeHtml = p.badge ? '<div class="badge-wrap"><span class="badge badge-' + badgeKind + '">' + p.badge + '</span></div>' : '';
                    var mediaContent = p.imagePath
                        ? '<img src="' + p.imagePath + '" alt="' + p.nameEn + '" style="max-height:120px;object-fit:contain;z-index:1;">'
                        : '<span style="font-size:54px;z-index:1;">' + (p.emoji || '📦') + '</span>';
                    
                    var discHtml = disc > 0 
                        ? '<div style="display:flex;align-items:center;gap:5px;margin-top:2px">'
                          + '<span style="font-size:11px;color:var(--on-surface-muted);text-decoration:line-through">EGP ' + Number(p.oldPrice).toLocaleString() + '</span>'
                          + '<span style="background:var(--error);color:white;font-size:9px;font-weight:800;padding:1px 5px;border-radius:100px">-' + disc + '%</span>'
                          + '</div>'
                        : '';

                    return '<article class="product-card" onclick="location.href=\'/products/' + p.slug + '\'">'
                        + '<div class="media">'
                        + badgeHtml
                        + '<a href="/products/' + p.slug + '" class="quick-view" aria-label="Quick view" onclick="event.stopPropagation()">'
                        + '<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'
                        + '</a>'
                        + mediaContent
                        + '</div>'
                        + '<div class="info">'
                        + '<div class="brand-line">'
                        + '<span class="brand">' + (p.brandName || '').toUpperCase() + '</span>'
                        + '<span class="sku">SKU · ' + String(p.id).padStart(2, '0') + '</span>'
                        + '</div>'
                        + '<h3><a href="/products/' + p.slug + '" onclick="event.stopPropagation()">'
                        + '<span data-ar>' + p.nameAr + '</span>'
                        + '<span data-en>' + p.nameEn + '</span>'
                        + '</a></h3>'
                        + '<p class="desc">'
                        + '<span data-ar>' + (p.shortDescAr || '') + '</span>'
                        + '<span data-en>' + (p.shortDescEn || '') + '</span>'
                        + '</p>'
                        + '<div class="price-row">'
                        + '<div style="display:flex; flex-direction:column;">'
                        + '<span class="price">EGP ' + Number(p.price).toLocaleString() + '</span>'
                        + discHtml
                        + '</div>'
                        + '<div class="actions">'
                        + '<a href="/products/' + p.slug + '" class="btn btn-dark btn-sm" onclick="event.stopPropagation()">'
                        + '<span data-ar>التفاصيل</span><span data-en>Details</span>'
                        + '</a>'
                        + '<button class="icon-only" onclick="event.stopPropagation(); addToCartQuick(' + p.id + ', this)" aria-label="Add to cart">'
                        + '<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 5h9l-1 6H5L4 5zM4 5L3.5 3H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="6" cy="13" r="1" fill="currentColor"/><circle cx="11" cy="13" r="1" fill="currentColor"/></svg>'
                        + '</button>'
                        + '</div>'
                        + '</div>'
                        + '</div>'
                        + '</article>';
                }).join('');
            }

            // Update attributes
            updateAttrFilters(data.attrGroups);

            // Re-apply bilingual visibility to the freshly-injected cards
            // (guards against any FOUC even though CSS now defaults data-en
            // to hidden — keeps behavior correct if JS toggled language).
            if (typeof applyLangVisibility === 'function') applyLangVisibility();

            // Update URL without reload
            var url = new URL(window.location);
            _brand    ? url.searchParams.set('brand',    _brand)    : url.searchParams.delete('brand');
            _category ? url.searchParams.set('category', _category) : url.searchParams.delete('category');
            _sort !== 'featured' ? url.searchParams.set('sort', _sort) : url.searchParams.delete('sort');
            url.searchParams.delete('av');
            _attrVals.forEach(function(v) { url.searchParams.append('av', v); });
            history.replaceState({}, '', url);

        } catch(e) {
            console.error('Filter error:', e);
        }
        grid.style.opacity = '1';
        grid.style.pointerEvents = 'auto';
    }

    function updateAttrFilters(groups) {
        var container = document.getElementById('attrFilters');
        if (!groups || !groups.length) { container.innerHTML = ''; return; }

        container.innerHTML = groups.map(function(g) {
            return '<div class="filter-group" id="flt-attr-' + g.attributeId + '">'
                + '<div class="filter-group-title" onclick="toggleFltGroup(\'flt-attr-' + g.attributeId + '\')">'
                + '<span><span data-ar>' + g.nameAr + '</span><span data-en>' + g.nameEn + '</span></span>'
                + '<svg class="arrow" width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>'
                + '</div>'
                + '<div class="filter-options">'
                + g.options.map(function(o) {
                    var checked = _attrVals.indexOf(o.valueId) !== -1;
                    return '<label class="filter-opt ' + (checked ? 'checked' : '') + '" onclick="toggleAttrFilter(' + o.valueId + ', this)">'
                        + '<span class="check"></span>'
                        + '<span><span data-ar>' + o.valueAr + '</span><span data-en>' + o.valueEn + '</span></span>'
                        + '<span class="n">' + o.count + '</span>'
                        + '</label>';
                }).join('')
                + '</div></div>';
        }).join('');
        if (typeof applyLangVisibility === 'function') applyLangVisibility();
    }
</script>
}
