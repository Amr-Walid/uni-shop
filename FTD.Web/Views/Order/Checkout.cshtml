@model FTD.Web.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "إتمام الطلب";
}

<main>
    <div class="container">
        <div class="breadcrumb">
            <a href="/"><span data-ar>الرئيسية</span><span data-en>Home</span></a>
            <span class="sep">/</span>
            <a href="/Cart"><span data-ar>السلة</span><span data-en>Cart</span></a>
            <span class="sep">/</span>
            <span class="current"><span data-ar>إتمام الطلب</span><span data-en>Checkout</span></span>
        </div>
    </div>

    <section class="checkout-page" style="padding-bottom: 100px;">
        <div class="container">
            <div class="checkout-header">
                <span class="eyebrow"><span data-ar>إرسال الطلب</span><span data-en>Order · Placing</span></span>
                <h1><span data-ar>إتمام الطلب</span><span data-en>Checkout</span></h1>
            </div>

            <!-- Steps Bar -->
            <div class="steps-bar">
                <div class="step done">
                    <span class="n">✓</span>
                    <span class="l"><span data-ar>السلة</span><span data-en>Cart</span></span>
                </div>
                <div class="step-connector done"></div>
                <div class="step active">
                    <span class="n">2</span>
                    <span class="l"><span data-ar>بيانات التوصيل</span><span data-en>Details</span></span>
                </div>
                <div class="step-connector"></div>
                <div class="step">
                    <span class="n">3</span>
                    <span class="l"><span data-ar>الدفع</span><span data-en>Payment</span></span>
                </div>
                <div class="step-connector"></div>
                <div class="step">
                    <span class="n">4</span>
                    <span class="l"><span data-ar>التأكيد</span><span data-en>Confirmation</span></span>
                </div>
            </div>

            <div class="checkout-layout">
                <form action="/Order/Checkout" method="post" id="checkoutForm">
                    @Html.AntiForgeryToken()

                    <!-- 1. DELIVERY INFO -->
                    <div class="form-card">
                        <h3><span class="step-num">1</span><span data-ar>بيانات التوصيل</span><span data-en>Delivery Information</span></h3>
                        <p class="sub"><span data-ar>أين تريد منا شحن طلبك؟</span><span data-en>Where should we send your order?</span></p>

                        <div class="form-group">
                            <label class="form-label"><span data-ar>الاسم الكامل *</span><span data-en>Full Name *</span></label>
                            <input class="form-input" type="text" asp-for="CustomerName" placeholder="اسمك الكامل هنا..." required style="direction:rtl;">
                            <span asp-validation-for="CustomerName" style="color:var(--error); font-size:12px; margin-top:4px; display:block;"></span>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label"><span data-ar>رقم الهاتف *</span><span data-en>Phone *</span></label>
                                <input class="form-input" type="tel" asp-for="CustomerPhone" placeholder="+20 1XX XXX XXXX" required style="direction:ltr;">
                                <span asp-validation-for="CustomerPhone" style="color:var(--error); font-size:12px; margin-top:4px; display:block;"></span>
                            </div>
                            <div class="form-group">
                                <label class="form-label"><span data-ar>البريد الإلكتروني</span><span data-en>Email</span></label>
                                <input class="form-input" type="email" asp-for="CustomerEmail" placeholder="example@email.com" style="direction:ltr;">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label"><span data-ar>المحافظة</span><span data-en>Governorate</span></label>
                                <div class="form-select-wrap">
                                    <select class="form-input form-select" asp-for="Governorate" style="direction:rtl;">
                                        <option value=""><span data-ar>اختر المحافظة...</span><span data-en>Select Governorate...</span></option>
                                        <option>القاهرة</option>
                                        <option>الجيزة</option>
                                        <option>الإسكندرية</option>
                                        <option>الدقهلية</option>
                                        <option>البحيرة</option>
                                        <option>الفيوم</option>
                                        <option>الغربية</option>
                                        <option>الإسماعيلية</option>
                                        <option>المنوفية</option>
                                        <option>المنيا</option>
                                        <option>القليوبية</option>
                                        <option>الوادي الجديد</option>
                                        <option>السويس</option>
                                        <option>أسوان</option>
                                        <option>أسيوط</option>
                                        <option>بني سويف</option>
                                        <option>بورسعيد</option>
                                        <option>دمياط</option>
                                        <option>جنوب سيناء</option>
                                        <option>شمال سيناء</option>
                                        <option>سوهاج</option>
                                        <option>قنا</option>
                                        <option>كفر الشيخ</option>
                                        <option>مطروح</option>
                                        <option>الأقصر</option>
                                        <option>البحر الأحمر</option>
                                        <option>الشرقية</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label"><span data-ar>المدينة / المنطقة</span><span data-en>City / District</span></label>
                                <input class="form-input" type="text" asp-for="City" placeholder="مصر الجديدة، مدينة نصر..." style="direction:rtl;">
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label"><span data-ar>العنوان التفصيلي</span><span data-en>Detailed Address</span></label>
                            <input class="form-input" type="text" asp-for="Address" placeholder="اسم الشارع، رقم المبنى، الدور، الشقة..." style="direction:rtl;">
                        </div>
                        <div class="form-group" style="margin-bottom:0">
                            <label class="form-label"><span data-ar>تعليمات التوصيل</span><span data-en>Delivery Notes</span></label>
                            <textarea class="form-textarea" asp-for="Notes" placeholder="أي ملاحظات خاصة للتسليم..." style="min-height:80px; direction:rtl;"></textarea>
                        </div>
                    </div>

                    <!-- 2. DELIVERY METHOD -->
                    <div class="form-card">
                        <h3><span class="step-num">2</span><span data-ar>طريقة الشحن</span><span data-en>Delivery Method</span></h3>
                        <p class="sub"><span data-ar>اختر مدى سرعة استلام طلبك.</span><span data-en>Choose how fast you want your order.</span></p>

                        <div class="delivery-options">
                            <label class="delivery-opt active" onclick="pickDelivery(this)">
                                <span class="radio"></span>
                                <span class="ico">
                                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M2 12h11l3-3h-2l-2-2H2v5zM4 14a2 2 0 100-4 2 2 0 000 4zM13 14a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                                </span>
                                <span class="txt">
                                    <div class="l"><span data-ar>توصيل قياسي</span><span data-en>Standard Delivery</span></div>
                                    <div class="s"><span data-ar>خلال ٢-٣ أيام عمل · لكافة المحافظات</span><span data-en>2-3 business days · All governorates</span></div>
                                </span>
                                <span class="price free"><span data-ar>مجاني</span><span data-en>FREE</span></span>
                            </label>
                            <label class="delivery-opt" onclick="pickDelivery(this)">
                                <span class="radio"></span>
                                <span class="ico">
                                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10L10 4l6 6M6 10v6h8v-6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                                </span>
                                <span class="txt">
                                    <div class="l"><span data-ar>شحن سريع (خلال نفس اليوم)</span><span data-en>Express (Same-day)</span></div>
                                    <div class="s"><span data-ar>داخل القاهرة الكبرى · اطلب قبل ٢ ظهراً</span><span data-en>Within Cairo · Order before 2PM</span></div>
                                </span>
                                <span class="price">EGP 120</span>
                            </label>
                            <label class="delivery-opt" onclick="pickDelivery(this)">
                                <span class="radio"></span>
                                <span class="ico">
                                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 2v6l4 2M10 2C5.6 2 2 5.6 2 10s3.6 8 8 8 8-3.6 8-8-3.6-8-8-8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </span>
                                <span class="txt">
                                    <div class="l"><span data-ar>استلام من الفرع</span><span data-en>Pickup from Store</span></div>
                                    <div class="s"><span data-ar>جاهز للاستلام خلال ساعتين · فرع مصر الجديدة</span><span data-en>Ready in 2h · Heliopolis branch</span></div>
                                </span>
                                <span class="price free"><span data-ar>مجاني</span><span data-en>FREE</span></span>
                            </label>
                        </div>
                    </div>

                    <!-- 3. PAYMENT METHOD -->
                    <div class="form-card">
                        <h3><span class="step-num">3</span><span data-ar>طريقة الدفع</span><span data-en>Payment Method</span></h3>
                        <p class="sub"><span data-ar>جميع المدفوعات آمنة ومشفرة بالكامل.</span><span data-en>All payments are secure and encrypted.</span></p>

                        <div class="payment-grid">
                            <label class="payment-opt active" onclick="pickPayment(this)">
                                <span class="radio"></span>
                                <div>
                                    <div class="l"><span data-ar>الدفع عند الاستلام</span><span data-en>Cash on Delivery</span></div>
                                    <div class="s"><span data-ar>ادفع نقداً عند استلام طلبك</span><span data-en>Pay when you receive</span></div>
                                </div>
                            </label>
                            <label class="payment-opt" onclick="pickPayment(this)">
                                <span class="radio"></span>
                                <div>
                                    <div class="l"><span data-ar>بطاقة ائتمان / خصم مباشر</span><span data-en>Credit / Debit Card</span></div>
                                    <div class="s"><span data-ar>فيزا، ماستركارد</span><span data-en>Visa, Mastercard</span></div>
                                </div>
                            </label>
                            <label class="payment-opt" onclick="pickPayment(this)">
                                <span class="radio"></span>
                                <div>
                                    <div class="l"><span data-ar>تقسيط بنكي بفائدة ٠٪</span><span data-en>Bank Installments</span></div>
                                    <div class="s"><span data-ar>تقسيط من ٦ إلى ١٢ شهر بدون فوائد</span><span data-en>0% interest · 6-12mo</span></div>
                                </div>
                            </label>
                            <label class="payment-opt" onclick="pickPayment(this)">
                                <span class="radio"></span>
                                <div>
                                    <div class="l"><span data-ar>المحافظ الإلكترونية / إنستاباي</span><span data-en>Mobile Wallet / InstaPay</span></div>
                                    <div class="s"><span data-ar>فودافون كاش، إنستاباي</span><span data-en>Vodafone Cash, InstaPay</span></div>
                                </div>
                            </label>
                        </div>
                    </div>
                </form>

                <!-- SUMMARY SIDEBAR -->
                <div class="summary">
                    <div class="summary-card">
                        <h3>
                            <span data-ar>ملخص الطلب</span><span data-en>Order Summary</span>
                            <a href="/Cart" class="edit"><span data-ar>تعديل</span><span data-en>Edit</span> →</a>
                        </h3>
                        
                        <div class="summary-items" id="sum-items" style="max-height: 240px; overflow-y: auto; margin-bottom: 20px;">
                            @foreach (var item in Model.Cart.Items)
                            {
                                <div class="sum-item" style="display:flex; justify-content:space-between; align-items:center; font-size:13px; padding: 10px 0; border-bottom: 1px solid var(--border);">
                                    <div style="display:flex; align-items:center; gap:8px;">
                                        @if (!string.IsNullOrEmpty(item.ImagePath))
                                        {
                                            <img src="@item.ImagePath" alt="@item.ProductName" style="width:36px; height:36px; object-fit:contain; background:var(--surface-container-low); border-radius:6px;">
                                        }
                                        <div>
                                            <strong style="display:block; max-width:180px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis">@item.ProductName</strong>
                                            <span style="font-size:11px; color:var(--on-surface-muted)">Qty: @item.Quantity</span>
                                        </div>
                                    </div>
                                    <strong style="font-variant-numeric: tabular-nums">EGP @item.SubTotal.ToString("N0")</strong>
                                </div>
                            }
                        </div>

                        <div class="summary-rows">
                            <div class="summary-row">
                                <span><span data-ar>المجموع الفرعي</span><span data-en>Subtotal</span></span>
                                <span class="v">EGP @Model.Cart.SubTotal.ToString("N0")</span>
                            </div>
                            <div class="summary-row">
                                <span><span data-ar>الشحن</span><span data-en>Shipping</span></span>
                                <span class="v @(Model.Cart.FreeShipping ? "free" : "")">
                                    @if (Model.Cart.FreeShipping)
                                    {
                                        <span data-ar>مجاني</span><span data-en>FREE</span>
                                    }
                                    else
                                    {
                                        <span>EGP @Model.Cart.ShippingFee.ToString("N0")</span>
                                    }
                                </span>
                            </div>
                            <div class="summary-row">
                                <span><span data-ar>الضريبة والرسوم</span><span data-en>Tax (VAT)</span></span>
                                <span class="v"><span data-ar>مشمولة</span><span data-en>Included</span></span>
                            </div>
                        </div>

                        <div class="summary-total">
                            <span class="l"><span data-ar>الإجمالي</span><span data-en>Total</span></span>
                            <span class="v">EGP @Model.Cart.Total.ToString("N0")</span>
                        </div>

                        <button class="place-order" onclick="document.getElementById('checkoutForm').submit();" style="width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px;">
                            <span data-ar>تأكيد وطلب الشراء</span><span data-en>Place Order</span>
                            <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4 10l4 4 8-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>

                        <div class="trust-mini">
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M8 2L3 4v4c0 3 5 6 5 6s5-3 5-6V4L8 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
                            <span data-ar>تأمين دفع SSL مشفر بالكامل لحماية بياناتك</span>
                            <span data-en>Secure SSL checkout · Your data is encrypted</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>

@section Scripts {
<script>
    function pickDelivery(el) {
        document.querySelectorAll('.delivery-opt').forEach(opt => opt.classList.remove('active'));
        el.classList.add('active');
    }

    function pickPayment(el) {
        document.querySelectorAll('.payment-opt').forEach(opt => opt.classList.remove('active'));
        el.classList.add('active');
    }
</script>
}
