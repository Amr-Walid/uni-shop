@{
    ViewData["Title"] = "تم استلام طلبك";
}

<div style="min-height:60vh;display:flex;align-items:center;justify-content:center;padding:5rem 5%">
  <div style="text-align:center;max-width:500px">
    <div style="font-size:4rem;margin-bottom:1.5rem">🎉</div>
    <h1 style="font-size:2rem;font-weight:900;margin-bottom:1rem;color:var(--green)">
      <span data-ar>تم استلام طلبك!</span><span data-en>Order Placed!</span>
    </h1>
    <div style="background:var(--bg);border-radius:var(--r);padding:1.2rem;margin-bottom:1.5rem;border:1px solid var(--border)">
      <p style="font-size:13px;color:var(--text3);margin-bottom:.3rem">
        <span data-ar>رقم الطلب</span><span data-en>Order Number</span>
      </p>
      <p style="font-size:1.3rem;font-weight:800;color:var(--blue)">@ViewBag.OrderNumber</p>
    </div>
    <p style="color:var(--text2);line-height:1.9;margin-bottom:2rem">
      <span data-ar>شكراً لثقتك بـ FTD TechZone. سيتواصل معك فريقنا قريباً لتأكيد طلبك وترتيب التوصيل.</span>
      <span data-en>Thank you for trusting FTD TechZone. Our team will contact you soon to confirm your order and arrange delivery.</span>
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
      <a href="/Products" class="btn-primary">
        <span data-ar>متابعة التسوق</span><span data-en>Continue Shopping</span>
      </a>
      <a href="/" class="btn-outline">
        <span data-ar>الرئيسية</span><span data-en>Home</span>
      </a>
    </div>
  </div>
</div>
