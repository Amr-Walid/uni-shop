@model FTD.Web.ViewModels.FooterViewModel
<footer class="footer">
    <div class="footer-inner container">
        <!-- Newsletter band -->
        <div class="newsletter-band">
            <div>
                <h4><span data-ar>خلّيك أول من يعرف 🔥</span><span data-en>Be the first to know 🔥</span></h4>
                <p class="nl-sub">
                    <span data-ar>اشترك ليصلك كل جديد عن المنتجات والعروض الحصرية قبل أي حد.</span>
                    <span data-en>Subscribe for new arrivals and exclusive deals before anyone else.</span>
                </p>
            </div>
            <form class="newsletter-form" onsubmit="return subscribeNewsletter(event)">
                <input type="email" required data-ph-ar="بريدك الإلكتروني..." data-ph-en="Your email address..." placeholder="بريدك الإلكتروني..." aria-label="Email">
                <button type="submit">
                    <span data-ar>اشترك</span><span data-en>Subscribe</span>
                </button>
            </form>
        </div>
        <div class="footer-grid">
            <!-- Brand & Intro -->
            <div class="footer-brand">
                <a href="/" class="logo" style="color: #ffffff; display: flex; align-items: center; gap: 8px;">
                    <img src="/images/logo-unishop-icon-light.png" alt="Uni Shop Logo" style="height: 36px; width: auto; display: block;" />
                    <span>Uni<strong>-Shop</strong></span>
                </a>
                <p class="footer-desc">
                    <span data-ar>بوابتك المعتمدة لأحدث الأجهزة التكنولوجية من DOOGEE و JisuLife و Dreame. نوفر جودة فائقة وضمان حقيقي.</span>
                    <span data-en>Your certified gateway for the latest tech hardware from DOOGEE, JisuLife, and Dreame. Delivering premium quality and certified warranty.</span>
                </p>
                @if (Model.ContactInfo != null)
                {
                    <div class="social-links">
                        @if (Model.ContactInfo.ShowFacebook && !string.IsNullOrEmpty(Model.ContactInfo.Facebook))
                        {
                            <a href="@Model.ContactInfo.Facebook" target="_blank" class="social-btn" aria-label="Facebook">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                            </a>
                        }
                        @if (Model.ContactInfo.ShowInstagram && !string.IsNullOrEmpty(Model.ContactInfo.Instagram))
                        {
                            <a href="@Model.ContactInfo.Instagram" target="_blank" class="social-btn" aria-label="Instagram">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                            </a>
                        }
                        @if (Model.ContactInfo.ShowWhatsApp && !string.IsNullOrEmpty(Model.ContactInfo.WhatsApp))
                        {
                            <a href="https://wa.me/@Model.ContactInfo.WhatsApp" target="_blank" class="social-btn" aria-label="WhatsApp">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                            </a>
                        }
                    </div>
                }
            </div>

            <!-- Links Column -->
            <div class="footer-links-col">
                <h4 class="footer-title">
                    <span data-ar>روابط سريعة</span><span data-en>Quick Links</span>
                </h4>
                <ul class="footer-links">
                    <li><a href="/"><span data-ar>الرئيسية</span><span data-en>Home</span></a></li>
                    <li><a href="/Products"><span data-ar>المنتجات</span><span data-en>Products</span></a></li>
                    <li><a href="/#about"><span data-ar>عننا</span><span data-en>About Us</span></a></li>
                    <li><a href="/#contact"><span data-ar>اتصل بنا</span><span data-en>Contact Us</span></a></li>
                </ul>
            </div>

            <!-- Brands Column -->
            <div class="footer-links-col">
                <h4 class="footer-title">
                    <span data-ar>العلامات التجارية</span><span data-en>Our Brands</span>
                </h4>
                <ul class="footer-links">
                    @foreach (var brand in Model.NavBrands)
                    {
                        <li><a href="/Products?brand=@brand.Slug">@brand.NameEn</a></li>
                    }
                </ul>
            </div>

            <!-- Contact Info Column -->
            <div class="footer-links-col">
                <h4 class="footer-title">
                    <span data-ar>تواصل معنا</span><span data-en>Contact</span>
                </h4>
                <ul class="footer-contact-list">
                    @if (Model.ContactInfo != null)
                    {
                        @if (Model.ContactInfo.ShowPhone && !string.IsNullOrEmpty(Model.ContactInfo.Phone))
                        {
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                                <span>@Model.ContactInfo.Phone</span>
                            </li>
                        }
                        @if (Model.ContactInfo.ShowEmail && !string.IsNullOrEmpty(Model.ContactInfo.Email))
                        {
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                                <span class="email-text">@Model.ContactInfo.Email</span>
                            </li>
                        }
                        @if (Model.ContactInfo.ShowAddress && !string.IsNullOrEmpty(Model.ContactInfo.AddressEn))
                        {
                            <li>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                <span>
                                    <span data-ar>@Model.ContactInfo.AddressAr, @Model.ContactInfo.City</span>
                                    <span data-en>@Model.ContactInfo.AddressEn, @Model.ContactInfo.City</span>
                                </span>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <div class="container footer-bottom-inner" style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px">
            <p>
                © @DateTime.Now.Year Uni-Shop —
                <span data-ar>يونى شوب. جميع الحقوق محفوظة.</span>
                <span data-en>Uni-Shop. All Rights Reserved.</span>
            </p>
            <div class="footer-payments" aria-label="Payment methods">
                <span class="pm">VISA</span>
                <span class="pm">MASTERCARD</span>
                <span class="pm">VODAFONE CASH</span>
                <span class="pm">INSTAPAY</span>
                <span class="pm"><span data-ar>كاش عند الاستلام</span><span data-en>COD</span></span>
            </div>
        </div>
    </div>
</footer>
