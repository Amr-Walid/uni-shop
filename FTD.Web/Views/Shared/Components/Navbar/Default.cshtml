@model FTD.Web.ViewModels.NavbarViewModel
<div class="nav-wrap">
    <nav class="nav">
        <a href="/" class="logo" style="color: var(--primary); display: flex; align-items: center; gap: 8px;">
            <img src="/images/logo-unishop-mark.png" alt="Uni Shop Logo" style="height: 36px; width: auto; display: block;" />
            <span><span data-ar>يوني <strong>شوب</strong></span><span data-en>Uni<strong>-Shop</strong></span></span>
        </a>
        <div class="nav-links">
            <a href="/" class="nav-link" id="nav-home">
                <span data-ar>الرئيسية</span><span data-en>Home</span>
            </a>
            <a href="/#about" class="nav-link" id="nav-about">
                <span data-ar>عننا</span><span data-en>About</span>
            </a>
            <div class="nav-dropdown" id="nav-products-wrap">
                <a href="/Products" class="nav-link" id="nav-products">
                    <span data-ar>المنتجات</span><span data-en>Products</span>
                    <svg class="nav-caret" width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                @if (Model.NavCategories.Any())
                {
                    <div class="nav-dropdown-menu" role="menu" aria-label="Product categories">
                        <a href="/Products" class="nav-dropdown-item all" role="menuitem">
                            <span class="nd-emoji">🛍️</span>
                            <span class="nd-name"><span data-ar>كل المنتجات</span><span data-en>All Products</span></span>
                            <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </a>
                        <div class="nav-dropdown-sep"></div>
                        @foreach (var c in Model.NavCategories)
                        {
                            <a href="/Products?category=@c.Slug" class="nav-dropdown-item" role="menuitem">
                                <span class="nd-emoji">@(string.IsNullOrWhiteSpace(c.Emoji) ? "📦" : c.Emoji)</span>
                                <span class="nd-name"><span data-ar>@c.NameAr</span><span data-en>@c.NameEn</span></span>
                                @if (c.ProductsCount > 0)
                                {
                                    <span class="nd-count">@c.ProductsCount</span>
                                }
                            </a>
                        }
                    </div>
                }
            </div>
            <a href="/#contact" class="nav-link" id="nav-contact">
                <span data-ar>تواصل معنا</span><span data-en>Contact</span>
            </a>
        </div>
        <div class="nav-actions">
            <button class="search-btn" onclick="openSearch()">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M14 14L11 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                <span><span data-ar>ابحث عن المنتجات...</span><span data-en>Search products</span></span>
                <kbd>⌘K</kbd>
            </button>
            <a href="/Cart" class="icon-btn primary" aria-label="Cart">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M5 6h11l-1 8H6L5 6zM5 6L4 3H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.5" fill="currentColor"/><circle cx="14" cy="17" r="1.5" fill="currentColor"/></svg>
                <span class="cart-badge" id="cartCount" data-cart-count style="display:none">0</span>
            </a>
            <button class="lang-toggle" onclick="toggleLang()">
                <span data-ar>EN</span><span data-en>AR</span>
            </button>
            <button class="mobile-menu-btn" onclick="toggleMobileMenu()" aria-label="Menu">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
        </div>
    </nav>
    <div class="mobile-menu" id="mobile-menu">
        <a href="/" class="mobile-menu-link" data-nav="home"><span data-ar>الرئيسية</span><span data-en>Home</span></a>
        <a href="/#about" class="mobile-menu-link" data-nav="about"><span data-ar>عننا</span><span data-en>About</span></a>
        <div class="mobile-accordion" id="mobile-products-acc">
            <div class="mobile-menu-link mobile-acc-row" data-nav="products">
                <a href="/Products" class="mobile-acc-link"><span data-ar>المنتجات</span><span data-en>Products</span></a>
                @if (Model.NavCategories.Any())
                {
                    <button type="button" class="mobile-acc-toggle" aria-label="Toggle categories" aria-expanded="false"
                            onclick="toggleMobileCats(event)">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                }
            </div>
            @if (Model.NavCategories.Any())
            {
                <div class="mobile-acc-panel" id="mobile-cats-panel">
                    @foreach (var c in Model.NavCategories)
                    {
                        <a href="/Products?category=@c.Slug" class="mobile-menu-link mobile-cat-link">
                            <span class="nd-emoji">@(string.IsNullOrWhiteSpace(c.Emoji) ? "📦" : c.Emoji)</span>
                            <span><span data-ar>@c.NameAr</span><span data-en>@c.NameEn</span></span>
                        </a>
                    }
                </div>
            }
        </div>
        <a href="/#contact" class="mobile-menu-link" data-nav="contact"><span data-ar>تواصل معنا</span><span data-en>Contact</span></a>
    </div>
</div>
<script>
    function toggleMobileMenu() {
        var menu = document.getElementById('mobile-menu');
        if (menu) menu.classList.toggle('open');
    }

    // Mobile: expand/collapse the categories accordion under "Products"
    function toggleMobileCats(e) {
        e.preventDefault();
        e.stopPropagation();
        var acc = document.getElementById('mobile-products-acc');
        var btn = e.currentTarget;
        if (acc) {
            var open = acc.classList.toggle('open');
            if (btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
    }

    (function () {
        // Map of logical nav "keys" to their .nav-link element id.
        var NAV_IDS = { home: 'nav-home', about: 'nav-about', products: 'nav-products', contact: 'nav-contact' };

        function setActive(key) {
            document.querySelectorAll('.nav-link').forEach(function (l) { l.classList.remove('active'); });
            document.querySelectorAll('.mobile-menu-link').forEach(function (l) { l.classList.remove('active'); });
            var id = NAV_IDS[key];
            var el = id ? document.getElementById(id) : null;
            if (el) el.classList.add('active');
            var mobileEl = document.querySelector('.mobile-menu-link[data-nav="' + key + '"]');
            if (mobileEl) mobileEl.classList.add('active');
        }

        // ── Deterministic initial state from the CURRENT URL ───────────────────
        // Runs identically no matter how this page was reached (full navigation,
        // back/forward, or a hard refresh) — this is what previously broke when
        // clicking "About" from a non-home page: the click was never intercepted
        // (by design — there's nothing to scroll to on /Products), so it always
        // resulted in a real navigation to "/#about", but the active-state logic
        // used to be skipped entirely for the initial paint on some browsers due
        // to a fragile early-return. It's now unconditional for every page.
        var path = window.location.pathname.replace(/\/+$/, '') || '/';
        var isHome = (path === '/' || path === '');

        function keyFromLocation() {
            if (path.toLowerCase().indexOf('/products') === 0) return 'products';
            if (isHome) {
                var hash = window.location.hash;
                if (hash === '#about')   return 'about';
                if (hash === '#contact') return 'contact';
                return 'home';
            }
            return null; // Cart / Order / Page / other routes: no top-level match
        }

        var initialKey = keyFromLocation();
        if (initialKey) setActive(initialKey);

        if (!isHome) return; // scroll-spy & in-page hash smooth-scroll only apply on Home

        // ── Scroll-spy (Home page only) ─────────────────────────────────────────
        // Uses IntersectionObserver instead of manual scrollY/offset math so it
        // stays correct even when content above a section (hero images, etc.)
        // finishes loading late and shifts the layout — the old manual-offset
        // version could get "stuck" pointing at the wrong section (reported as
        // "About" incorrectly showing "Home" as active) once that happened.
        var SECTIONS = [
            { id: 'about', key: 'about' },
            { id: 'featured', key: 'products' },
            { id: 'contact', key: 'contact' }
        ];

        var lockedKey = null;
        var lockTimer = null;
        function lockActive(key, ms) {
            lockedKey = key;
            setActive(key);
            clearTimeout(lockTimer);
            lockTimer = setTimeout(function () { lockedKey = null; }, ms);
        }

        window.addEventListener('load', function () {
            var observed = [];
            SECTIONS.forEach(function (s) {
                var el = document.getElementById(s.id);
                if (el) observed.push({ el: el, key: s.key });
            });

            if (observed.length && 'IntersectionObserver' in window) {
                var io = new IntersectionObserver(function (entries) {
                    if (lockedKey) return; // a click just triggered a smooth scroll — don't fight it
                    var best = null;
                    entries.forEach(function (entry) {
                        if (entry.isIntersecting && (!best || entry.intersectionRatio > best.intersectionRatio)) {
                            best = entry;
                        }
                    });
                    if (best) {
                        var match = observed.filter(function (o) { return o.el === best.target; })[0];
                        if (match) setActive(match.key);
                    } else if (window.scrollY < 200) {
                        setActive('home');
                    }
                }, { threshold: [0.15, 0.3, 0.5], rootMargin: '-96px 0px -40% 0px' });

                observed.forEach(function (o) { io.observe(o.el); });
            }

            // Always-correct fallback: near the very top of the page => Home.
            window.addEventListener('scroll', function () {
                if (!lockedKey && window.scrollY < 120) setActive('home');
            }, { passive: true });

            // In-page hash links: intercept for a smooth scroll + instant active state.
            document.querySelectorAll('a[href^="/#"], a[href="/"], a[href="/#"]').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    var href = this.getAttribute('href');
                    var key, targetSelector;

                    if      (href === '/' || href === '/#') { key = 'home';     targetSelector = null; }
                    else if (href === '/#about')             { key = 'about';   targetSelector = '#about'; }
                    else if (href === '/#contact')           { key = 'contact'; targetSelector = '#contact'; }
                    else return;

                    if (targetSelector) {
                        var el = document.querySelector(targetSelector);
                        if (el) {
                            e.preventDefault();
                            lockActive(key, 900);
                            el.scrollIntoView({ behavior: 'smooth' });
                            window.history.pushState(null, '', href);
                        }
                    } else {
                        lockActive('home', 900);
                    }
                });
            });
        });
    })();
</script>
