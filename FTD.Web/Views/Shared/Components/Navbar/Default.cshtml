@model FTD.Web.ViewModels.NavbarViewModel
<div class="nav-wrap">
    <nav class="nav">
        <a href="/" class="logo">
            <span class="logo-mark"><span>U</span></span>
            <span>Uni<strong>-Shop</strong></span>
        </a>
        <div class="nav-links">
            <a href="/" class="nav-link" id="nav-home">
                <span data-ar>الرئيسية</span><span data-en>Home</span>
            </a>
            <a href="/#about" class="nav-link" id="nav-about">
                <span data-ar>عننا</span><span data-en>About</span>
            </a>
            <a href="/Products" class="nav-link" id="nav-products">
                <span data-ar>المنتجات</span><span data-en>Products</span>
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/#contact" class="nav-link" id="nav-contact">
                <span data-ar>تواصل معنا</span><span data-en>Contact</span>
            </a>
        </div>
        <div class="nav-actions">
            <button class="search-btn" onclick="openSearch()">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M14 14L11 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                <span><span data-ar>ابحث عن المنتجات...</span><span data-en>Search products</span></span>
                <kbd>⌘K</kbd>
            </button>
            <a href="/Cart" class="icon-btn primary" aria-label="Cart">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M5 6h11l-1 8H6L5 6zM5 6L4 3H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7" cy="17" r="1.5" fill="currentColor"/><circle cx="14" cy="17" r="1.5" fill="currentColor"/></svg>
                <span class="cart-badge" id="cartCount" data-cart-count style="display:none">0</span>
            </a>
            <button class="lang-toggle" onclick="toggleLang()">
                <span data-ar>EN</span><span data-en>AR</span>
            </button>
            <button class="mobile-menu-btn" onclick="toggleMobileMenu()" aria-label="Menu">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M3 6h14M3 10h14M3 14h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
        </div>
    </nav>
    <div class="mobile-menu" id="mobile-menu">
        <a href="/" class="mobile-menu-link"><span data-ar>الرئيسية</span><span data-en>Home</span></a>
        <a href="/#about" class="mobile-menu-link"><span data-ar>عننا</span><span data-en>About</span></a>
        <a href="/Products" class="mobile-menu-link"><span data-ar>المنتجات</span><span data-en>Products</span></a>
        <a href="/#contact" class="mobile-menu-link"><span data-ar>تواصل معنا</span><span data-en>Contact</span></a>
    </div>
</div>
<script>
    function toggleMobileMenu() {
        var menu = document.getElementById('mobile-menu');
        if (menu) menu.classList.toggle('open');
    }

    (function () {
        var path = window.location.pathname;
        var hash = window.location.hash;

        function setActive(id) {
            document.querySelectorAll('.nav-link').forEach(function (l) { l.classList.remove('active'); });
            var el = document.getElementById(id);
            if (el) el.classList.add('active');
        }

        // ── Non-home pages: set by route ─────────────────────────────────────
        if (path !== '/' && path !== '') {
            if (path.indexOf('/Products') === 0) setActive('nav-products');
            return;
        }

        // ── Home page ────────────────────────────────────────────────────────

        // Set active immediately from URL hash — handles cross-page navigation
        // (browser natively scrolls to hash, no JS scroll events involved)
        if      (hash === '#about')   setActive('nav-about');
        else if (hash === '#contact') setActive('nav-contact');
        else                          setActive('nav-home');

        // Scroll spy — only for manual scrolling AFTER the page loads
        window.addEventListener('load', function () {
            var aboutEl    = document.getElementById('about');
            var featuredEl = document.getElementById('featured');
            var contactEl  = document.getElementById('contact');

            function getActiveId() {
                var scrollY     = window.scrollY + 180;
                var contactTop  = contactEl  ? contactEl.getBoundingClientRect().top  + window.scrollY : Infinity;
                var aboutTop    = aboutEl    ? aboutEl.getBoundingClientRect().top    + window.scrollY : Infinity;
                var featuredTop = featuredEl ? featuredEl.getBoundingClientRect().top + window.scrollY : Infinity;
                if (contactEl  && scrollY >= contactTop)  return 'nav-contact';
                if (aboutEl    && scrollY >= aboutTop)    return 'nav-about';
                if (featuredEl && scrollY >= featuredTop) return 'nav-products';
                return 'nav-home';
            }

            var isNavigating = false;

            window.addEventListener('scroll', function () {
                if (!isNavigating) setActive(getActiveId());
            }, { passive: true });

            // Click on hash links: freeze spy, smooth scroll, unfreeze when done
            document.querySelectorAll('a[href^="/#"], a[href="/"]').forEach(function (link) {
                link.addEventListener('click', function (e) {
                    var href = this.getAttribute('href');
                    var targetId, targetSelector;

                    if      (href === '/' || href === '/#') { targetId = 'nav-home';    targetSelector = null; }
                    else if (href === '/#about')            { targetId = 'nav-about';   targetSelector = '#about'; }
                    else if (href === '/#contact')          { targetId = 'nav-contact'; targetSelector = '#contact'; }
                    else return;

                    setActive(targetId);

                    if (targetSelector) {
                        e.preventDefault();
                        var el = document.querySelector(targetSelector);
                        if (el) {
                            isNavigating = true;
                            el.scrollIntoView({ behavior: 'smooth' });
                            window.history.pushState(null, '', href);

                            if ('onscrollend' in window) {
                                window.addEventListener('scrollend', function () {
                                    isNavigating = false;
                                }, { once: true });
                            } else {
                                var lastY = window.scrollY, stable = 0;
                                var t = setInterval(function () {
                                    if (Math.abs(window.scrollY - lastY) < 2) {
                                        if (++stable >= 3) { clearInterval(t); isNavigating = false; }
                                    } else { stable = 0; lastY = window.scrollY; }
                                }, 50);
                            }
                        }
                    }
                });
            });
        });
    })();
</script>
