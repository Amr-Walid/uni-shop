@model FTD.Web.ViewModels.NavbarViewModel
<!-- NAV -->
<nav id="mainNav">
    <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
    </button>
    <div class="nav-logo">
        <a href="/" style="display:flex;align-items:center;text-decoration:none">
            <img src="/images/ftd-logo.png" alt="FTD TechZone" style="height:38px;object-fit:contain">
        </a>
    </div>
    <ul class="nav-center">
        <li>
            <a href="/" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <span data-ar>الرئيسية</span><span data-en>Home</span>
            </a>
        </li>
        <li><a href="/#about"><span data-ar>عننا</span><span data-en>About</span></a></li>
        <li class="nav-megabtn" id="productsMegaBtn">
            <a href="/Products" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")" id="productsMegaTrigger">
                <span data-ar>المنتجات</span><span data-en>Products</span>
                <span class="mega-arrow">▾</span>
            </a>
            <div class="mega-panel" id="productsMegaPanel">
                <a href="/Products" class="mega-all">
                    <span class="d-icon">🛍️</span>
                    <span data-ar>كل المنتجات</span><span data-en>All Products</span>
                </a>
                <div class="mega-divider"></div>
                @foreach (var nb in Model.NavBrands)
                {
                    <a href="/brand/@nb.Slug" class="mega-brand-link">
                        @if (!string.IsNullOrEmpty(nb.LogoPath))
                        {
                            <img src="@nb.LogoPath" alt="@nb.NameEn" style="height:18px;object-fit:contain;max-width:70px">
                        }
                        else
                        {
                            <span>@nb.NameEn</span>
                        }
                    </a>
                }
            </div>
        </li>
        <li><a href="/#contact"><span data-ar>تواصل معنا</span><span data-en>Contact</span></a></li>
        @foreach (var ni in Model.NavItems)
        {
            var niUrl = ni.LinkType == "ContentPage" ? "/page/" + ni.PageSlug
            : ni.LinkType == "External" ? ni.ExternalUrl
            : ni.StaticRoute;
            <li>
                <a href="@niUrl" @(ni.OpenInNewTab ? "target=_blank" : "")>
                    <span data-ar>@ni.LabelAr</span><span data-en>@ni.LabelEn</span>
                </a>
            </li>
        }
    </ul>
    <div class="nav-right">
        <div class="search-trigger" onclick="openSearch()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
            <span><span data-ar>بحث...</span><span data-en>Search...</span></span>
        </div>
        <a href="/Cart" class="cart-btn">
            <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 01-8 0" /></svg>
            <div class="cart-count" id="cartCount">0</div>
        </a>
        <button class="lang-btn" onclick="toggleLang()">
            <span data-ar>EN</span><span data-en>AR</span>
        </button>
    </div>
</nav>
<!-- MOBILE NAV DRAWER -->
<div class="mobile-nav" id="mobileNav">
    <a href="/">
        <span data-ar>الرئيسية</span><span data-en>Home</span>
    </a>
    <a href="/#about">
        <span data-ar>عننا</span><span data-en>About</span>
    </a>
    <a href="/Products">
        <span data-ar>كل المنتجات</span><span data-en>All Products</span>
    </a>
    @foreach (var nb in Model.NavBrands)
    {
        <a href="/brand/@nb.Slug">@nb.NameEn</a>
    }
    @foreach (var ni in Model.NavItems)
    {
        var niUrl = ni.LinkType == "ContentPage" ? "/page/" + ni.PageSlug
        : ni.LinkType == "External" ? ni.ExternalUrl
        : ni.StaticRoute;
        <a href="@niUrl">
            <span data-ar>@ni.LabelAr</span><span data-en>@ni.LabelEn</span>
        </a>
    }
    <a href="/#contact">
        <span data-ar>تواصل معنا</span><span data-en>Contact</span>
    </a>
</div>
