@model PageSectionDto
@* Parse JSON: {"ar":"...","en":"...","style":{...}} *@
@{
    string bodyAr = "", bodyEn = "";
    if (!string.IsNullOrEmpty(Model.ContentJson))
    {
        try {
            var doc = System.Text.Json.JsonDocument.Parse(Model.ContentJson);
            bodyAr = SectionJson.Str(doc.RootElement, "ar");
            bodyEn = SectionJson.Str(doc.RootElement, "en");
        } catch { bodyAr = Model.ContentJson; }
    }
    var style = SectionStyle.Parse(Model.ContentJson);
    var wrapCss = style.WrapperCss();
    var darkCss = style.IsDark ? "color:#fff;" : "";
}
<div class="page-content @(style.IsDark ? "pc-dark" : "")" style="@wrapCss @darkCss margin-bottom:2rem">
  <span data-ar>@Html.Raw(FTD.Application.Common.HtmlSanitizer.Sanitize(bodyAr))</span>
  <span data-en>@Html.Raw(FTD.Application.Common.HtmlSanitizer.Sanitize(bodyEn))</span>
</div>
@if (style.IsDark)
{
    <style>.pc-dark p, .pc-dark li { color: rgba(255,255,255,.75) !important; }</style>
}
