@model PageSectionDto
@{
    var cards = new List<(string titleAr, string titleEn, string bodyAr, string bodyEn, string icon, string img)>();
    foreach (var el in SectionJson.Items(Model.ContentJson))
    {
        cards.Add((SectionJson.Str(el, "title_ar"), SectionJson.Str(el, "title_en"),
                   SectionJson.Str(el, "body_ar"), SectionJson.Str(el, "body_en"),
                   SectionJson.Str(el, "icon"), SectionJson.Str(el, "card_image_path")));
    }
    var style = SectionStyle.Parse(Model.ContentJson);
    var wrapCss = style.WrapperCss();
    var cardText = style.IsDark ? "color:#fff;" : "";
}

@if (cards.Any())
{
    <div style="@wrapCss margin-bottom:2rem">
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1.2rem">
        @foreach (var card in cards)
        {
            <div style="background:white;border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;transition:all .3s;@(style.Align == "center" ? "text-align:center;" : "")" onmouseover="this.style.boxShadow='0 8px 32px rgba(26,107,255,.12)';this.style.borderColor='rgba(26,107,255,.3)'" onmouseout="this.style.boxShadow='';this.style.borderColor='var(--border)'">
                @if (!string.IsNullOrEmpty(card.img))
                {
                    <div style="height:150px;overflow:hidden">
                      <img src="@card.img" alt="@card.titleAr" loading="lazy" style="width:100%;height:100%;object-fit:cover">
                    </div>
                }
                <div style="padding:1.5rem">
                  @if (string.IsNullOrEmpty(card.img) && !string.IsNullOrEmpty(card.icon))
                  {
                      <div style="width:44px;height:44px;background:var(--blue-light);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:1rem;border:1px solid rgba(26,107,255,.15);@(style.Align == "center" ? "margin-left:auto;margin-right:auto;" : "")">
                          @if (card.icon.StartsWith("bi-")) { <i class="bi @card.icon" style="color:var(--blue)"></i> }
                          else { @card.icon }
                      </div>
                  }
                  @if (!string.IsNullOrEmpty(card.titleAr) || !string.IsNullOrEmpty(card.titleEn))
                  {
                      <h3 style="font-size:15px;font-weight:700;margin-bottom:.5rem">
                          <span data-ar>@card.titleAr</span>
                          <span data-en>@card.titleEn</span>
                      </h3>
                  }
                  @if (!string.IsNullOrEmpty(card.bodyAr) || !string.IsNullOrEmpty(card.bodyEn))
                  {
                      <p style="font-size:13px;color:var(--text2);line-height:1.7">
                          <span data-ar>@card.bodyAr</span>
                          <span data-en>@card.bodyEn</span>
                      </p>
                  }
                </div>
            </div>
        }
      </div>
    </div>
}
