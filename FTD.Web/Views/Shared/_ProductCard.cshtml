@model ProductDto
@{
    var badgeKind = Model.Badge?.ToLower() switch
    {
        "new" => "new",
        "hot" => "hot",
        "4k" => "4k",
        "rugged" => "rugged",
        _ => "new"
    };
}
<article class="product-card" onclick="location.href='/products/@Model.Slug'">
    <div class="media">
        @if (!string.IsNullOrEmpty(Model.Badge))
        {
            <div class="badge-wrap"><span class="badge badge-@badgeKind">@Model.Badge</span></div>
        }
        <a href="/products/@Model.Slug" class="quick-view" aria-label="Quick view" onclick="event.stopPropagation()">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" alt="@Model.NameEn" style="max-height:120px;object-fit:contain;z-index:1;">
        }
        else
        {
            <span style="font-size:54px;z-index:1;">@(Model.Emoji ?? "📦")</span>
        }
    </div>
    <div class="info">
        <div class="brand-line">
            <span class="brand">@Model.BrandName?.ToUpper()</span>
            <span class="sku">SKU · @Model.Id.ToString("D2")</span>
        </div>
        <h3><a href="/products/@Model.Slug" onclick="event.stopPropagation()">
            <span data-ar>@Model.NameAr</span>
            <span data-en>@Model.NameEn</span>
        </a></h3>
        <p class="desc">
            <span data-ar>@Model.ShortDescAr</span>
            <span data-en>@Model.ShortDescEn</span>
        </p>
        <div class="price-row">
            <div style="display:flex; flex-direction:column;">
                <span class="price">EGP @Model.Price.ToString("N0")</span>
                @if (Model.OldPrice.HasValue && Model.OldPrice.Value > Model.Price)
                {
                    var disc = (int)Math.Round((1 - Model.Price / Model.OldPrice.Value) * 100);
                    <div style="display:flex;align-items:center;gap:5px;margin-top:2px">
                        <span style="font-size:11px;color:var(--on-surface-muted);text-decoration:line-through">EGP @Model.OldPrice.Value.ToString("N0")</span>
                        <span style="background:#FF3B30;color:white;font-size:9px;font-weight:800;padding:1px 5px;border-radius:100px">-@disc%</span>
                    </div>
                }
            </div>
            <div class="actions">
                <a href="/products/@Model.Slug" class="btn btn-dark btn-sm" onclick="event.stopPropagation()">
                    <span data-ar>التفاصيل</span><span data-en>Details</span>
                </a>
                <button class="icon-only" onclick="event.stopPropagation(); addToCartQuick(@Model.Id, this)" aria-label="Add to cart">
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4 5h9l-1 6H5L4 5zM4 5L3.5 3H2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="6" cy="13" r="1" fill="currentColor"/><circle cx="11" cy="13" r="1" fill="currentColor"/></svg>
                </button>
            </div>
        </div>
    </div>
</article>
