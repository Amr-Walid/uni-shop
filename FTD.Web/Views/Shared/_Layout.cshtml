@{
    var en = Context.Request.Cookies["ftd_lang"] == "en";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" id="htmlRoot">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Uni-Shop</title>
    <meta name="description" content="@(ViewData["MetaDesc"] ?? "وجهتك الأولى لأحدث التكنولوجيا في مصر — يونى شوب")">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- SEARCH OVERLAY -->
    <div class="search-overlay" id="searchOverlay">
        <div class="search-box">
            <div class="search-input-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
                <input type="text" id="searchInput" placeholder="ابحث عن منتج، براند، أو كاتيجوري...">
                <button class="search-close" onclick="closeSearch()">✕</button>
            </div>
            <div id="searchResults" class="search-results" style="display:none"></div>
            <div class="search-tags" id="searchTags">
                <a href="/brand/doogee" class="search-tag">Doogee Tablets</a>
                <a href="/brand/jisulife" class="search-tag">Jisulife Fans</a>
                <a href="/brand/dreame" class="search-tag">Dreame Webcams</a>
                <span class="search-tag" onclick="doSearch('تابلت متين')">تابلت متين</span>
                <span class="search-tag" onclick="doSearch('مروحة محمولة')">مروحة محمولة</span>
                <span class="search-tag" onclick="doSearch('كاميرا 4K')">كاميرا 4K</span>
            </div>
        </div>
    </div>
    
    @await Component.InvokeAsync("Navbar")

    <!-- MAIN CONTENT -->
    <main>
        @RenderBody()
    </main>

    @await Component.InvokeAsync("Footer")
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
