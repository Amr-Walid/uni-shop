@model FTD.Web.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "الرئيسية";

    // ── Dynamic content helpers ──────────────────────────────────────────
    string Get(string key) => Model.ContentBlocks.TryGetValue(key, out var v) ? v : "";
    string GetOr(string key, string fallback)
    {
        var v = Get(key);
        return string.IsNullOrWhiteSpace(v) ? fallback : v;
    }

    // Hero slider products (selected & ordered from the dashboard)
    var heroList = Model.HeroProducts;

    // Homepage categories (respect ShowOnHomepage + configurable count)
    var homepageCats = Model.Categories
        .Where(c => c.ShowOnHomepage)
        .Take(Model.HomepageCategoriesCount)
        .ToList();

    // Marquee items (comma-separated, editable from dashboard)
    var marqueeAr = GetOr("marquee.items.ar", "DOOGEE,JISULIFE,DREAME,ضمان معتمد,منتجات أصلية,توصيل سريع")
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var marqueeEn = GetOr("marquee.items.en", "DOOGEE,JISULIFE,DREAME,CERTIFIED WARRANTY,ORIGINAL PRODUCTS,FAST DELIVERY")
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    // Section order (from dashboard) — append any missing known section for safety
    var knownSections = new[] { "hero", "values", "marquee", "categories", "featured", "about", "mission", "cta", "contact" };
    var sectionOrder = Model.SectionsOrder.Where(s => knownSections.Contains(s)).ToList();
    foreach (var s in knownSections)
    {
        if (!sectionOrder.Contains(s)) { sectionOrder.Add(s); }
    }

    // Default value-prop icons (Bootstrap Icons) used when block icon is empty
    var defaultPropIcons = new[] { "bi-shield-check", "bi-truck", "bi-headset", "bi-arrow-counterclockwise" };
}

@{
    // ════════════════ SECTION RENDERERS (local functions) ════════════════

    void RenderHero()
    {
<!-- ============ HERO ============ -->
<section class="hero">
    <div class="container">
        <div class="hero-inner">
            <div class="hero-content">
                <div class="hero-chips">
                    <span class="chip"><span class="dot"></span><span data-ar>@GetOr("hero.chip1.ar", "مباشر · الأكثر مبيعاً")</span><span data-en>@GetOr("hero.chip1.en", "LIVE · Best Seller Q3")</span></span>
                    <span class="chip" style="background:var(--surface-container-low);color:var(--navy-3);border-color:var(--outline-variant)">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                        <span data-ar>@GetOr("hero.chip2.ar", "وصل حديثاً · ٢٤")</span><span data-en>@GetOr("hero.chip2.en", "New Arrivals · 24")</span>
                    </span>
                </div>
                <h1>
                    <span class="flex-line"><span data-ar>@GetOr("hero.title.line1.ar", "منصة التحكم")</span><span data-en>@GetOr("hero.title.line1.en", "The command deck")</span></span>
                    <span class="flex-line"><span data-ar>@GetOr("hero.title.line2.ar", "للتكنولوجيا العصرية.")</span><span data-en>@GetOr("hero.title.line2.en", "for modern tech.")</span></span>
                </h1>
                <p class="hero-sub">
                    <span data-ar>@GetOr("hero.subtitle.ar", "منصة منسقة لأحدث الأجهزة التكنولوجية — توصيل لكافة محافظات مصر بضمان معتمد.")</span>
                    <span data-en>@GetOr("hero.subtitle.en", "A curated platform for the latest tech — delivered across Egypt with certified warranty.")</span>
                </p>
                <div class="hero-actions">
                    <a href="@GetOr("hero.btn1.url.ar", "/Products")" class="btn btn-primary btn-lg">
                        <span data-ar>@GetOr("hero.btn1.text.ar", "اكتشف الكتالوج")</span><span data-en>@GetOr("hero.btn1.text.en", "Explore Catalog")</span>
                        <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                    <a href="@GetOr("hero.btn2.url.ar", "#featured")" class="btn btn-ghost btn-lg">
                        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                        <span data-ar>@GetOr("hero.btn2.text.ar", "المميز هذا الأسبوع")</span><span data-en>@GetOr("hero.btn2.text.en", "Featured this week")</span>
                    </a>
                </div>
                <div class="hero-stats">
                    <div class="hero-stat">
                        <div class="value">@Get("about.stat.years.ar")<span class="plus">+</span></div>
                        <div class="label"><span data-ar>@GetOr("hero.stat1.label.ar", "سنوات خبرة")</span><span data-en>@GetOr("hero.stat1.label.en", "Years Experience")</span></div>
                    </div>
                    <div class="hero-stat">
                        <div class="value">@Get("about.stat.clients.ar")<span class="plus">+</span></div>
                        <div class="label"><span data-ar>@GetOr("hero.stat2.label.ar", "عميل سعيد")</span><span data-en>@GetOr("hero.stat2.label.en", "Delivered Orders")</span></div>
                    </div>
                    <div class="hero-stat">
                        <div class="value">@Get("about.stat.products.ar")<span class="plus">+</span></div>
                        <div class="label"><span data-ar>@GetOr("hero.stat3.label.ar", "منتج فريد")</span><span data-en>@GetOr("hero.stat3.label.en", "Curated SKUs")</span></div>
                    </div>
                </div>
            </div>

            <div class="hero-visual">
                <div class="showcase-slider">
                    @for (int i = 0; i < heroList.Count; i++)
                    {
                        var prod = heroList[i];
                        <div class="showcase-slide @(i == 0 ? "active" : "")" data-slide-index="@i">
                            <div class="showcase-card">
                                <div class="showcase-badge">
                                    <span class="dot-live"></span>
                                    <span>@prod.BrandName?.ToUpper()</span>
                                </div>
                                <div class="showcase-media">
                                    @if (!string.IsNullOrEmpty(prod.ImagePath))
                                    {
                                        <img src="@prod.ImagePath" alt="@prod.NameEn">
                                    }
                                    else
                                    {
                                        <span class="fallback-emoji">@(prod.Emoji ?? "📦")</span>
                                    }
                                </div>
                                <div class="showcase-info">
                                    <h3 class="showcase-title">
                                        <span data-ar>@prod.NameAr</span>
                                        <span data-en>@prod.NameEn</span>
                                    </h3>
                                    <p class="showcase-desc">
                                        <span data-ar>@prod.ShortDescAr</span>
                                        <span data-en>@prod.ShortDescEn</span>
                                    </p>
                                    <div class="showcase-footer">
                                        <div class="showcase-price">
                                            <span class="currency">EGP</span>
                                            <span class="amt">@prod.Price.ToString("N0")</span>
                                        </div>
                                        <a href="/products/@prod.Slug" class="showcase-btn">
                                            <span data-ar>تصفح المنتج</span><span data-en>View Product</span>
                                            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Slider Controls -->
                    <div class="showcase-controls">
                        <button class="ctrl-btn prev" onclick="prevShowcaseSlide()" aria-label="Previous Slide">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                        </button>
                        <div class="showcase-dots">
                            @for (int i = 0; i < heroList.Count; i++)
                            {
                                <button class="dot-indicator @(i == 0 ? "active" : "")" onclick="setShowcaseSlide(@i)" aria-label="Go to slide @(i+1)"></button>
                            }
                        </div>
                        <button class="ctrl-btn next" onclick="nextShowcaseSlide()" aria-label="Next Slide">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    var currentShowcaseIndex = 0;
    var totalShowcaseSlides = @heroList.Count;
    var showcaseAutoplayTimer = null;

    function setShowcaseSlide(index) {
        if (index < 0 || index >= totalShowcaseSlides) return;
        currentShowcaseIndex = index;

        document.querySelectorAll('.showcase-slide').forEach(function(slide, idx) {
            slide.classList.toggle('active', idx === index);
        });

        document.querySelectorAll('.dot-indicator').forEach(function(dot, idx) {
            dot.classList.toggle('active', idx === index);
        });

        resetShowcaseAutoplay();
    }

    function nextShowcaseSlide() {
        var nextIndex = (currentShowcaseIndex + 1) % totalShowcaseSlides;
        setShowcaseSlide(nextIndex);
    }

    function prevShowcaseSlide() {
        var prevIndex = (currentShowcaseIndex - 1 + totalShowcaseSlides) % totalShowcaseSlides;
        setShowcaseSlide(prevIndex);
    }

    function resetShowcaseAutoplay() {
        clearInterval(showcaseAutoplayTimer);
        if (totalShowcaseSlides > 1) {
            showcaseAutoplayTimer = setInterval(nextShowcaseSlide, 5000);
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        resetShowcaseAutoplay();
    });
</script>
    }

    void RenderValues()
    {
<!-- ============ VALUE PROPS STRIP (dynamic) ============ -->
<section class="container">
    <div class="value-strip reveal">
        @for (int i = 1; i <= 4; i++)
        {
            var icon = GetOr($"value.prop{i}.title.icon", defaultPropIcons[i - 1]);
            var titleAr = Get($"value.prop{i}.title.ar");
            var titleEn = Get($"value.prop{i}.title.en");
            if (string.IsNullOrWhiteSpace(titleAr) && string.IsNullOrWhiteSpace(titleEn)) { continue; }
            <div class="value-item">
                <span class="v-ico"><i class="bi @icon" style="font-size:20px"></i></span>
                <div>
                    <div class="v-t"><span data-ar>@titleAr</span><span data-en>@titleEn</span></div>
                    <div class="v-s"><span data-ar>@Get($"value.prop{i}.desc.ar")</span><span data-en>@Get($"value.prop{i}.desc.en")</span></div>
                </div>
            </div>
        }
    </div>
</section>
    }

    void RenderMarquee()
    {
<!-- ============ BRAND MARQUEE (dynamic) ============ -->
<section class="marquee">
    <div class="marquee-track">
        @for (int rep = 0; rep < 2; rep++)
        {
            for (int i = 0; i < marqueeAr.Length; i++)
            {
                var en = i < marqueeEn.Length ? marqueeEn[i] : marqueeAr[i];
                <span class="marquee-item"><span data-ar>@marqueeAr[i]</span><span data-en>@en</span> <span class="dot"></span></span>
            }
        }
    </div>
</section>
    }

    void RenderCategories()
    {
        if (!homepageCats.Any()) { return; }
<!-- ============ CATEGORY SHOWCASE (dynamic) ============ -->
<section class="section" style="padding-bottom:0">
    <div class="container">
        <div class="section-header reveal">
            <div>
                <span class="eyebrow"><span data-ar>@GetOr("cat.showcase.eyebrow.ar", "تسوق حسب الفئة · ٠١")</span><span data-en>@GetOr("cat.showcase.eyebrow.en", "Shop by Category · 01")</span></span>
                <h2 class="headline-lg">
                    <span data-ar>@GetOr("cat.showcase.title.ar", "اختر فئتك، واكتشف الأفضل.")</span>
                    <span data-en>@GetOr("cat.showcase.title.en", "Pick a category, discover the best.")</span>
                </h2>
            </div>
            <div class="side">
                <p>
                    <span data-ar>@GetOr("cat.showcase.desc.ar", "كل فئة منسقة بعناية بمواصفات مؤكدة وأسعار تنافسية.")</span>
                    <span data-en>@GetOr("cat.showcase.desc.en", "Every category is hand-curated with verified specs and competitive prices.")</span>
                </p>
            </div>
        </div>
        <div class="cat-showcase-grid reveal">
            @foreach (var cat in homepageCats)
            {
                var catCount = cat.ProductsCount > 0 ? cat.ProductsCount : Model.FeaturedProducts.Count(p => p.CategoryId == cat.Id);
                <a href="/Products?category=@cat.Slug" class="cat-tile">
                    @if (!string.IsNullOrEmpty(cat.ImagePath))
                    {
                        <img src="@cat.ImagePath" alt="@cat.NameEn" class="cat-tile-image">
                    }
                    else
                    {
                        <span class="cat-emoji">@(cat.Emoji ?? "📦")</span>
                    }
                    <span class="cat-count">@catCount+ <span data-ar>منتج</span><span data-en>Products</span></span>
                    <h3><span data-ar>@cat.NameAr</span><span data-en>@cat.NameEn</span></h3>
                    <span class="cat-link">
                        <span data-ar>تصفح الفئة</span><span data-en>Browse category</span>
                        <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                </a>
            }
        </div>
    </div>
</section>
    }

    void RenderFeatured()
    {
<!-- ============ FEATURED PRODUCTS (dynamic) ============ -->
<section class="section" id="featured">
    <div class="container">
        <div class="section-header reveal">
            <div>
                <span class="eyebrow"><span data-ar>@GetOr("feat.catalog.eyebrow.ar", "كتالوج المنتجات · ٠٢")</span><span data-en>@GetOr("feat.catalog.eyebrow.en", "Product Catalog · 02")</span></span>
                <h2 class="headline-lg">
                    <span data-ar>@GetOr("feat.catalog.title.ar", "أجهزة منسقة لكل أسلوب عمل.")</span>
                    <span data-en>@GetOr("feat.catalog.title.en", "Curated hardware for every workflow.")</span>
                </h2>
            </div>
            <div class="side">
                <p>
                    <span data-ar>@GetOr("feat.catalog.desc.ar", "قم بالتصفية حسب الفئة لاستكشاف المنتجات الهامة فقط.")</span>
                    <span data-en>@GetOr("feat.catalog.desc.en", "Filter by category to explore only what matters.")</span>
                </p>
                <a href="/Products" class="btn btn-secondary">
                    <span data-ar>@GetOr("feat.catalog.btn.text.ar", "عرض جميع المنتجات")</span><span data-en>@GetOr("feat.catalog.btn.text.en", "View All Products")</span>
                    <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>
        </div>

        <div class="tab-row reveal" role="tablist">
            <button class="tab active" data-cat="all">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
                <span data-ar>الكل</span><span data-en>All</span> <span class="count">@Model.FeaturedProducts.Count</span>
            </button>
            @foreach (var cat in Model.Categories)
            {
                var count = Model.FeaturedProducts.Count(p => p.CategoryId == cat.Id);
                if (count == 0) { continue; }
                <button class="tab" data-cat="@cat.Slug">
                    @(cat.Emoji ?? "")
                    <span data-ar>@cat.NameAr</span><span data-en>@cat.NameEn</span>
                    <span class="count">@count</span>
                </button>
            }
        </div>

        <div class="products-grid reveal" id="products-grid">
            @foreach (var product in Model.FeaturedProducts)
            {
                <div data-category="@product.Category?.Slug">
                    <partial name="_ProductCard" model="product" />
                </div>
            }
        </div>
    </div>
</section>
    }

    void RenderAbout()
    {
<!-- ============ ABOUT (dynamic) ============ -->
<section class="section" id="about">
    <div class="container">
        <div class="about reveal">
            <div class="about-copy">
                <span class="eyebrow"><span data-ar>@GetOr("about.eyebrow.ar", "من نحن · ٠٣")</span><span data-en>@GetOr("about.eyebrow.en", "About Us · 03")</span></span>
                <h2 class="headline-lg" style="margin-top:20px">
                    <span data-ar>@GetOr("about.headline.ar", "تقديم أفضل التكنولوجيا لحياة أكثر سهولة وذكاءً.")</span>
                    <span data-en>@GetOr("about.headline.en", "Delivering the best technology for a better life.")</span>
                </h2>
                <p style="margin-top:24px">
                    <span data-ar>@Get("about.body.ar.ar")</span>
                    <span data-en>@Get("about.body.en.en")</span>
                </p>
                <div class="about-stats">
                    <div class="stat-card">
                        <div class="n">@Get("about.stat.years.ar")<span class="plus">+</span></div>
                        <div class="l"><span data-ar>@GetOr("hero.stat1.label.ar", "سنوات خبرة")</span><span data-en>@GetOr("hero.stat1.label.en", "Years Exp.")</span></div>
                    </div>
                    <div class="stat-card">
                        <div class="n">@Get("about.stat.clients.ar")<span class="plus">+</span></div>
                        <div class="l"><span data-ar>@GetOr("hero.stat2.label.ar", "عميل سعيد")</span><span data-en>@GetOr("hero.stat2.label.en", "Happy Clients")</span></div>
                    </div>
                    <div class="stat-card">
                        <div class="n">@Get("about.stat.products.ar")<span class="plus">+</span></div>
                        <div class="l"><span data-ar>@GetOr("hero.stat3.label.ar", "منتج فريد")</span><span data-en>@GetOr("hero.stat3.label.en", "Products")</span></div>
                    </div>
                </div>
            </div>
            @{
                var features = Enumerable.Range(1, 6)
                .Select(i => new
                {
                    icon = Model.ContentBlocks.GetValueOrDefault($"features.{i}.icon", "⭐"),
                    ar = Model.ContentBlocks.GetValueOrDefault($"features.{i}.ar", ""),
                    en = Model.ContentBlocks.GetValueOrDefault($"features.{i}.en", "")
                })
                .Where(f => !string.IsNullOrEmpty(f.ar))
                .ToList();
            }
            <div class="about-panel">
                <h3><span data-ar>لماذا تختار <span>يوني شوب</span>؟</span><span data-en>Why <span>Uni-Shop</span>?</span></h3>
                <div class="about-features">
                    @for (int idx = 0; idx < features.Count; idx++)
                    {
                        var feat = features[idx];
                        <div class="about-feature">
                            <span class="num">@((idx + 1).ToString("D2"))</span>
                            <span class="ico">
                                @if (idx == 0) { <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 2L3 4v4c0 3 5 6 5 6s5-3 5-6V4L8 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M6 8l1.5 1.5L10.5 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> }
                                else if (idx == 1) { <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M2 10h9l3-3h-2l-2-2H2v5zM4 12a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM11 12a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg> }
                                else if (idx == 2) { <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg> }
                                else { <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 1l2 4 5 .5-3.5 3.5L12.5 14 8 11.5 3.5 14l1-5L1 5.5 6 5l2-4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg> }
                            </span>
                            <span class="txt">
                                <span data-ar>@feat.ar</span>
                                <span data-en>@feat.en</span>
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
    }

    void RenderMission()
    {
<!-- ============ MISSION (dynamic) ============ -->
<section class="mission-section">
    <div class="container">
        <div class="mission-head reveal">
            <span class="eyebrow"><span data-ar>@GetOr("mission.eyebrow.ar", "رؤيتنا ورسالتنا · ٠٤")</span><span data-en>@GetOr("mission.eyebrow.en", "Mission & Vision · 04")</span></span>
            <h2><span data-ar>@GetOr("mission.headline.ar", "نبني مستقبل التكنولوجيا في مصر.")</span><span data-en>@GetOr("mission.headline.en", "Building the tech future in Egypt.")</span></h2>
        </div>
        <div class="mission-grid reveal">
            <div class="mission-card">
                <span class="tag">01</span>
                <div class="ico">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                        <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                        <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.5"/>
                        <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
                    </svg>
                </div>
                <h3><span data-ar>رسالتنا</span><span data-en>Our Mission</span></h3>
                <p>
                    <span data-ar>@Get("mission.text.ar.ar")</span>
                    <span data-en>@Get("mission.text.en.en")</span>
                </p>
            </div>
            <div class="mission-card">
                <span class="tag">02</span>
                <div class="ico">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                        <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                </div>
                <h3><span data-ar>رؤيتنا</span><span data-en>Our Vision</span></h3>
                <p>
                    <span data-ar>@Get("vision.text.ar.ar")</span>
                    <span data-en>@Get("vision.text.en.en")</span>
