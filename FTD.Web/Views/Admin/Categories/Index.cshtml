@model List<CategoryDto>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "الكاتيجوريز";
}

<div style="display:flex;justify-content:flex-end;margin-bottom:1.5rem">
  <a href="/Admin/AdminCategories/Create" class="a-btn">+ كاتيجوري جديدة</a>
</div>

<div class="a-card">
  <div class="a-table-wrap">
    <table class="a-table">
      <thead>
        <tr>
          <th>الكاتيجوري</th>
          <th>Slug</th>
          <th>عدد المنتجات</th>
          <th>الترتيب</th>
          <th>الحالة</th>
          <th>الرئيسية</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        @foreach (var cat in Model)
        {
            <tr>
              <td>
                <div style="display:flex;align-items:center;gap:10px">
                  @if (!string.IsNullOrEmpty(cat.ImagePath))
                  {
                    <img src="@cat.ImagePath" alt="@cat.NameEn" style="width:38px;height:38px;object-fit:cover;border-radius:8px;border:1px solid var(--a-border)">
                  }
                  else
                  {
                    <span style="font-size:22px">@(cat.Emoji ?? "📦")</span>
                  }
                  <div>
                    <div style="font-weight:700">@cat.NameAr</div>
                    <div style="font-size:12px;color:var(--a-text2)">@cat.NameEn</div>
                  </div>
                </div>
              </td>

              <td><span style="font-family:monospace;font-size:12px;color:var(--a-blue)">@cat.Slug</span></td>
              <td>@cat.ProductsCount منتج</td>
              <td>@cat.SortOrder</td>
              <td>
                <span class="status-badge @(cat.IsActive ? "badge-active" : "badge-inactive")">
                  @(cat.IsActive ? "نشط" : "مخفي")
                </span>
              </td>
              <td>
                <span class="status-badge @(cat.ShowOnHomepage ? "badge-active" : "badge-inactive")">
                  @(cat.ShowOnHomepage ? "🏠 تظهر" : "مخفية")
                </span>
              </td>
              <td><a href="/Admin/AdminCategories/Edit/@cat.Id" class="a-btn-sm">تعديل</a></td>
            </tr>
        }
      </tbody>
    </table>
  </div>
</div>
