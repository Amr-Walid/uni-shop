@* _SectionEditor_Gallery.cshtml — interactive image gallery with lightbox *@
@model PageSectionDto
@{
    string titleAr = "", titleEn = "";
    var r = SectionJson.Root(Model.ContentJson);
    if (r.HasValue)
    {
        titleAr = SectionJson.Str(r.Value, "title_ar");
        titleEn = SectionJson.Str(r.Value, "title_en");
    }
    var imgs = new List<(string url, string capAr, string capEn)>();
    foreach (var el in SectionJson.Items(Model.ContentJson))
        imgs.Add((SectionJson.Str(el, "url"), SectionJson.Str(el, "cap_ar"), SectionJson.Str(el, "cap_en")));
    var sid = Model.Id;
}
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
    <div class="a-form-group">
        <label>عنوان المعرض بالعربي (اختياري)</label>
        <input type="text" name="title_ar" value="@titleAr" placeholder="معرض الصور">
    </div>
    <div class="a-form-group">
        <label>Gallery Title EN (optional)</label>
        <input type="text" name="title_en" value="@titleEn" placeholder="Gallery" dir="ltr">
    </div>
</div>

<div id="galRows-@sid" class="builder-rows" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:.8rem">
    @for (int i = 0; i < imgs.Count; i++)
    {
        var g = imgs[i];
        var uid = $"{sid}_{i}";
        <div class="gal-row builder-row" style="background:var(--a-bg);border-radius:10px;padding:.8rem;border:1px solid var(--a-border)">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem">
                <span style="font-size:11px;font-weight:700;color:var(--a-text3)">🖼 صورة</span>
                <button type="button" onclick="this.closest('.gal-row').remove()" style="background:none;border:none;color:var(--a-text3);cursor:pointer">✕</button>
            </div>
            <div class="img-preview" data-preview="gal_img_@uid"
                 style="width:100%;height:110px;border-radius:8px;border:1px solid var(--a-border);background:#fff center/cover no-repeat;margin-bottom:.5rem;@(string.IsNullOrEmpty(g.url) ? "" : $"background-image:url('{g.url}')")"></div>
            <input type="hidden" name="gal_url_@sid" id="gal_img_@uid" value="@g.url">
            <input type="file" accept=".png,.jpg,.jpeg,.webp,.gif" class="ajax-img-upload" data-target="gal_img_@uid" style="font-size:11px;width:100%;margin-bottom:.5rem">
            <input type="text" name="gal_cap_ar_@sid" value="@g.capAr" placeholder="تعليق بالعربي (اختياري)" style="margin-bottom:.4rem">
            <input type="text" name="gal_cap_en_@sid" value="@g.capEn" placeholder="Caption EN (optional)" dir="ltr">
        </div>
    }
</div>
<button type="button" class="a-btn-sm add-gal-row" data-sid="@sid" style="margin-top:.8rem">+ صورة جديدة</button>
@await Html.PartialAsync("~/Views/Admin/Content/_SectionStyleControls.cshtml", Model)
