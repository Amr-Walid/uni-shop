@section Scripts {
<script>
    // ── Product picker (add / remove / reorder) ──
    document.querySelectorAll('.picker-wrap').forEach(function (wrap) {
        var available = wrap.querySelector('[data-role="available"]');
        var selected = wrap.querySelector('[data-role="selected"]');
        var inputName = selected.dataset.inputName;

        function renumber() {
            selected.querySelectorAll('li').forEach(function (li, i) {
                var num = li.querySelector('.p-num');
                if (num) num.textContent = i + 1;
            });
            if (!selected.querySelector('li')) {
                if (!selected.querySelector('.picker-empty')) {
                    var d = document.createElement('div');
                    d.className = 'picker-empty';
                    d.textContent = 'لم يتم اختيار منتجات — سيتم استخدام الافتراضي';
                    selected.appendChild(d);
                }
            } else {
                var e = selected.querySelector('.picker-empty');
                if (e) e.remove();
            }
        }

        function makeSelectedLi(id, name) {
            var li = document.createElement('li');
            li.dataset.id = id;
            li.dataset.name = name;
            li.innerHTML = '<span class="p-num"></span><span class="p-name"></span>'
                + '<button type="button" class="up" title="أعلى"><i class="bi bi-arrow-up"></i></button>'
                + '<button type="button" class="down" title="أسفل"><i class="bi bi-arrow-down"></i></button>'
                + '<button type="button" class="rm" title="إزالة"><i class="bi bi-x-lg"></i></button>'
                + '<input type="hidden" name="' + inputName + '" value="' + id + '">';
            li.querySelector('.p-name').textContent = name;
            return li;
        }

        function makeAvailableLi(id, name) {
            var li = document.createElement('li');
            li.dataset.id = id;
            li.dataset.name = name;
            li.innerHTML = '<span class="p-name"></span><button type="button" class="add" title="إضافة"><i class="bi bi-plus-lg"></i></button>';
            li.querySelector('.p-name').textContent = name;
            return li;
        }

        wrap.addEventListener('click', function (ev) {
            var btn = ev.target.closest('button');
            if (!btn) return;
            var li = btn.closest('li');
            if (!li) return;

            if (btn.classList.contains('add')) {
                selected.appendChild(makeSelectedLi(li.dataset.id, li.dataset.name));
                li.remove();
            } else if (btn.classList.contains('rm')) {
                available.appendChild(makeAvailableLi(li.dataset.id, li.dataset.name));
                li.remove();
            } else if (btn.classList.contains('up')) {
                var prev = li.previousElementSibling;
                if (prev) li.parentNode.insertBefore(li, prev);
            } else if (btn.classList.contains('down')) {
                var next = li.nextElementSibling;
                if (next) li.parentNode.insertBefore(next, li);
            }
            renumber();
        });

        renumber();
    });
</script>
}
