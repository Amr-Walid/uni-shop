@* _SectionEditor_RichText.cshtml — Quill.js visual editors (AR + EN) *@
@model PageSectionDto
@{
    string bodyAr = "", bodyEn = "";
    if (!string.IsNullOrEmpty(Model.ContentJson))
    {
        try {
            var doc = System.Text.Json.JsonDocument.Parse(Model.ContentJson);
            doc.RootElement.TryGetProperty("ar", out var ar); bodyAr = ar.ValueKind == System.Text.Json.JsonValueKind.String ? ar.GetString() ?? "" : "";
            doc.RootElement.TryGetProperty("en", out var en); bodyEn = en.ValueKind == System.Text.Json.JsonValueKind.String ? en.GetString() ?? "" : "";
        } catch { bodyAr = Model.ContentJson; }
    }
}
<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem" class="quill-pair">
    <div class="a-form-group">
        <label><i class="bi bi-fonts"></i> المحتوى بالعربي</label>
        <div class="quill-holder" data-target="rt_ar_@Model.Id" data-dir="rtl"></div>
        <textarea name="ar" id="rt_ar_@Model.Id" style="display:none">@bodyAr</textarea>
    </div>
    <div class="a-form-group">
        <label><i class="bi bi-fonts"></i> Content in English</label>
        <div class="quill-holder" data-target="rt_en_@Model.Id" data-dir="ltr"></div>
        <textarea name="en" id="rt_en_@Model.Id" style="display:none">@bodyEn</textarea>
    </div>
</div>
@await Html.PartialAsync("~/Views/Admin/Content/_SectionStyleControls.cshtml", Model)
