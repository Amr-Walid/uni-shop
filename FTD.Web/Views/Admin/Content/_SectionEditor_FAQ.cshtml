@* _SectionEditor_FAQ.cshtml *@
@model PageSectionDto
@{
    var items = new List<(string qAr, string qEn, string aAr, string aEn)>();
    foreach (var el in SectionJson.Items(Model.ContentJson))
    {
        items.Add((SectionJson.Str(el, "q_ar"), SectionJson.Str(el, "q_en"),
                   SectionJson.Str(el, "a_ar"), SectionJson.Str(el, "a_en")));
    }
    if (items.Count == 0) items.Add(("", "", "", ""));
    var sid = Model.Id;
}

<p style="font-size:12px;color:var(--a-text2);margin-bottom:1rem">
    كل سطر = سؤال وإجابة. السطور الفارغة بيتم تجاهلها تلقائياً.
</p>

<div id="faqRows-@sid" class="builder-rows">
    @for (int i = 0; i < items.Count; i++)
    {
        var item = items[i];
        <div class="faq-row builder-row" style="background:var(--a-bg);border-radius:10px;padding:1rem;margin-bottom:.8rem;border:1px solid var(--a-border)">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem">
                <span style="font-size:11px;font-weight:700;color:var(--a-text3)">❓ سؤال</span>
                <button type="button" onclick="this.closest('.faq-row').remove()" style="background:none;border:none;color:var(--a-text3);cursor:pointer;font-size:14px">✕</button>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-bottom:.8rem">
                <div class="a-form-group">
                    <label>السؤال بالعربي</label>
                    <input type="text" name="faq_q_ar_@sid" value="@item.qAr" placeholder="ما هي سياسة الإرجاع؟">
                </div>
                <div class="a-form-group">
                    <label>Question in English</label>
                    <input type="text" name="faq_q_en_@sid" value="@item.qEn" placeholder="What is the return policy?" dir="ltr">
                </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem">
                <div class="a-form-group">
                    <label>الإجابة بالعربي</label>
                    <textarea name="faq_a_ar_@sid" rows="2" placeholder="يمكنك الإرجاع خلال 14 يوم...">@item.aAr</textarea>
                </div>
                <div class="a-form-group">
                    <label>Answer in English</label>
                    <textarea name="faq_a_en_@sid" rows="2" placeholder="You can return within 14 days..." dir="ltr">@item.aEn</textarea>
                </div>
            </div>
        </div>
    }
</div>

<button type="button" class="a-btn-sm add-faq-row" data-sid="@sid" style="margin-top:.5rem">+ سؤال جديد</button>
@await Html.PartialAsync("~/Views/Admin/Content/_SectionStyleControls.cshtml", Model)
