@* _SectionEditor_Cards.cshtml — cards with icon OR uploaded image *@
@model PageSectionDto
@{
    var cards = new List<(string titleAr, string titleEn, string bodyAr, string bodyEn, string icon, string img)>();
    foreach (var el in SectionJson.Items(Model.ContentJson))
    {
        cards.Add((SectionJson.Str(el, "title_ar"), SectionJson.Str(el, "title_en"),
                   SectionJson.Str(el, "body_ar"), SectionJson.Str(el, "body_en"),
                   SectionJson.Str(el, "icon"), SectionJson.Str(el, "card_image_path")));
    }
    if (cards.Count == 0) cards.Add(("", "", "", "", "", ""));
    var sid = Model.Id;
}

<div id="cardRows-@sid" class="builder-rows">
    @for (int i = 0; i < cards.Count; i++)
    {
        var c = cards[i];
        var uid = $"{sid}_{i}";
        <div class="card-row builder-row" style="background:var(--a-bg);border-radius:10px;padding:1rem;margin-bottom:.8rem;border:1px solid var(--a-border)">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem">
                <span style="font-size:11px;font-weight:700;color:var(--a-text3)">🃏 كارد</span>
                <button type="button" onclick="this.closest('.card-row').remove()" style="background:none;border:none;color:var(--a-text3);cursor:pointer">✕</button>
            </div>
            <div style="display:grid;grid-template-columns:110px 1fr 1fr;gap:.8rem;margin-bottom:.8rem">
                <div class="a-form-group">
                    <label>Emoji/Icon</label>
                    <input type="text" name="card_icon_@sid" value="@c.icon" placeholder="✓ أو bi-truck">
                </div>
                <div class="a-form-group">
                    <label>العنوان بالعربي</label>
                    <input type="text" name="card_title_ar_@sid" value="@c.titleAr" placeholder="مميزة">
                </div>
                <div class="a-form-group">
                    <label>Title in English</label>
                    <input type="text" name="card_title_en_@sid" value="@c.titleEn" placeholder="Feature" dir="ltr">
                </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-bottom:.8rem">
                <div class="a-form-group">
                    <label>الوصف بالعربي</label>
                    <textarea name="card_body_ar_@sid" rows="2" placeholder="وصف المميزة...">@c.bodyAr</textarea>
                </div>
                <div class="a-form-group">
                    <label>Description in English</label>
                    <textarea name="card_body_en_@sid" rows="2" placeholder="Feature description..." dir="ltr">@c.bodyEn</textarea>
                </div>
            </div>
            <!-- Card image (optional — replaces the icon) -->
            <div style="display:flex;gap:.8rem;align-items:center">
                <div class="img-preview" data-preview="card_img_@uid"
                     style="width:64px;height:48px;border-radius:8px;border:1px solid var(--a-border);background:#fff center/cover no-repeat;flex-shrink:0;@(string.IsNullOrEmpty(c.img) ? "" : $"background-image:url('{c.img}')")"></div>
                <input type="hidden" name="card_image_@sid" id="card_img_@uid" value="@c.img">
                <input type="file" accept=".png,.jpg,.jpeg,.webp,.svg,.gif" class="ajax-img-upload" data-target="card_img_@uid" style="font-size:12px;flex:1">
                <button type="button" class="a-btn-sm a-btn-danger clear-img" data-target="card_img_@uid" style="@(string.IsNullOrEmpty(c.img) ? "display:none" : "")">✕</button>
            </div>
            <small style="font-size:10.5px;color:var(--a-text3)">صورة الكارد اختيارية — لو اترفعت بتظهر مكان الأيقونة</small>
        </div>
    }
</div>
<button type="button" class="a-btn-sm add-card-row" data-sid="@sid">+ كارد جديد</button>
@await Html.PartialAsync("~/Views/Admin/Content/_SectionStyleControls.cshtml", Model)
