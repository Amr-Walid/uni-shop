@model List<FTD.Web.Models.ContactMessage>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "رسائل التواصل";
    var unread = Model.Count(m => !m.IsRead);
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
    <div style="display:flex;align-items:center;gap:10px">
        <span style="font-size:13px;color:var(--a-text2)">إجمالي: @Model.Count رسالة</span>
        @if (unread > 0)
        {
            <span style="background:var(--a-blue);color:white;font-size:11px;font-weight:700;padding:3px 10px;border-radius:100px">
                @unread غير مقروءة
            </span>
        }
    </div>
    @if (Model.Any(m => m.IsRead))
    {
        <form action="/Admin/AdminMessages/DeleteRead" method="post" style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="a-btn-sm a-btn-danger"
                    onclick="return confirm('حذف كل الرسائل المقروءة؟')">
                حذف المقروءة
            </button>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div style="text-align:center;padding:4rem;color:var(--a-text2);background:var(--a-card);border-radius:14px;border:1px dashed var(--a-border)">
        <div style="font-size:2.5rem;margin-bottom:.5rem">📭</div>
        <p>لا توجد رسائل بعد</p>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;gap:.8rem">
        @foreach (var msg in Model)
        {
            <div class="a-card" style="border-right:3px solid @(msg.IsRead ? "var(--a-border)" : "var(--a-blue)")">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem">
                    <div style="flex:1;min-width:0">
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:.6rem;flex-wrap:wrap">
                            @if (!msg.IsRead)
                            {
                                <span style="width:8px;height:8px;background:var(--a-blue);border-radius:50%;flex-shrink:0;display:inline-block"></span>
                            }
                            <span style="font-weight:700;font-size:15px">@(msg.Name ?? "—")</span>
                            @if (!string.IsNullOrEmpty(msg.Email))
                            {
                                <a href="mailto:@msg.Email" style="font-size:12px;color:var(--a-blue)">@msg.Email</a>
                            }
                            @if (!string.IsNullOrEmpty(msg.Phone))
                            {
                                <a href="tel:@msg.Phone" style="font-size:12px;color:var(--a-text2)">📞 @msg.Phone</a>
                            }
                            <span style="font-size:11px;color:var(--a-text3);margin-right:auto">
                                @msg.CreatedAt.ToString("dd/MM/yyyy — hh:mm tt")
                            </span>
                        </div>
                        <p style="font-size:14px;color:var(--a-text2);line-height:1.7;margin:0">
                            @msg.Message
                        </p>
                    </div>
                    <div style="display:flex;gap:6px;flex-shrink:0">
                        @if (!msg.IsRead)
                        {
                            <form action="/Admin/AdminMessages/MarkRead/@msg.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="a-btn-sm">✓ قراءة</button>
                            </form>
                        }
                        @if (!string.IsNullOrEmpty(msg.Email))
                        {
                            <a href="mailto:@msg.Email?subject=رد على رسالتك — FTD TechZone"
                               class="a-btn-sm" style="background:rgba(0,196,140,.12);color:#00C48C;border-color:rgba(0,196,140,.2)">
                                رد
                            </a>
                        }
                        <form action="/Admin/AdminMessages/Delete/@msg.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="a-btn-sm a-btn-danger"
                                    onclick="return confirm('حذف الرسالة؟')">حذف</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
