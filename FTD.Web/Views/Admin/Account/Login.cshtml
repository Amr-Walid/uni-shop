@{
    Layout = null;
    ViewData["Title"] = "تسجيل الدخول";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@ViewData["Title"] — Uni-Shop Admin</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
</head>
<body class="admin-body">
<div class="login-page">
  <div class="login-card">
    <div class="login-logo">
      <div class="login-logo-badge">
        <img src="~/images/logo-unishop-icon.png" alt="Uni Shop" style="object-fit:contain" />
      </div>
      <span class="login-wordmark">Uni Shop</span>
    </div>

    <div class="login-title">لوحة التحكم</div>
    <div class="login-sub">Uni-Shop &mdash; Admin Panel</div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="login-error">
            <span>⚠️</span>
            <span>بيانات الدخول غير صحيحة، حاول مرة أخرى</span>
        </div>
    }

    <form method="post" action="/Admin/AdminAccount/Login">
      @Html.AntiForgeryToken()
      <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl">

      <div class="login-group">
        <label>البريد الإلكتروني</label>
        <input type="email" name="email" placeholder="admin@example.com" autocomplete="username" required>
      </div>
      <div class="login-group">
        <label>كلمة المرور</label>
        <input type="password" name="password" placeholder="••••••••" autocomplete="current-password" required>
      </div>

      <button type="submit" class="login-btn">
        <span>دخول</span>
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </form>

    <div class="login-foot">Uni-Shop &copy; @DateTime.Now.Year — لوحة تحكم إدارية محمية</div>
  </div>
</div>
</body>
</html>
