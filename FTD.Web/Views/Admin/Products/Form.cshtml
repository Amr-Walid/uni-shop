@model FTD.Web.ViewModels.ProductFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    Layout = "_AdminLayout";
    var p      = Model.Product;
    var isEdit = p.Id > 0;
    ViewData["Title"] = isEdit ? "تعديل المنتج" : "إضافة منتج جديد";
}

<form action="@(isEdit ? "/Admin/AdminProducts/Edit/" + p.Id : "/Admin/AdminProducts/Create")"
      method="post" enctype="multipart/form-data">
  @Html.AntiForgeryToken()

  <div style="display:grid;grid-template-columns:1fr 340px;gap:1.5rem;align-items:start">

    <!-- MAIN FIELDS -->
    <div>
      <div class="a-card" style="margin-bottom:1.5rem">
        <h3 class="a-card-title">البيانات الأساسية</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem">
          <div class="a-form-group">
            <label>الاسم بالعربي *</label>
            <input type="text" name="Product.NameAr" value="@p.NameAr" placeholder="اسم المنتج بالعربي" required>
          </div>
          <div class="a-form-group">
            <label>الاسم بالإنجليزي *</label>
            <input type="text" name="Product.NameEn" value="@p.NameEn" placeholder="Product name in English" dir="ltr" required>
          </div>
          <div class="a-form-group">
            <label>الـ Slug (URL)</label>
            <input type="text" name="Product.Slug" value="@p.Slug" placeholder="product-name-en" dir="ltr">
            <small style="color:var(--a-text2);font-size:11px">يُترك فارغاً للتوليد تلقائياً</small>
          </div>
          <div class="a-form-group">
            <label>الكاتيجوري *</label>
            <select name="Product.CategoryId" class="a-select" id="catSelect" onchange="loadAttrs(this.value)">
              <option value="">اختر الكاتيجوري...</option>
              @foreach (var cat in Model.Categories)
              {
                  if (p.CategoryId == cat.Id)
                  { <option value="@cat.Id" selected>@cat.NameAr</option> }
                  else
                  { <option value="@cat.Id">@cat.NameAr</option> }
              }
            </select>
          </div>
          <div class="a-form-group">
            <label>البراند</label>
            <select name="Product.BrandId" class="a-select">
              <option value="">— اختر البراند —</option>
              @foreach (var br in Model.Brands)
              {
                  if (p.BrandId == br.Id)
                  { <option value="@br.Id" selected>@br.NameEn</option> }
                  else
                  { <option value="@br.Id">@br.NameEn</option> }
              }
            </select>
          </div>
          <div class="a-form-group">
            <label>Emoji</label>
            <input type="text" name="Product.Emoji" value="@p.Emoji" placeholder="📱">
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-top:1rem">
          <div class="a-form-group">
            <label>وصف مختصر بالعربي</label>
            <textarea name="Product.ShortDescAr" rows="2" placeholder="وصف قصير...">@p.ShortDescAr</textarea>
          </div>
          <div class="a-form-group">
            <label>Short Description EN</label>
            <textarea name="Product.ShortDescEn" rows="2" placeholder="Short description..." dir="ltr">@p.ShortDescEn</textarea>
          </div>
          <div class="a-form-group">
            <label>وصف تفصيلي بالعربي</label>
            <textarea name="Product.DescAr" rows="4" placeholder="وصف تفصيلي...">@p.DescAr</textarea>
          </div>
          <div class="a-form-group">
            <label>Full Description EN</label>
            <textarea name="Product.DescEn" rows="4" placeholder="Full description..." dir="ltr">@p.DescEn</textarea>
          </div>
        </div>
      </div>

      <!-- ATTRIBUTES -->
      <div class="a-card" style="margin-bottom:1.5rem">
        <h3 class="a-card-title">المواصفات التقنية</h3>
        <div id="attrsContainer" style="margin-top:1rem">
          @if (Model.Attributes.Any())
          {
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
                @foreach (var attr in Model.Attributes)
                {
                    <div class="a-form-group" data-attr-group="@attr.Id">
                      <label>@attr.NameAr / @attr.NameEn</label>
                      @if (attr.Values.Any())
                      {
                          <div style="display:flex;gap:6px;align-items:center">
                            <select name="SelectedAttributeValues[@attr.Id]" class="a-select" id="attrSel-@attr.Id" style="flex:1">
                              <option value="">— اختر —</option>
                              @foreach (var val in attr.Values)
                              {
                                  var isSelected = Model.SelectedAttributeValues.ContainsKey(attr.Id) &&
                                                   Model.SelectedAttributeValues[attr.Id] == val.Id;
                                  if (isSelected)
                                  { <option value="@val.Id" selected>@val.ValueAr / @val.ValueEn</option> }
                                  else
                                  { <option value="@val.Id">@val.ValueAr / @val.ValueEn</option> }
                              }
                            </select>
                            <button type="button" class="attr-quick-add-btn" title="إضافة قيمة جديدة"
                                    onclick="toggleQuickAdd(@attr.Id)">+</button>
                          </div>
                          <div class="attr-quick-add-row" id="quickAddRow-@attr.Id" style="display:none;margin-top:6px;gap:6px">
                            <input type="text" id="quickAddInput-@attr.Id" placeholder="اكتب القيمة الجديدة..."
                                   style="flex:1;font-size:13px" onkeydown="quickAddKeydown(event, @attr.Id)">
                            <button type="button" class="a-btn-sm" onclick="submitQuickAdd(@attr.Id)">حفظ</button>
                            <button type="button" class="a-btn-sm" style="opacity:.7" onclick="toggleQuickAdd(@attr.Id)">✕</button>
                          </div>
                      }
                      else
                      {
                          <!-- Free-text spec: no predefined values → type the value directly -->
                          <input type="text" name="FreeTextAttributeValues[@attr.Id]" class="attr-free-text"
                                 placeholder="اكتب القيمة يدوياً (نص حر)..."
                                 value="@(Model.FreeTextAttributeValues.TryGetValue(attr.Id, out var ftv) ? ftv : "")">
                          <small style="color:var(--a-text3);font-size:11px">سيتم إنشاء القيمة تلقائياً عند الحفظ</small>
                      }
                    </div>
                }
              </div>
          }
          else
          {
              <div style="color:var(--a-text3);font-size:12px">
                لا توجد مواصفات — أضف Attributes من قسم الـ Attributes أولاً أو اختر الكاتيجوري الصح
              </div>
          }
        </div>
      </div>

      <!-- IMAGES -->
      <div class="a-card" style="margin-bottom:1.5rem">
        <h3 class="a-card-title" style="margin-bottom:1rem">صور المنتج (حتى 4 صور)</h3>

        @if (Model.ExistingImages.Any())
        {
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.6rem;margin-bottom:1rem">
              @foreach (var img in Model.ExistingImages)
              {
                  <div style="position:relative">
                    <img src="@img.ImagePath"
                         style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:8px;background:var(--a-bg)">
                    @if (img.IsMain)
                    {
                        <span style="position:absolute;top:4px;right:4px;background:var(--a-blue);color:white;font-size:9px;padding:2px 6px;border-radius:4px;font-weight:700">رئيسية</span>
                    }
                    <form action="/Admin/AdminProducts/DeleteImage/@img.Id" method="post"
                          style="position:absolute;top:4px;left:4px">
                      @Html.AntiForgeryToken()
                      <button type="submit"
                              style="background:var(--a-danger);border:none;color:white;border-radius:4px;width:22px;height:22px;cursor:pointer;font-size:12px"
                              onclick="return confirm('حذف الصورة؟')">✕</button>
                    </form>
                  </div>
              }
            </div>
        }

        <div class="a-form-group">
          <label>الصورة الرئيسية</label>
          <input type="file" name="MainImage" accept="image/jpeg,image/png,image/webp" style="font-size:13px">
          <small style="color:var(--a-text3);font-size:11px">تظهر في الـ cards والقوائم</small>
        </div>
        @if (!string.IsNullOrEmpty(p.ImagePath))
        {
            <div style="margin-top:.6rem;background:var(--a-bg);border-radius:8px;padding:.6rem;display:inline-block">
              <img src="@p.ImagePath" style="height:60px;object-fit:contain">
              <div style="font-size:10px;color:var(--a-text3);margin-top:4px;text-align:center">الحالية</div>
            </div>
        }
        <div class="a-form-group" style="margin-top:.8rem">
          <label>صور إضافية (حتى 3)</label>
          <input type="file" name="ProductImages" accept="image/jpeg,image/png,image/webp"
                 multiple style="font-size:13px" onchange="limitFiles(this,3)">
          <small style="color:var(--a-text3);font-size:11px">بتظهر في الـ slider في صفحة المنتج</small>
        </div>
      </div>

      <!-- DYNAMIC FEATURES -->
      <div class="a-card" style="margin-bottom:1.5rem">
        <h3 class="a-card-title" style="margin-bottom:1rem">ميزات المنتج الإضافية (محتويات العلبة)</h3>
        
        <input type="hidden" name="Product.FeaturesJson" id="featuresJsonInput" value="@p.FeaturesJson">
        
        <div id="featuresListContainer" style="display:flex;flex-direction:column;gap:0.8rem;margin-bottom:1.5rem">
          <!-- Populated by JS -->
        </div>

        <div style="background:var(--a-bg);border:1px solid var(--a-border);border-radius:10px;padding:1rem;display:grid;grid-template-columns:100px 1fr 1fr auto;gap:0.8rem;align-items:end">
          <div class="a-form-group" style="margin-bottom:0">
            <label style="font-size:11px">الأيقونة</label>
            <select id="newFeatureIcon" class="a-select" style="padding: 7px 10px;font-size:13px">
              <option value="bi-shield-check">🛡️ ضمان</option>
              <option value="bi-truck">🚚 شحن</option>
              <option value="bi-arrow-counterclockwise">🔄 إرجاع</option>
              <option value="bi-credit-card">💳 تقسيط</option>
              <option value="bi-box-seam">📦 علبة</option>
              <option value="bi-plug">🔌 كهرباء</option>
              <option value="bi-headset">🎧 دعم</option>
              <option value="bi-star">⭐ تقييم</option>
            </select>
          </div>
          <div class="a-form-group" style="margin-bottom:0">
            <label style="font-size:11px">النص بالعربي</label>
            <input type="text" id="newFeatureTextAr" placeholder="مثال: ضمان ١٨ شهر" style="padding: 7px 10px;font-size:13px">
          </div>
          <div class="a-form-group" style="margin-bottom:0">
            <label style="font-size:11px">Text in English</label>
            <input type="text" id="newFeatureTextEn" placeholder="e.g. 18-month warranty" dir="ltr" style="padding: 7px 10px;font-size:13px">
          </div>
          <button type="button" class="a-btn" id="addFeatureBtn" style="padding: 7px 15px;font-size:13px;height:34px">إضافة</button>
        </div>
      </div>
    </div>

    <!-- SIDEBAR -->
    <div>
      <div class="a-card" style="margin-bottom:1rem">
        <h3 class="a-card-title">التسعير والمخزون</h3>
        <div style="display:flex;flex-direction:column;gap:1rem;margin-top:1rem">
          <div class="a-form-group">
            <label>السعر (EGP) *</label>
            <input type="number" name="Product.Price" value="@p.Price" step="0.01" placeholder="0.00" required>
          </div>
          <div class="a-form-group">
            <label>السعر القديم (شطب)</label>
            <input type="number" name="Product.OldPrice" value="@p.OldPrice" step="0.01" placeholder="0.00">
          </div>
          <div class="a-form-group">
            <label>المخزون</label>
            <input type="number" name="Product.Stock" value="@p.Stock" placeholder="0">
          </div>
          <div class="a-form-group">
            <label>الـ Badge</label>
            <select name="Product.Badge" class="a-select">
              <option value="">— بدون —</option>
              @foreach (var b in new[]{"NEW","HOT","SALE","RUGGED","4K"})
              {
                  if (p.Badge == b) { <option selected>@b</option> }
                  else              { <option>@b</option> }
              }
            </select>
          </div>
          <div class="a-form-group">
            <label>الترتيب</label>
            <input type="number" name="Product.SortOrder" value="@p.SortOrder" placeholder="0">
          </div>
        </div>
      </div>

      <div class="a-card" style="margin-bottom:1rem">
        <h3 class="a-card-title">الإعدادات</h3>
        <div style="display:flex;flex-direction:column;gap:.8rem;margin-top:1rem">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px">
            <input type="checkbox" name="Product.IsActive" value="true"
                   @(p.IsActive ? "checked" : "") style="width:16px;height:16px">
            نشط (مرئي في الموقع)
          </label>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px">
            <input type="checkbox" name="Product.IsFeatured" value="true"
                   @(p.IsFeatured ? "checked" : "") style="width:16px;height:16px">
            مميز (يظهر في الصفحة الرئيسية)
          </label>
        </div>
      </div>

      <div class="a-card" style="margin-bottom:1rem">
        <h3 class="a-card-title">SEO</h3>
        <div style="display:flex;flex-direction:column;gap:1rem;margin-top:1rem">
          <div class="a-form-group">
            <label>Meta Title</label>
            <input type="text" name="Product.MetaTitle" value="@p.MetaTitle" placeholder="عنوان لمحركات البحث">
          </div>
          <div class="a-form-group">
            <label>Meta Description</label>
            <textarea name="Product.MetaDesc" rows="2" placeholder="وصف لمحركات البحث...">@p.MetaDesc</textarea>
          </div>
        </div>
      </div>

      <div style="display:flex;gap:.8rem">
        <button type="submit" class="a-btn" style="flex:1">
          @(isEdit ? "💾 حفظ التعديلات" : "✚ إضافة المنتج")
        </button>
        <a href="/Admin/AdminProducts" class="a-btn-outline">إلغاء</a>
      </div>
    </div>

  </div>
</form>

@section Scripts {
<script>
function limitFiles(input, max) {
    if (input.files.length > max) {
        alert("يمكنك رفع " + max + " صور كحد أقصى");
        input.value = "";
    }
}

function escHtml(s) {
    return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

function renderAttrGroup(a) {
    var html = '<div class="a-form-group" data-attr-group="' + a.id + '"><label>' + escHtml(a.nameAr) + ' / ' + escHtml(a.nameEn) + '</label>';
    if (a.values && a.values.length) {
        html += '<div style="display:flex;gap:6px;align-items:center">';
        html += '<select name="SelectedAttributeValues[' + a.id + ']" class="a-select" id="attrSel-' + a.id + '" style="flex:1"><option value="">— اختر —</option>';
        a.values.forEach(function(v) {
            html += '<option value="' + v.id + '">' + escHtml(v.valueAr) + ' / ' + escHtml(v.valueEn) + '</option>';
        });
        html += '</select>';
        html += '<button type="button" class="attr-quick-add-btn" title="إضافة قيمة جديدة" onclick="toggleQuickAdd(' + a.id + ')">+</button>';
        html += '</div>';
        html += '<div class="attr-quick-add-row" id="quickAddRow-' + a.id + '" style="display:none;margin-top:6px;gap:6px">';
        html += '<input type="text" id="quickAddInput-' + a.id + '" placeholder="اكتب القيمة الجديدة..." style="flex:1;font-size:13px" onkeydown="quickAddKeydown(event, ' + a.id + ')">';
        html += '<button type="button" class="a-btn-sm" onclick="submitQuickAdd(' + a.id + ')">حفظ</button>';
        html += '<button type="button" class="a-btn-sm" style="opacity:.7" onclick="toggleQuickAdd(' + a.id + ')">✕</button>';
        html += '</div>';
    } else {
        html += '<input type="text" name="FreeTextAttributeValues[' + a.id + ']" class="attr-free-text" placeholder="اكتب القيمة يدوياً (نص حر)...">';
        html += '<small style="color:var(--a-text3);font-size:11px">سيتم إنشاء القيمة تلقائياً عند الحفظ</small>';
    }
    html += '</div>';
    return html;
}

function loadAttrs(catId) {
    var container = document.getElementById('attrsContainer');
    if (!catId) { container.innerHTML = '<div style="color:var(--a-text3);font-size:12px">اختر الكاتيجوري أولاً</div>'; return; }
    container.innerHTML = '<div style="color:var(--a-text2);font-size:13px;padding:.5rem 0">جاري التحميل...</div>';
    fetch('/Admin/AdminProducts/AttributesByCategory?categoryId=' + catId)
        .then(function(r) { return r.json(); })
        .then(function(attrs) {
            if (!attrs.length) {
                container.innerHTML = '<div style="color:var(--a-text3);font-size:12px">لا توجد مواصفات لهذه الكاتيجوري — أضفها من قسم الـ Attributes</div>';
                return;
            }
            var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">';
            attrs.forEach(function(a) { html += renderAttrGroup(a); });
            html += '</div>';
            container.innerHTML = html;
        })
        .catch(function() {
            container.innerHTML = '<div style="color:var(--a-danger);font-size:12px">خطأ في التحميل</div>';
        });
}

// ── INLINE QUICK-ADD ATTRIBUTE VALUE (AJAX) ─────────────────────────────────
function toggleQuickAdd(attrId) {
    var row = document.getElementById('quickAddRow-' + attrId);
    if (!row) return;
    var visible = row.style.display !== 'none';
    row.style.display = visible ? 'none' : 'flex';
    if (!visible) {
        var input = document.getElementById('quickAddInput-' + attrId);
        if (input) { input.value = ''; input.focus(); }
    }
}

function quickAddKeydown(e, attrId) {
    if (e.key === 'Enter') {
        e.preventDefault(); // don't submit the whole product form
        submitQuickAdd(attrId);
    } else if (e.key === 'Escape') {
        toggleQuickAdd(attrId);
    }
}

function submitQuickAdd(attrId) {
    var input = document.getElementById('quickAddInput-' + attrId);
    var value = (input && input.value || '').trim();
    if (!value) { if (input) input.focus(); return; }

    var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
    var fd = new FormData();
    fd.append('attributeId', attrId);
    fd.append('valueAr', value);
    fd.append('valueEn', value);
    if (tokenEl) fd.append('__RequestVerificationToken', tokenEl.value);

    fetch('/Admin/AdminProducts/QuickAddAttributeValue', { method: 'POST', body: fd })
        .then(function(r) { if (!r.ok) throw new Error('bad'); return r.json(); })
        .then(function(res) {
            if (!res.success) throw new Error('fail');
            var sel = document.getElementById('attrSel-' + attrId);
            if (sel) {
                // If the value already exists in the list (idempotent server), just select it
                var existing = sel.querySelector('option[value="' + res.id + '"]');
                if (!existing) {
                    var opt = document.createElement('option');
                    opt.value = res.id;
                    opt.textContent = res.valueAr + ' / ' + res.valueEn;
                    sel.appendChild(opt);
                }
                sel.value = res.id;
            }
            toggleQuickAdd(attrId);
        })
        .catch(function() {
            alert('تعذر إضافة القيمة — حاول مرة أخرى');
        });
}

document.addEventListener("DOMContentLoaded", function() {
    var featuresInput = document.getElementById("featuresJsonInput");
    var container = document.getElementById("featuresListContainer");
    var addBtn = document.getElementById("addFeatureBtn");
    
    var features = [];
    if (featuresInput && featuresInput.value) {
        try {
            features = JSON.parse(featuresInput.value) || [];
        } catch(e) {
            features = [];
        }
    }

    function renderFeatures() {
        container.innerHTML = "";
        if (features.length === 0) {
            container.innerHTML = '<div style="color:var(--a-text3);font-size:12px;text-align:center;padding:1rem;background:var(--a-bg);border-radius:8px">لا توجد ميزات مخصصة لهذا المنتج (سيتم إخفاء هذا البوكس في صفحة المشتري)</div>';
            return;
        }
        features.forEach(function(f, idx) {
            var row = document.createElement("div");
            row.style.display = "grid";
            row.style.gridTemplateColumns = "40px 120px 1fr 1fr auto";
            row.style.gap = "0.8rem";
            row.style.alignItems = "center";
            row.style.background = "var(--a-bg)";
            row.style.padding = "0.5rem 0.8rem";
            row.style.borderRadius = "8px";
            row.style.border = "1px solid var(--a-border)";

            var emojiSpan = document.createElement("span");
            emojiSpan.style.fontSize = "16px";
            emojiSpan.style.textAlign = "center";
            emojiSpan.innerHTML = getEmojiForIcon(f.icon);

            var iconSpan = document.createElement("span");
            iconSpan.style.fontSize = "11px";
            iconSpan.style.fontFamily = "monospace";
            iconSpan.style.color = "var(--a-text2)";
            iconSpan.textContent = f.icon;

            var textArSpan = document.createElement("span");
            textArSpan.style.fontSize = "13px";
            textArSpan.textContent = f.text_ar;

            var textEnSpan = document.createElement("span");
            textEnSpan.style.fontSize = "13px";
            textEnSpan.dir = "ltr";
            textEnSpan.textContent = f.text_en;

            var delBtn = document.createElement("button");
            delBtn.type = "button";
            delBtn.className = "a-btn-sm a-btn-danger";
            delBtn.style.padding = "4px 8px";
            delBtn.innerHTML = "✕";
            delBtn.addEventListener("click", function() {
                features.splice(idx, 1);
                updateInputAndRender();
            });

            row.appendChild(emojiSpan);
            row.appendChild(iconSpan);
            row.appendChild(textArSpan);
            row.appendChild(textEnSpan);
            row.appendChild(delBtn);
            container.appendChild(row);
        });
    }

    function getEmojiForIcon(icon) {
        switch(icon) {
            case "bi-shield-check": return "🛡️";
            case "bi-truck": return "🚚";
            case "bi-arrow-counterclockwise": return "🔄";
            case "bi-credit-card": return "💳";
            case "bi-box-seam": return "📦";
            case "bi-plug": return "🔌";
            case "bi-headset": return "🎧";
            case "bi-star": return "⭐";
            default: return "✨";
        }
    }

    function updateInputAndRender() {
        featuresInput.value = JSON.stringify(features);
        renderFeatures();
    }

    if (addBtn) {
        addBtn.addEventListener("click", function() {
            var iconVal = document.getElementById("newFeatureIcon").value;
            var textArVal = document.getElementById("newFeatureTextAr").value.trim();
            var textEnVal = document.getElementById("newFeatureTextEn").value.trim();
            
            if (!textArVal || !textEnVal) {
                alert("يرجى إدخال النصوص بالعربية والإنجليزية");
                return;
            }
            
            features.push({
                icon: iconVal,
                text_ar: textArVal,
                text_en: textEnVal
            });
            
            document.getElementById("newFeatureTextAr").value = "";
            document.getElementById("newFeatureTextEn").value = "";
            updateInputAndRender();
        });
    }

    renderFeatures();
});
</script>
}
