@model List<Product>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "المنتجات";
}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem">
  <div></div>
  <a href="/Admin/AdminProducts/Create" class="a-btn">+ إضافة منتج</a>
</div>

<div class="a-card">
  <div class="a-table-wrap">
    <table class="a-table">
      <thead>
        <tr>
          <th>المنتج</th>
          <th>الكاتيجوري</th>
          <th>البراند</th>
          <th>السعر</th>
          <th>المخزون</th>
          <th>الحالة</th>
          <th>الإجراءات</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var p in Model)
        {
            <tr>
              <td>
                <div style="display:flex;align-items:center;gap:10px">
                  <div style="width:40px;height:40px;background:var(--a-bg);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:20px">
                    @(p.Emoji ?? "📦")
                  </div>
                  <div>
                    <div style="font-weight:700;font-size:13px">@p.NameAr</div>
                    <div style="font-size:11px;color:var(--a-text2)">@p.Slug</div>
                  </div>
                </div>
              </td>
              <td style="font-size:13px">@p.Category?.NameAr</td>
              <td><span class="status-badge" style="background:rgba(26,107,255,.1);color:#1A6BFF">@p.BrandName</span></td>
              <td style="font-weight:700">EGP @p.Price.ToString("N0")</td>
              <td>@p.Stock</td>
              <td>
                <span class="status-badge" style="background:@(p.IsActive ? "rgba(0,196,140,.1)" : "rgba(255,59,48,.1)");color:@(p.IsActive ? "#00C48C" : "#FF3B30")">
                  @(p.IsActive ? "نشط" : "مخفي")
                </span>
              </td>
              <td>
                <div style="display:flex;gap:6px">
                  <a href="/Admin/AdminProducts/Edit/@p.Id" class="a-btn-sm">تعديل</a>
                  <form action="/Admin/AdminProducts/Delete" method="post" style="display:inline" onsubmit="return confirm('هل أنت متأكد من حذف هذا المنتج؟')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@p.Id">
                    <button type="submit" class="a-btn-sm a-btn-danger">حذف</button>
                  </form>
                </div>
              </td>
            </tr>
        }
      </tbody>
    </table>
  </div>
</div>
